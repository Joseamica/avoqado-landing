---
import MobileMenu from '../interactive/MobileMenu';
import DemoButton from '../interactive/DemoButton';

interface Props {
	position?: 'fixed' | 'absolute';
    transparentOnTop?: boolean;
}

const { position = 'fixed', transparentOnTop = false } = Astro.props;

const baseClasses = "top-0 left-0 right-0 z-[300] transition-all duration-300";
const solidClasses = "bg-white border-b border-gray-200 shadow-sm white-nav";
const transparentClasses = "bg-transparent border-transparent";
const initialClasses = transparentOnTop ? transparentClasses : solidClasses;
---

<nav
    id="main-navbar"
    data-transparent-on-top={transparentOnTop.toString()}
    class:list={[baseClasses, initialClasses, position, "group"]}
>
	<div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-16">
			<!-- Logo -->
			<div class="flex items-center">
				<a href="/" class="flex items-center focus:outline-none">
					<img
                        src="/imagotipo-white.png"
                        alt="Avoqado Logo"
                        class="h-8 w-auto group-[.white-nav]:hidden transition-all duration-300"
                        width="160"
                        height="32"
                    />
                    <img
                        src="/imagotipo.png"
                        alt="Avoqado Logo"
                        class="h-8 w-auto hidden group-[.white-nav]:block transition-all duration-300"
                        width="160"
                        height="32"
                    />
				</a>
			</div>

			<!-- Desktop Navigation -->
			<div class="hidden lg:flex items-center gap-1">
				<div id="nav-center-links" class="flex items-center gap-1 transition-opacity duration-300">

				<!-- Products Dropdown -->
				<div id="products-menu-trigger" class="relative group/products">
						<button class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white group-[.white-nav]:text-gray-700 group-[.white-nav]:hover:text-black group-hover/products:text-white group-[.white-nav]:group-hover/products:text-black transition-colors flex items-center cursor-pointer rounded-full group-[.white-nav]:hover:bg-gray-100 hover:bg-white/10">
							Productos
							<svg class="w-3.5 h-3.5 ml-1 transition-transform group-hover/products:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
						</button>

						<div class="absolute left-0 w-full h-4 top-full"></div>

						<!-- Products Mega Menu -->
						<div class="fixed top-16 left-0 w-full bg-white text-black origin-top scale-y-0 group-hover/products:scale-y-100 transition-transform duration-200 ease-out border-b border-gray-100 shadow-lg z-50">
							<div class="max-w-[1400px] mx-auto px-8 py-10">
								<div class="grid grid-cols-3 gap-12">
									<!-- Column 1: Software -->
									<div>
										<p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Software</p>
										<div class="space-y-1">
											<a href="/productos/tpv" class="group/item flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
												<div class="w-10 h-10 rounded-lg bg-black flex items-center justify-center shrink-0 mt-0.5">
													<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7" /></svg>
												</div>
												<div>
													<p class="text-sm font-semibold text-gray-900 group-hover/item:text-black">Punto de venta</p>
													<p class="text-xs text-gray-500 mt-0.5">Cobra, gestiona y controla tu negocio</p>
												</div>
											</a>
											<a href="/productos/dashboard" class="group/item flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
												<div class="w-10 h-10 rounded-lg bg-black flex items-center justify-center shrink-0 mt-0.5">
													<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
												</div>
												<div>
													<p class="text-sm font-semibold text-gray-900 group-hover/item:text-black">Dashboard</p>
													<p class="text-xs text-gray-500 mt-0.5">Reportes, analytics y consultor IA</p>
												</div>
											</a>
											<a href="/productos/qr" class="group/item flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
												<div class="w-10 h-10 rounded-lg bg-black flex items-center justify-center shrink-0 mt-0.5">
													<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" /></svg>
												</div>
												<div>
													<p class="text-sm font-semibold text-gray-900 group-hover/item:text-black">Pagos QR</p>
													<p class="text-xs text-gray-500 mt-0.5">El cliente escanea, escoge y paga</p>
												</div>
											</a>
										</div>
									</div>

									<!-- Column 2: Hardware & Pagos -->
									<div>
										<p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Hardware y pagos</p>
										<div class="space-y-1">
											<a href="/productos/tpv" class="group/item flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
												<div class="w-10 h-10 rounded-lg bg-black flex items-center justify-center shrink-0 mt-0.5">
													<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
												</div>
												<div>
													<p class="text-sm font-semibold text-gray-900 group-hover/item:text-black">Terminal TPV</p>
													<p class="text-xs text-gray-500 mt-0.5">Dispositivo todo en uno para cobros</p>
												</div>
											</a>
											<a href="/productos/tpv" class="group/item flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
												<div class="w-10 h-10 rounded-lg bg-black flex items-center justify-center shrink-0 mt-0.5">
													<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
												</div>
												<div>
													<p class="text-sm font-semibold text-gray-900 group-hover/item:text-black">Pagos</p>
													<p class="text-xs text-gray-500 mt-0.5">Acepta tarjetas, contactless y más</p>
												</div>
											</a>
											<a href="/productos/dashboard" class="group/item flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors">
												<div class="w-10 h-10 rounded-lg bg-black flex items-center justify-center shrink-0 mt-0.5">
													<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
												</div>
												<div>
													<p class="text-sm font-semibold text-gray-900 group-hover/item:text-black">Personal</p>
													<p class="text-xs text-gray-500 mt-0.5">Gestiona turnos, roles y propinas</p>
												</div>
											</a>
										</div>
									</div>

									<!-- Column 3: Highlighted -->
									<div class="bg-gray-50 rounded-2xl p-6">
										<p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Destacado</p>
										<div class="space-y-4">
											<div>
												<p class="text-sm font-semibold text-gray-900">Avoqado para Retail</p>
												<p class="text-xs text-gray-500 mt-1">Descubre cómo Avoqado transforma la gestión de tu tienda con inventario, cobros y analytics en una sola plataforma.</p>
												<a href="/retail" class="inline-flex items-center gap-1 text-xs font-semibold text-black mt-2 hover:underline">
													Conocer más
													<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
												</a>
											</div>
											<div class="h-px bg-gray-200"></div>
											<a href="/productos" class="inline-flex items-center gap-1 text-sm font-semibold text-black hover:underline">
												Ver todos los productos
												<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
											</a>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>

				<!-- Industries Dropdown -->
				<div id="mega-menu-trigger" class="relative group/menu">
						<button class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white group-[.white-nav]:text-gray-700 group-[.white-nav]:hover:text-black group-hover/menu:text-white group-[.white-nav]:group-hover/menu:text-black transition-colors flex items-center cursor-pointer rounded-full group-[.white-nav]:hover:bg-gray-100 hover:bg-white/10">
							Industrias
							<svg class="w-3.5 h-3.5 ml-1 transition-transform group-hover/menu:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
						</button>

						<div class="absolute left-0 w-full h-4 top-full"></div>

						<!-- Industries Mega Menu -->
						<div class="fixed top-16 left-0 w-full bg-white text-black origin-top scale-y-0 group-hover/menu:scale-y-100 transition-transform duration-200 ease-out border-b border-gray-100 shadow-lg z-50">
							<div class="max-w-[1400px] mx-auto px-8 py-10">
								<div class="grid grid-cols-4 gap-4">
									<a href="/restaurants" class="group/card p-5 rounded-2xl hover:bg-gray-50 transition-colors">
										<div class="w-12 h-12 rounded-xl bg-orange-50 flex items-center justify-center mb-3">
											<svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
										</div>
										<p class="text-base font-semibold text-gray-900 mb-1">Restaurantes</p>
										<p class="text-sm text-gray-500">TPV, mesas, menú y propinas</p>
									</a>
									<a href="/retail" class="group/card p-5 rounded-2xl hover:bg-gray-50 transition-colors">
										<div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center mb-3">
											<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
										</div>
										<p class="text-base font-semibold text-gray-900 mb-1">Retail</p>
										<p class="text-sm text-gray-500">Inventario, cobros y analytics</p>
									</a>
									<a href="/beauty" class="group/card p-5 rounded-2xl hover:bg-gray-50 transition-colors">
										<div class="w-12 h-12 rounded-xl bg-pink-50 flex items-center justify-center mb-3">
											<svg class="w-6 h-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
										</div>
										<p class="text-base font-semibold text-gray-900 mb-1">Belleza</p>
										<p class="text-sm text-gray-500">Citas, clientes y pagos</p>
									</a>
									<a href="/services" class="group/card p-5 rounded-2xl hover:bg-gray-50 transition-colors">
										<div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center mb-3">
											<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
										</div>
										<p class="text-base font-semibold text-gray-900 mb-1">Servicios</p>
										<p class="text-sm text-gray-500">Agenda, facturación y CRM</p>
									</a>
								</div>
								<div class="mt-6 pt-6 border-t border-gray-100">
									<a href="/#industries" class="inline-flex items-center gap-1 text-sm font-semibold text-gray-500 hover:text-black transition-colors">
										Ver todos los tipos de negocio
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
									</a>
								</div>
							</div>
						</div>
					</div>

					<a href="/pricing" class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white group-[.white-nav]:text-gray-700 group-[.white-nav]:hover:text-black transition-colors rounded-full group-[.white-nav]:hover:bg-gray-100 hover:bg-white/10">
						Precios
					</a>
					<a href="/contact" class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white group-[.white-nav]:text-gray-700 group-[.white-nav]:hover:text-black transition-colors rounded-full group-[.white-nav]:hover:bg-gray-100 hover:bg-white/10">
						Contacto
					</a>
				</div>
				<div class="flex items-center gap-3 ml-6">
					<a
						href="https://dashboard.avoqado.io"
						class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white group-[.white-nav]:text-gray-700 group-[.white-nav]:hover:text-black transition-colors"
					>
						Iniciar sesión
					</a>
					<DemoButton client:load />
				</div>
			</div>

			<!-- Mobile Menu Component -->
			<MobileMenu client:load />
		</div>
	</div>
</nav>

<style>
	.white-nav .demo-btn {
		background-color: black !important;
		color: white !important;
	}
	.white-nav .demo-btn:hover {
		background-color: #1f1f1f !important;
	}
</style>

<script>
    const navbar = document.getElementById('main-navbar');
    const navLinks = document.getElementById('nav-center-links');
    const megaMenuTrigger = document.getElementById('mega-menu-trigger');
    const productsMenuTrigger = document.getElementById('products-menu-trigger');

    if (navbar && navbar.dataset.transparentOnTop === 'true') {
        const transparentClasses = ["bg-transparent", "border-transparent"];
        const whiteClasses = ["bg-white", "border-b", "border-gray-200", "shadow-sm", "white-nav"];

        let isMegaMenuOpen = false;

        const updateNavbar = () => {
             if (isMegaMenuOpen || window.scrollY > 50) {
                navbar.classList.remove(...transparentClasses);
                navbar.classList.add(...whiteClasses);
                if (navLinks && window.scrollY > 50 && !isMegaMenuOpen) {
                    navLinks.classList.add('opacity-0', 'pointer-events-none');
                    navLinks.classList.remove('opacity-100');
                } else if (navLinks) {
                    navLinks.classList.remove('opacity-0', 'pointer-events-none');
                    navLinks.classList.add('opacity-100');
                }
            } else {
                navbar.classList.remove(...whiteClasses);
                navbar.classList.add(...transparentClasses);
                if (navLinks) {
                    navLinks.classList.remove('opacity-0', 'pointer-events-none');
                    navLinks.classList.add('opacity-100');
                }
            }
        };

        if (megaMenuTrigger) {
            megaMenuTrigger.addEventListener('mouseenter', () => {
                isMegaMenuOpen = true;
                updateNavbar();
            });
            megaMenuTrigger.addEventListener('mouseleave', () => {
                isMegaMenuOpen = false;
                updateNavbar();
            });
        }

        if (productsMenuTrigger) {
            productsMenuTrigger.addEventListener('mouseenter', () => {
                isMegaMenuOpen = true;
                updateNavbar();
            });
            productsMenuTrigger.addEventListener('mouseleave', () => {
                isMegaMenuOpen = false;
                updateNavbar();
            });
        }

        updateNavbar();
        window.addEventListener('scroll', updateNavbar, { passive: true });
    }
</script>
