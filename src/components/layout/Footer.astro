---
import { Image } from 'astro:assets';

const SUPPORT_WHATSAPP_URL = 'https://wa.me/525640070001';
---

<footer class="bg-avoqado-black text-white py-12">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
			<!-- Logo & Description -->
			<div class="col-span-1 md:col-span-2">
				<div class="flex items-center space-x-2 mb-4">
					<Image src="/isotipo.svg" alt="Avoqado" class="w-10 h-10 brightness-200" width={40} height={40} loading="lazy" />
					<span class="text-xl font-semibold">AVOQADO</span>
				</div>
				<p class="text-gray-400 max-w-md">
					Cobros y gestion inteligente para todo tipo de negocio. Simplifica operaciones, mejora la experiencia de tus clientes.
				</p>
			</div>

			<!-- Quick Links -->
			<div>
				<h3 class="font-semibold mb-4">Producto</h3>
				<ul class="space-y-2 text-gray-400">
					<li><a href="/productos/tpv" class="hover:text-avoqado-green transition-colors">TPV</a></li>
					<li><a href="/pricing" class="hover:text-avoqado-green transition-colors">Precios</a></li>
					<li><a href="/contact" class="hover:text-avoqado-green transition-colors">Demo</a></li>
				</ul>
			</div>

			<!-- Contact -->
			<div>
				<h3 class="font-semibold mb-4">Contacto</h3>
				<ul class="space-y-2 text-gray-400">
					<li><a href="mailto:hola@avoqado.io" class="hover:text-avoqado-green transition-colors">hola@avoqado.io</a></li>
					<li><a href={SUPPORT_WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="hover:text-avoqado-green transition-colors">Soporte</a></li>
				</ul>
			</div>
		</div>

		<!-- Bottom Bar -->
		<div class="border-t border-gray-800 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center">
			<p class="text-gray-400 text-sm">
				&copy; {new Date().getFullYear()} Avoqado. Todos los derechos reservados.
			</p>
			<div class="flex space-x-6 mt-4 md:mt-0">
				<a href="/privacy" class="text-gray-400 hover:text-avoqado-green text-sm transition-colors">Aviso de Privacidad</a>
				<a href="/terms" class="text-gray-400 hover:text-avoqado-green text-sm transition-colors">Terminos y Condiciones</a>
			</div>
		</div>
	</div>
</footer>
