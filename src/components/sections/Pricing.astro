<section id="pricing" class="py-20 bg-avoqado-dark-bg">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-16">
			<h2 class="text-4xl md:text-5xl font-semibold mb-4">
				Planes para <span class="text-avoqado-green">cada tipo de negocio</span>
			</h2>
			<p class="text-xl text-gray-400 max-w-3xl mx-auto">
				Sin costos ocultos. Sin contratos largos. Cancela cuando quieras.
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
			<!-- Plan Starter -->
			<div class="bg-avoqado-dark-bg rounded-2xl p-8 border-2 border-gray-700 hover:border-avoqado-green transition-all">
				<div class="text-center mb-6">
					<h3 class="text-2xl font-semibold mb-2 text-white">Starter</h3>
					<p class="text-gray-400 mb-4">Para negocios pequenos</p>
					<div class="text-4xl font-bold mb-2">$99<span class="text-lg text-gray-500 font-normal">/mes</span></div>
					<p class="text-sm text-gray-500">+ 2.9% por transacción</p>
				</div>

				<ul class="space-y-3 mb-8">
					<li class="flex items-start">
						<svg class="w-5 h-5 text-avoqado-green mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
						</svg>
						<span class="text-gray-300">Hasta 500 transacciones/mes</span>
					</li>
					<li class="flex items-start">
						<svg class="w-5 h-5 text-avoqado-green mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
