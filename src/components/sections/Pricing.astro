						</svg>
						<span class="text-gray-300">Dashboard básico</span>
					</li>
					<li class="flex items-start">
						<svg class="w-5 h-5 text-avoqado-green mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
