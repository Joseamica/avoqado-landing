---
---

<section class="py-20 bg-gradient-to-br from-avoqado-dark-bg via-avoqado-dark-surface to-avoqado-dark-bg relative overflow-hidden">
	<!-- Background decoration -->
	<div class="absolute top-0 left-1/4 w-96 h-96 bg-avoqado-green rounded-full opacity-10 blur-3xl" aria-hidden="true"></div>
	<div class="absolute bottom-0 right-1/4 w-96 h-96 bg-avoqado-orange rounded-full opacity-10 blur-3xl" aria-hidden="true"></div>

	<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
		<!-- Early Access Badge -->
		<div class="text-center mb-8">
			<div class="inline-flex items-center gap-2 px-6 py-3 bg-avoqado-green/20 border-2 border-avoqado-green rounded-full text-avoqado-green text-sm font-bold mb-4">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
				</svg>
				EARLY ACCESS
			</div>
		</div>

		<!-- Main Message -->
		<div class="text-center mb-12">
			<h2 class="text-3xl md:text-5xl font-bold mb-6 leading-tight">
				<span class="text-white">Únete a los pioneros que están</span><br/>
				<span class="text-avoqado-green">rompiendo las cadenas</span> de los procesadores
			</h2>
			<p class="text-lg md:text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
				Avoqado está en <strong class="text-white">Early Access</strong>. Estamos perfeccionando la plataforma con un grupo selecto de empresas y pioneros como tú.
			</p>
		</div>

		<!-- Value Props Grid -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
			<div class="bg-avoqado-dark-surface rounded-2xl p-6 border border-avoqado-green/30 text-center">
				<div class="w-10 h-10 mx-auto mb-3 bg-avoqado-green/10 rounded-xl flex items-center justify-center">
					<svg class="w-5 h-5 text-avoqado-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
					</svg>
				</div>
				<h3 class="text-lg font-bold text-white mb-2">Acceso Prioritario</h3>
				<p class="text-sm text-gray-400">Se de los primeros en usar la tecnologia que cambiara la industria</p>
			</div>
			<div class="bg-avoqado-dark-surface rounded-2xl p-6 border border-avoqado-green/30 text-center">
				<div class="w-10 h-10 mx-auto mb-3 bg-avoqado-green/10 rounded-xl flex items-center justify-center">
					<svg class="w-5 h-5 text-avoqado-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
					</svg>
				</div>
				<h3 class="text-lg font-bold text-white mb-2">Influencia Directa</h3>
				<p class="text-sm text-gray-400">Tu feedback moldea el producto. Construimos lo que necesitas</p>
			</div>
			<div class="bg-avoqado-dark-surface rounded-2xl p-6 border border-avoqado-green/30 text-center">
				<div class="w-10 h-10 mx-auto mb-3 bg-avoqado-green/10 rounded-xl flex items-center justify-center">
					<svg class="w-5 h-5 text-avoqado-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
					</svg>
				</div>
				<h3 class="text-lg font-bold text-white mb-2">Soporte VIP</h3>
				<p class="text-sm text-gray-400">Atencion personalizada y onboarding dedicado</p>
			</div>
		</div>

		<!-- CTA -->
		<div class="text-center">
			<p class="text-gray-400 mb-6">
				Cupos limitados para garantizar calidad de soporte durante Early Access
			</p>
			<a
				href="/#contact"
				class="inline-block px-8 py-4 bg-avoqado-green text-white text-lg font-semibold rounded-full hover:opacity-90 hover:scale-105 transition-all shadow-glow-green"
			>
				Solicitar acceso anticipado
			</a>
		</div>

		<!-- Trust Badge -->
		<div class="mt-12 text-center">
			<p class="text-sm text-gray-500 mb-4">Ya estamos trabajando con empresas como la tuya</p>
			<p class="text-xs text-gray-600 max-w-2xl mx-auto">
				Estamos en fase Early Access perfeccionando cada detalle. Los datos que ves en esta página son proyecciones y casos de uso reales de nuestros beta testers.
			</p>
		</div>
	</div>
</section>
