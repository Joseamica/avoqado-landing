---
import Icon from '../ui/Icon.astro';
---

<section class="py-32 bg-black text-white">
	<div class="max-w-[1400px] mx-auto px-6">
		<!-- Header -->
		<div class="mb-24 md:flex md:justify-between md:items-end">
			<div class="max-w-3xl">
				<h2 class="text-5xl md:text-6xl font-light mb-8 font-light tracking-tight leading-tight">
					Una sola plataforma <br/>
					para todo tu negocio.
				</h2>
				<p class="text-xl text-gray-400 font-light max-w-2xl">
					Olvídate de contratar cinco proveedores diferentes. Avoqado unifica pagos, software y hardware en un sistema elegante.
				</p>
			</div>
			
			<div class="hidden md:block">
				<a href="/contact" class="text-white border-b border-white pb-1 hover:text-gray-300 hover:border-gray-300 transition-colors">
					Hablar con ventas →
				</a>
			</div>
		</div>

		<!-- Grid de Sectores - Monochrome Premium -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-32">
			<!-- Restaurantes -->
			<div class="group relative bg-avoqado-dark-surface rounded-3xl p-10 hover:bg-white/5 transition-colors duration-300">
				<div class="mb-8">
					<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3v7c0 1.657 1.343 3 3 3s3-1.343 3-3V3m0 18V11m9-8v7a3 3 0 01-3 3m3-3a3 3 0 003-3V3M18 21V11"></path>
					</svg>
				</div>
				<h3 class="text-2xl font-medium text-white mb-4">Restaurantes</h3>
				<p class="text-gray-500 mb-8 font-light">
					Desde food trucks hasta franquicias. Gestión de mesas, cocina y pedidos online.
				</p>
				<ul class="space-y-4 text-gray-400 text-sm font-light">
					<li class="flex items-center gap-3">
						<span class="w-1.5 h-1.5 bg-white rounded-full"></span>
						Gestión de mesas en vivo
					</li>
					<li class="flex items-center gap-3">
						<span class="w-1.5 h-1.5 bg-white rounded-full"></span>
						Pedidos a cocina (KDS)
					</li>
					<li class="flex items-center gap-3">
						<span class="w-1.5 h-1.5 bg-white rounded-full"></span>
						Menú digital QR
					</li>
				</ul>
			</div>

			<!-- Retail / Tiendas -->
			<div class="group relative bg-avoqado-dark-surface rounded-3xl p-10 hover:bg-white/5 transition-colors duration-300">
				<div class="mb-8">
					<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
					</svg>
				</div>
				<h3 class="text-2xl font-medium text-white mb-4">Retail</h3>
				<p class="text-gray-500 mb-8 font-light">
					Vende en tienda y en línea. Inventario sincronizado y perfiles de clientes.
				</p>
				<ul class="space-y-4 text-gray-400 text-sm font-light">
					<li class="flex items-center gap-3">
						<span class="w-1.5 h-1.5 bg-white rounded-full"></span>
						Inventario multi-ubicación
					</li>
					<li class="flex items-center gap-3">
						<span class="w-1.5 h-1.5 bg-white rounded-full"></span>
						E-commerce integrado
					</li>
					<li class="flex items-center gap-3">
						<span class="w-1.5 h-1.5 bg-white rounded-full"></span>
						Programas de lealtad
					</li>
				</ul>
			</div>

			<!-- Servicios -->
			<div class="group relative bg-avoqado-dark-surface rounded-3xl p-10 hover:bg-white/5 transition-colors duration-300">
				<div class="mb-8">
					<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
				</div>
				<h3 class="text-2xl font-medium text-white mb-4">Servicios</h3>
				<p class="text-gray-500 mb-8 font-light">
					Citas, facturación y pagos recurrentes. Todo lo que necesitas para tu consultorio o salón.
				</p>
				<ul class="space-y-4 text-gray-400 text-sm font-light">
					<li class="flex items-center gap-3">
						<span class="w-1.5 h-1.5 bg-white rounded-full"></span>
						Agendamiento online
					</li>
					<li class="flex items-center gap-3">
						<span class="w-1.5 h-1.5 bg-white rounded-full"></span>
						Cobros recurrentes
					</li>
					<li class="flex items-center gap-3">
						<span class="w-1.5 h-1.5 bg-white rounded-full"></span>
						Recordatorios automáticos
					</li>
				</ul>
			</div>
		</div>

		<!-- Feature Highlight - Clean Layout -->
		<div class="bg-avoqado-dark-surface rounded-3xl p-12 md:p-20 relative overflow-hidden">
			<div class="relative z-10 max-w-2xl">
				<h3 class="text-4xl md:text-5xl font-light text-white mb-8 font-light tracking-tight">
					Enrutamiento Inteligente
				</h3>
				<p class="text-xl text-gray-400 font-light leading-relaxed mb-10">
					Avoqado te libera de los procesadores tradicionales. Nuestra tecnología dirige cada transacción al banco que más te conviene, reduciendo comisiones y tiempos de espera.
				</p>
				
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
					<div>
						<div class="text-4xl font-light text-white mb-2">100%</div>
						<p class="text-sm text-gray-500 uppercase tracking-widest">Flexible</p>
					</div>
					<div>
						<div class="text-4xl font-light text-white mb-2">0</div>
						<p class="text-sm text-gray-500 uppercase tracking-widest">Ataduras</p>
					</div>
					<div>
						<div class="text-4xl font-light text-white mb-2">Tiempo real</div>
						<p class="text-sm text-gray-500 uppercase tracking-widest">Reportes</p>
					</div>
				</div>
			</div>
			
			<!-- Decorative Circle (Subtle) -->
			<div class="absolute -right-20 -bottom-40 w-96 h-96 rounded-full border border-gray-800 opacity-50 z-0"></div>
			<div class="absolute top-10 right-10 opacity-20 hidden lg:block">
				<svg class="w-64 h-64 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
				</svg>
			</div>
		</div>
	</div>
</section>
