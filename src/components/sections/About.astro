---
---

<section id="about" class="py-20 bg-avoqado-dark-surface">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
			<!-- Left Column - Content -->
			<div class="space-y-6">
				<div class="inline-block px-4 py-2 bg-avoqado-green/20 rounded-full text-avoqado-green text-sm font-semibold mb-4">
					Nuestra Visión
				</div>
				<h2 class="text-4xl md:text-5xl font-bold text-white">
					Plataforma de <span class="text-avoqado-green">Inteligencia Operativa</span>
				</h2>
				<p class="text-lg text-gray-300 leading-relaxed">
					Avoqado no es otro procesador de pagos. Somos la <strong class="text-white">primera plataforma unificada</strong> que te libera del encierro de los procesadores tradicionales.
				</p>
				<p class="text-lg text-gray-300 leading-relaxed">
					Nuestro <strong class="text-white">Enrutamiento Inteligente</strong> te da el poder de elegir qué procesador cobra cada transacción. Manual o automático. Tú decides.
				</p>
				<p class="text-lg text-gray-300 leading-relaxed">
					Con <strong class="text-white">5 Pilares Unificados</strong> (Backend + Windows Server + TPV + QR + Dashboard), todo se sincroniza automáticamente. Cero conciliaciones manuales.
				</p>

				<div class="bg-avoqado-green/10 border-l-4 border-avoqado-green p-4 rounded mt-6">
					<p class="text-gray-300 text-sm leading-relaxed">
						<strong class="text-white">Trabajamos con varios sectores</strong> perfeccionando cada detalle. Estamos en Early Access construyendo algo revolucionario.
					</p>
				</div>
			</div>

			<!-- Right Column - 5 Pilares -->
			<div class="relative">
				<div class="bg-gradient-to-br from-avoqado-green/20 to-avoqado-orange/20 rounded-3xl p-8 backdrop-blur-sm border border-white/10">
					<h3 class="text-2xl font-bold text-white mb-6 text-center">Los 5 Pilares Unificados</h3>
					<div class="space-y-4">
						<div class="flex items-center gap-4 bg-avoqado-dark-bg/60 p-4 rounded-xl border border-avoqado-green/30">
							<div class="w-10 h-10 bg-avoqado-green/10 rounded-lg flex items-center justify-center flex-shrink-0">
								<svg class="w-5 h-5 text-avoqado-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"></path>
								</svg>
							</div>
							<div>
								<h4 class="text-white font-semibold">Backend</h4>
								<p class="text-sm text-gray-400">Motor de procesamiento inteligente</p>
							</div>
						</div>

						<div class="flex items-center gap-4 bg-avoqado-dark-bg/60 p-4 rounded-xl border border-avoqado-green/30">
							<div class="w-10 h-10 bg-avoqado-green/10 rounded-lg flex items-center justify-center flex-shrink-0">
								<svg class="w-5 h-5 text-avoqado-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
								</svg>
							</div>
							<div>
								<h4 class="text-white font-semibold">Windows Server</h4>
								<p class="text-sm text-gray-400">Sincronizacion local en tiempo real</p>
							</div>
						</div>

						<div class="flex items-center gap-4 bg-avoqado-dark-bg/60 p-4 rounded-xl border border-avoqado-green/30">
							<div class="w-10 h-10 bg-avoqado-green/10 rounded-lg flex items-center justify-center flex-shrink-0">
								<svg class="w-5 h-5 text-avoqado-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
								</svg>
							</div>
							<div>
								<h4 class="text-white font-semibold">Avoqado TPV</h4>
								<p class="text-sm text-gray-400">Terminal movil para tu staff</p>
							</div>
						</div>

						<div class="flex items-center gap-4 bg-avoqado-dark-bg/60 p-4 rounded-xl border border-avoqado-green/30">
							<div class="w-10 h-10 bg-avoqado-green/10 rounded-lg flex items-center justify-center flex-shrink-0">
								<svg class="w-5 h-5 text-avoqado-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path>
								</svg>
							</div>
							<div>
								<h4 class="text-white font-semibold">Avoqado QR</h4>
								<p class="text-sm text-gray-400">Pago instantaneo en 30 segundos</p>
							</div>
						</div>

						<div class="flex items-center gap-4 bg-avoqado-dark-bg/60 p-4 rounded-xl border border-avoqado-green/30">
							<div class="w-10 h-10 bg-avoqado-green/10 rounded-lg flex items-center justify-center flex-shrink-0">
								<svg class="w-5 h-5 text-avoqado-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
								</svg>
							</div>
							<div>
								<h4 class="text-white font-semibold">Dashboard Web</h4>
								<p class="text-sm text-gray-400">Analytics + Chatbot con IA</p>
							</div>
						</div>
					</div>

					<div class="mt-6 text-center">
						<p class="text-sm text-avoqado-green font-semibold">
							Todo sincronizado automaticamente
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
