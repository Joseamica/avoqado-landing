---
import ContactForm from '../interactive/ContactForm';
import Icon from '../ui/Icon.astro';
---

<section id="contact" class="py-20 bg-gradient-to-br from-avoqado-green to-green-600">
	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-12">
			<div class="inline-flex items-center gap-2 px-6 py-3 bg-white/20 rounded-full text-white text-sm font-bold mb-4">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
				</svg>
				ACCESO ANTICIPADO LIMITADO
			</div>
			<h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
				Únete a los pioneros del <span class="text-black">Enrutamiento Inteligente</span>
			</h2>
			<p class="text-xl text-white/90">
				Solicita acceso Early Access y sé de los primeros en romper las cadenas de los procesadores tradicionales
			</p>
		</div>

		<div class="bg-white rounded-3xl p-8 md:p-12 shadow-2xl">
			<ContactForm client:load />
		</div>

		<div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 text-white">
			<div class="text-center">
				<div class="w-12 h-12 mx-auto mb-3 bg-white/20 rounded-xl flex items-center justify-center">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 6h9m0 0l-3-3m3 3l-3 3M5 12h9m0 0l-3-3m3 3l-3 3M5 18h9m0 0l-3-3m3 3l-3 3"></path>
					</svg>
				</div>
				<h3 class="font-semibold mb-2">Control Total</h3>
				<p class="text-white/80 text-sm">Tu decides que procesador usa cada transaccion</p>
			</div>

			<div class="text-center">
				<div class="w-12 h-12 mx-auto mb-3 bg-white/20 rounded-xl flex items-center justify-center">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
					</svg>
				</div>
				<h3 class="font-semibold mb-2">5 Pilares Unificados</h3>
				<p class="text-white/80 text-sm">Todo sincronizado automaticamente</p>
			</div>

			<div class="text-center">
				<div class="w-12 h-12 mx-auto mb-3 bg-white/20 rounded-xl flex items-center justify-center">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
					</svg>
				</div>
				<h3 class="font-semibold mb-2">IA Integrada</h3>
				<p class="text-white/80 text-sm">Chatbot + Analytics en tiempo real</p>
			</div>
		</div>

		<div class="mt-8 text-center">
			<p class="text-white/70 text-sm">
				Contacto: <a href="mailto:hello@avoqado.io" class="underline hover:text-white">hello@avoqado.io</a>
			</p>
		</div>
	</div>
</section>
