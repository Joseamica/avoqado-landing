---
/**
 * ValueProposition - Premium centered headline (Stripe inspired)
 */

interface Props {
    headline: string;
    ctaText?: string;
    ctaHref?: string;
}

const { headline, ctaText = "Ver todas las capacidades", ctaHref = "#features" } = Astro.props;
---

<section class="py-36 px-6 bg-gradient-to-b from-slate-50/50 to-white relative overflow-hidden">
    <!-- Subtle decorative gradient -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(105,225,133,0.08),transparent_50%)]"></div>
    
    <div class="relative max-w-4xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-medium font-serif text-gray-900 leading-[1.15] mb-10 tracking-tight">
            {headline}
        </h2>
        <a 
            href={ctaHref}
            class="group inline-flex items-center gap-2 px-7 py-3.5 bg-white border border-gray-200 rounded-full text-gray-900 font-medium font-inter shadow-sm hover:shadow-md hover:border-gray-300 hover:-translate-y-0.5 transition-all duration-300"
        >
            {ctaText}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
        </a>
    </div>
</section>

