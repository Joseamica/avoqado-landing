---
import { Image } from 'astro:assets';
import ContactForm from '../interactive/ContactForm';
---

<section id="contact" class="py-32 bg-gradient-to-br from-[--color-avoqado-green] to-green-500 relative overflow-hidden">
	<!-- Background decorations -->
	<div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
	<div class="absolute bottom-0 left-0 w-96 h-96 bg-[--color-avoqado-orange]/20 rounded-full blur-3xl"></div>

	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
		<!-- Logo/Icon -->
		<div class="w-20 h-20 bg-white rounded-full mx-auto mb-8 flex items-center justify-center shadow-xl">
			<Image src="/isotipo.svg" alt="Avoqado" class="w-12 h-12" width={48} height={48} loading="lazy" />
		</div>

		<h2 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
			¿Listo para transformar tu negocio?
		</h2>

		<p class="text-xl md:text-2xl text-white/90 mb-12 max-w-2xl mx-auto">
			Únete a cientos de restaurantes que ya modernizaron sus operaciones con Avoqado
		</p>

		<!-- CTA Form -->
		<div class="bg-white rounded-3xl p-8 md:p-12 shadow-2xl max-w-2xl mx-auto">
			<h3 class="text-2xl font-semibold mb-4">Agenda una demo gratuita</h3>
			<p class="text-gray-600 mb-8">Te mostraremos cómo Avoqado puede ayudar a tu negocio</p>

			<ContactForm client:load />
		</div>

		<!-- Alternative CTA -->
		<div class="mt-12">
			<p class="text-white/90 mb-4">¿Prefieres hablar con nosotros?</p>
			<a href="/contact" class="inline-flex items-center gap-2 text-white text-xl font-semibold hover:underline">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
				</svg>
				Contactar ventas
			</a>
		</div>

		<!-- Trust indicators -->
		<div class="mt-16 flex flex-wrap justify-center gap-8 text-white/80 text-sm">
			<span class="inline-flex items-center gap-1.5">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
				</svg>
				Datos protegidos
			</span>
			<span class="inline-flex items-center gap-1.5">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
				</svg>
				Cancelacion gratuita
			</span>
			<span class="inline-flex items-center gap-1.5">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
				</svg>
				Respuesta en 24hrs
			</span>
		</div>
	</div>
</section>
