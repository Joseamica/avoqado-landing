---
/**
 * TpvFrame — real PAX mockup from the design kits, two variants:
 *
 *  - "frontal"  → PAX A920 Pro, flat, big rectangular screen (public/pax-frame.png).
 *                 Kit: pax_mockup_pack_dark. Handles dense screens.
 *  - "diagonal" → PAX A910S, angled/premium, smaller screen (public/pax-a910s-frame.png).
 *                 Kit: pax_a910s_dark_mockup_pack. Use big type + few modules.
 *
 * The device photo overlays on top (z-2); its transparent screen cutout reveals
 * a DARK screen UI beneath (z-1). The UI is authored on a fixed 343×692 canvas
 * (the kits' design size) and `transform: scale(--s)` to fit the cutout, so it
 * stays crisp and proportional at every viewport (never reflows / clips). --s
 * is set per instance by JS.
 */
interface Props {
  variant?: 'frontal' | 'diagonal';
  /** Device (frame) width. */
  w?: string;
  screenClass?: string;
  class?: string;
}
const { variant = 'frontal', w = '340px', screenClass = '', class: cls = '' } = Astro.props;
const src = variant === 'diagonal' ? '/pax-a910s-frame.png' : '/pax-frame.png';
---

<div class={`tpvf tpvf--${variant} ${cls}`} style={`max-width:${w};`}>
  <div class="tpvf-screen" data-tpvf-screen>
    <div class={`tpvf-canvas ${screenClass}`}>
      <slot />
    </div>
  </div>
  <img src={src} alt="Terminal PAX de Avoqado" class="tpvf-frame-img" draggable="false" aria-hidden="true" />
</div>

<style>
  .tpvf {
    position: relative;
    width: 100%;
    max-width: 340px;
    margin: 0 auto;
    filter: drop-shadow(0 40px 70px rgba(0, 0, 0, 0.4));
  }
  .tpvf--frontal { aspect-ratio: 856 / 1759; }
  .tpvf--diagonal { aspect-ratio: 1 / 1; }

  .tpvf-screen {
    position: absolute;
    z-index: 1;
    overflow: hidden;
    background:
      radial-gradient(120% 62% at 84% 0%, rgba(122, 221, 44, 0.1), transparent 55%),
      #0a0c0b;
    --s: 0.78; /* fallback until JS measures */
  }
  /* frontal: rectangular cutout (kit metadata) */
  .tpvf--frontal .tpvf-screen {
    left: 9.5794%;
    top: 21.3189%;
    width: 80.1402%;
    height: 78.6811%;
    border-radius: 4px 4px 0 0;
  }
  /* diagonal: angled cutout, clipped to the screen polygon (kit metadata) */
  .tpvf--diagonal .tpvf-screen {
    left: 28.9167%;
    top: 23.6667%;
    width: 27.6667%;
    height: 61.0833%;
    clip-path: polygon(0% 1.91%, 99.6988% 0%, 99.6988% 99.8636%, 0.3012% 97.1351%);
  }

  /* fixed design canvas (kit size), scaled to fill the cutout width */
  .tpvf-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 343px;
    height: 692px;
    transform: scale(var(--s));
    transform-origin: top left;
    padding: 16px 15px 18px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .tpvf-frame-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }
</style>

<script>
  // Scale each terminal's 343-wide design canvas to fill its screen cutout.
  const DESIGN_W = 343;
  function fitScreens() {
    document.querySelectorAll<HTMLElement>('[data-tpvf-screen]').forEach((el) => {
      el.style.setProperty('--s', String(el.clientWidth / DESIGN_W));
    });
  }
  fitScreens();
  window.addEventListener('resize', fitScreens);
  window.addEventListener('load', fitScreens);
  if ('ResizeObserver' in window) {
    const ro = new ResizeObserver(fitScreens);
    document.querySelectorAll('[data-tpvf-screen]').forEach((el) => ro.observe(el));
  }
</script>
