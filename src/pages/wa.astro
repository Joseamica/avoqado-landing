---
/**
 * WhatsApp click bridge for ad campaigns.
 *
 * Use this as the ad destination URL instead of a raw wa.me link so the click
 * is measured before the user leaves to WhatsApp (you can't run a pixel inside
 * WhatsApp). GTM is injected site-wide via middleware, so this page fires a
 * `whatsapp_click` dataLayer event (→ GA4, and later Google Ads / LinkedIn
 * conversions) and then redirects to WhatsApp.
 *
 * Examples:
 *   https://avoqado.io/wa?src=googleads_demo
 *   https://avoqado.io/wa?src=linkedin&text=Hola,%20vi%20su%20anuncio%20en%20LinkedIn
 *
 * Query params:
 *   src  – campaign source label (googleads, linkedin, ig_bio, etc.)  [optional]
 *   text – override the pre-filled WhatsApp message                    [optional]
 *
 * Google Ads auto-tagging appends ?gclid=... to this URL automatically; the
 * Google Ads conversion tag in GTM reads it from the page URL, so attribution
 * works without any extra handling here.
 */
export const prerender = true;

const WHATSAPP_NUMBER = '525640070001';
const DEFAULT_MESSAGE = 'Hola, me interesa Avoqado. Vengo de un anuncio.';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="preconnect" href="https://www.googletagmanager.com" />
			<link rel="preconnect" href="https://www.google-analytics.com" />
			<link rel="preconnect" href="https://www.googleadservices.com" />
			<link rel="preconnect" href="https://www.google.com" />
			<!-- Eager, direct gtag: fires the WhatsApp conversion FAST (gtag.js loads ~0.5s),
			     independent of the full GTM container, which loads too slowly on this redirect
			     bridge to fire the custom-event conversion before we leave to WhatsApp. -->
			<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18201754401"></script>
			<script is:inline>
				window.dataLayer = window.dataLayer || [];
				function gtag(){ dataLayer.push(arguments); }
				// /wa is a conversion bridge reached from a WhatsApp CTA (ad/CTA traffic) —
				// grant consent for the conversion (México opt-out; mirrors the site's hybrid
				// default). GTM is NOT injected here (see middleware), so this is the only config.
				gtag('consent', 'default', { ad_storage:'granted', ad_user_data:'granted', ad_personalization:'granted', analytics_storage:'granted', functionality_storage:'granted', security_storage:'granted' });
				gtag('js', new Date());
				gtag('config', 'AW-18201754401');
				gtag('config', 'G-F6JCDF9K3P', { send_page_view: false });
			</script>
			<link rel="icon" type="image/png" href="/favicon.png?v=3" />
		<title>Conectando con WhatsApp… | Avoqado</title>
		<style>
			:root { color-scheme: dark; }
			* { margin: 0; padding: 0; box-sizing: border-box; }
			body {
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				background: #0b0f0d;
				color: #e8efe9;
				font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
				text-align: center;
				padding: 1.5rem;
			}
			.wrap { max-width: 22rem; }
			.spinner {
				width: 56px;
				height: 56px;
				margin: 0 auto 1.5rem;
				border: 4px solid rgba(37, 211, 102, 0.2);
				border-top-color: #25d366;
				border-radius: 50%;
				animation: spin 0.8s linear infinite;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			h1 { font-size: 1.25rem; font-weight: 500; margin-bottom: 0.5rem; }
			p { font-size: 0.9rem; color: #9fb3a6; line-height: 1.5; }
			a { color: #25d366; text-decoration: underline; }
			@media (prefers-reduced-motion: reduce) {
				.spinner { animation: none; border-top-color: rgba(37, 211, 102, 0.2); }
			}
		</style>
	</head>
	<body>
		<div class="wrap">
			<div class="spinner" aria-hidden="true"></div>
			<h1>Conectando con WhatsApp…</h1>
			<p id="fallback">
				Si no abre automáticamente,
				<a id="manual" href="#" rel="noopener">toca aquí para continuar</a>.
			</p>
		</div>

		<script define:vars={{ WHATSAPP_NUMBER, DEFAULT_MESSAGE }}>
			(function () {
				var params = new URLSearchParams(window.location.search);
				var src = params.get('src') || 'direct';
				var page = params.get('page') || '';
				var text = params.get('text') || DEFAULT_MESSAGE;
				var dest = 'https://wa.me/' + WHATSAPP_NUMBER + '?text=' + encodeURIComponent(text);

				// Manual fallback link (also works if JS redirect is blocked).
				var manual = document.getElementById('manual');
				if (manual) manual.href = dest;

				var redirected = false;
				function go() {
					if (redirected) return;
					redirected = true;
					// Debug mode (?debug=1): keep the page instead of redirecting, so the
					// conversion tags can be observed firing/sending. No user ever hits this.
					if (params.get('debug') === '1') return;
					window.location.replace(dest);
				}

				// Mirror to PostHog (product-analytics funnel). This is the single
				// PostHog capture point for whatsapp_click, so every WhatsApp CTA
				// routed through /wa (ad prompt, navbar, footer, hero…) lands in the
				// funnel exactly once. No-op until the user consents — PostHog inits
				// opted-out. `page` is where the click came from (passed via ?page=).
				try {
					window.posthog && window.posthog.capture('whatsapp_click', { wa_source: src, wa_page: page });
				} catch (e) {}

				// Fire the Google Ads conversion + GA4 event DIRECTLY via the eager gtag
				// loaded in <head> — NOT through the full GTM container, which loads too
				// slowly on this redirect bridge to fire the custom-event conversion before
				// we leave to WhatsApp (CDP-verified: only page-level tags fired in time).
				// transport_type:beacon delivers the hit even as the page unloads; the
				// conversion's event_callback redirects as soon as it's sent (~0.5s). No
				// dataLayer 'whatsapp_click' push here, so the GTM tags don't double-count.
				try {
					gtag('event', 'conversion', {
						send_to: 'AW-18201754401/cvaUCLOG-b0cEKH2oudD',
						transport_type: 'beacon',
						event_callback: go,
					});
					gtag('event', 'whatsapp_click', {
						send_to: 'G-F6JCDF9K3P',
						wa_source: src,
						wa_page: page,
						transport_type: 'beacon',
					});
				} catch (e) {}

				setTimeout(go, 3000);
			})();
		</script>
	</body>
</html>
