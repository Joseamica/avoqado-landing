---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingChatbot from '../components/interactive/FloatingChatbot';

const MAGENTA = 'oklch(0.72 0.15 340)';
const GREEN = '#69E185';
const BLUE = 'oklch(0.72 0.14 240)';
const AMBER = 'oklch(0.78 0.14 75)';
const ROSE = 'oklch(0.65 0.18 10)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado para Belleza | Salones, Spas y Wellness</title>
		<meta name="description" content="Plataforma integral para salones, spas, barberias, nail studios y centros de bienestar. Reservaciones, comisiones, CRM y pagos en un solo lugar." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">B&W</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style={`color: ${MAGENTA};`}>Avoqado Beauty</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Tu salon.<br/>Tu sistema.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							Citas, clientes y comisiones en un solo lugar. Reservaciones online, historial de cada cliente, comisiones automaticas por estilista y pagos integrados — todo desde una sola plataforma.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://demo.dashboard.avoqado.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-white font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200" style={`background: ${MAGENTA};`}>
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Hablar con ventas
							</a>
						</div>
					</div>

					<!-- Calendar mockup -->
					<div class="hidden lg:block">
						<div class="rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
							<!-- Header -->
							<div class="flex items-center justify-between mb-4">
								<div class="flex items-center gap-2">
									<div class="w-6 h-6 rounded-lg flex items-center justify-center" style={`background: oklch(0.18 0.02 340); color: ${MAGENTA};`}>
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>
									</div>
									<span class="text-[11px] text-white font-medium">Agenda — Hoy, 19 mar</span>
								</div>
								<div class="flex gap-1.5">
									<span class="text-[8px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 340); color: ${MAGENTA};`}>8 citas</span>
									<span class="text-[8px] px-2 py-0.5 rounded-full bg-avoqado-green text-black">2 libres</span>
								</div>
							</div>
							<!-- Time slots -->
							<div class="space-y-1.5 mb-4">
								<div class="flex items-center gap-2">
									<span class="text-[9px] text-gray-600 w-10 shrink-0 text-right">09:00</span>
									<div class="flex-1 rounded-lg p-2.5 flex items-center justify-between" style={`background: oklch(0.18 0.02 340); border-left: 3px solid ${MAGENTA};`}>
										<div>
											<span class="text-[10px] text-white">Corte + Balayage</span>
											<span class="text-[8px] text-gray-500 block">Lucia M. — Diana (Est. 2)</span>
										</div>
										<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.22 0.03 340); color: ${MAGENTA};`}>2h 30m</span>
									</div>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-[9px] text-gray-600 w-10 shrink-0 text-right">09:30</span>
									<div class="flex-1 rounded-lg p-2.5 flex items-center justify-between" style={`background: oklch(0.18 0.02 340); border-left: 3px solid ${MAGENTA};`}>
										<div>
											<span class="text-[10px] text-white">Barba + Corte clasico</span>
											<span class="text-[8px] text-gray-500 block">Carlos R. — Erick (Est. 1)</span>
										</div>
										<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.22 0.03 340); color: ${MAGENTA};`}>1h</span>
									</div>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-[9px] text-gray-600 w-10 shrink-0 text-right">10:30</span>
									<div class="flex-1 rounded-lg p-2.5 flex items-center justify-between" style="background: oklch(0.16 0.005 155); border-left: 3px solid oklch(0.40 0.005 155);">
										<div>
											<span class="text-[10px] text-gray-400">Espacio libre</span>
											<span class="text-[8px] text-gray-600 block">Erick (Est. 1) disponible</span>
										</div>
										<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.18 0.02 340); color: ${MAGENTA};`}>Agendar</span>
									</div>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-[9px] text-gray-600 w-10 shrink-0 text-right">11:00</span>
									<div class="flex-1 rounded-lg p-2.5 flex items-center justify-between" style={`background: oklch(0.18 0.02 75); border-left: 3px solid ${AMBER};`}>
										<div>
											<span class="text-[10px] text-white">Manicure + Pedicure gel</span>
											<span class="text-[8px] text-gray-500 block">Sofia G. — Valentina (Est. 3)</span>
										</div>
										<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.22 0.03 75); color: ${AMBER};`}>1h 30m</span>
									</div>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-[9px] text-gray-600 w-10 shrink-0 text-right">12:00</span>
									<div class="flex-1 rounded-lg p-2.5 flex items-center justify-between" style={`background: oklch(0.18 0.02 340); border-left: 3px solid ${MAGENTA};`}>
										<div>
											<span class="text-[10px] text-white">Tinte + Tratamiento keratina</span>
											<span class="text-[8px] text-gray-500 block">Ana L. — Diana (Est. 2)</span>
										</div>
										<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.22 0.03 340); color: ${MAGENTA};`}>3h</span>
									</div>
								</div>
							</div>
							<!-- Legend -->
							<div class="flex items-center gap-4 pt-3 border-t border-white/5">
								<div class="flex items-center gap-1.5">
									<div class="w-2 h-2 rounded-sm" style={`background: ${MAGENTA};`}></div>
									<span class="text-[8px] text-gray-500">Confirmada</span>
								</div>
								<div class="flex items-center gap-1.5">
									<div class="w-2 h-2 rounded-sm" style={`background: ${AMBER};`}></div>
									<span class="text-[8px] text-gray-500">Pendiente</span>
								</div>
								<div class="flex items-center gap-1.5">
									<div class="w-2 h-2 rounded-sm" style="background: oklch(0.25 0.005 155);"></div>
									<span class="text-[8px] text-gray-500">Libre</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. RESERVACIONES                            -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${MAGENTA};`}>Reservaciones</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Agenda sin esfuerzo.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Tus clientes reservan desde tu pagina de booking o WhatsApp. El sistema asigna estacion, bloquea el horario y envia recordatorio automatico. Si no confirman, libera el espacio.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${MAGENTA};`}></div>
								<span class="text-sm text-gray-600">Booking online 24/7 con pagina publica personalizada</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-600">Waitlist automatica cuando no hay disponibilidad</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${AMBER};`}></div>
								<span class="text-sm text-gray-600">Recordatorios por WhatsApp 24h y 1h antes de la cita</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${BLUE};`}></div>
								<span class="text-sm text-gray-600">Deposito con Stripe para reducir no-shows</span>
							</div>
						</div>
					</div>

					<!-- Booking calendar mockup -->
					<div class="rounded-2xl overflow-hidden border border-black/5 p-5" style="background: #0A0A0A;">
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-gray-500">Reservaciones — Semana del 17 mar</span>
							<div class="flex gap-1.5">
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 340); color: ${MAGENTA};`}>Dia</span>
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: ${MAGENTA}; color: white;`}>Semana</span>
								<span class="text-[9px] px-2 py-0.5 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">Mes</span>
							</div>
						</div>
						<!-- Week grid -->
						<div class="grid grid-cols-6 gap-1 mb-4">
							<!-- Header row -->
							<div class="text-center py-1"></div>
							<div class="text-center py-1"><span class="text-[8px] text-gray-600">Lun 17</span></div>
							<div class="text-center py-1"><span class="text-[8px] text-gray-600">Mar 18</span></div>
							<div class="text-center py-1 rounded" style={`background: oklch(0.18 0.02 340);`}><span class="text-[8px]" style={`color: ${MAGENTA};`}>Mie 19</span></div>
							<div class="text-center py-1"><span class="text-[8px] text-gray-600">Jue 20</span></div>
							<div class="text-center py-1"><span class="text-[8px] text-gray-600">Vie 21</span></div>
							<!-- 09:00 -->
							<div class="text-right pr-1 py-2"><span class="text-[8px] text-gray-600">09:00</span></div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 340); border-left: 2px solid ${MAGENTA};`}>
								<span class="text-[7px] text-white block">Lucia M.</span>
								<span class="text-[6px] text-gray-500">Balayage</span>
							</div>
							<div class="rounded p-1" style="background: oklch(0.16 0.005 155);">
								<span class="text-[7px] text-gray-500 block">Libre</span>
							</div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 340); border-left: 2px solid ${MAGENTA};`}>
								<span class="text-[7px] text-white block">Marta S.</span>
								<span class="text-[6px] text-gray-500">Corte</span>
							</div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 75); border-left: 2px solid ${AMBER};`}>
								<span class="text-[7px] text-white block">Reservada</span>
								<span class="text-[6px]" style={`color: ${AMBER};`}>Pend.</span>
							</div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 340); border-left: 2px solid ${MAGENTA};`}>
								<span class="text-[7px] text-white block">Ana T.</span>
								<span class="text-[6px] text-gray-500">Tinte</span>
							</div>
							<!-- 11:00 -->
							<div class="text-right pr-1 py-2"><span class="text-[8px] text-gray-600">11:00</span></div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 340); border-left: 2px solid ${MAGENTA};`}>
								<span class="text-[7px] text-white block">Carlos R.</span>
								<span class="text-[6px] text-gray-500">Barba</span>
							</div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 340); border-left: 2px solid ${MAGENTA};`}>
								<span class="text-[7px] text-white block">Sofia G.</span>
								<span class="text-[6px] text-gray-500">Manicure</span>
							</div>
							<div class="rounded p-1" style="background: oklch(0.16 0.005 155);">
								<span class="text-[7px] text-gray-500 block">Libre</span>
							</div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 340); border-left: 2px solid ${MAGENTA};`}>
								<span class="text-[7px] text-white block">Rosa P.</span>
								<span class="text-[6px] text-gray-500">Pedicure</span>
							</div>
							<div class="rounded p-1" style="background: oklch(0.16 0.005 155);">
								<span class="text-[7px] text-gray-500 block">Libre</span>
							</div>
							<!-- 13:00 -->
							<div class="text-right pr-1 py-2"><span class="text-[8px] text-gray-600">13:00</span></div>
							<div class="rounded p-1" style="background: oklch(0.16 0.005 155);">
								<span class="text-[7px] text-gray-500 block">Libre</span>
							</div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 340); border-left: 2px solid ${MAGENTA};`}>
								<span class="text-[7px] text-white block">Elena V.</span>
								<span class="text-[6px] text-gray-500">Keratina</span>
							</div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 340); border-left: 2px solid ${MAGENTA};`}>
								<span class="text-[7px] text-white block">Lucia M.</span>
								<span class="text-[6px] text-gray-500">Retoque</span>
							</div>
							<div class="rounded p-1" style="background: oklch(0.16 0.005 155);">
								<span class="text-[7px] text-gray-500 block">Libre</span>
							</div>
							<div class="rounded p-1" style={`background: oklch(0.18 0.02 340); border-left: 2px solid ${MAGENTA};`}>
								<span class="text-[7px] text-white block">Julia M.</span>
								<span class="text-[6px] text-gray-500">Extensiones</span>
							</div>
						</div>
						<!-- Booking link -->
						<div class="rounded-lg p-3 flex items-center justify-between" style="background: oklch(0.14 0.02 155); border: 1px solid oklch(0.25 0.03 155);">
							<div>
								<span class="text-[10px] text-white">Pagina de booking publica</span>
								<span class="text-[9px] text-avoqado-green block">book.avoqado.io/tu-salon</span>
							</div>
							<span class="text-[9px] px-2 py-0.5 rounded bg-avoqado-green text-black font-medium">Compartir</span>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. CLIENTES VIP                             -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Client profile mockup -->
					<div class="order-2 lg:order-1 rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
						<!-- Client header -->
						<div class="flex items-center gap-3 mb-4">
							<div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold" style={`background: oklch(0.18 0.02 340); color: ${MAGENTA};`}>LM</div>
							<div>
								<span class="text-sm text-white font-medium">Lucia Martinez</span>
								<div class="flex items-center gap-2 mt-0.5">
									<span class="text-[9px] text-gray-500">Cliente desde feb 2024</span>
									<span class="text-[8px] px-1.5 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 340); color: ${MAGENTA};`}>VIP</span>
								</div>
							</div>
						</div>
						<!-- Stats row -->
						<div class="grid grid-cols-3 gap-2 mb-4">
							<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
								<div class="text-sm font-light text-white">24</div>
								<div class="text-[8px] text-gray-600">Visitas</div>
							</div>
							<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
								<div class="text-sm font-light text-white">$18,400</div>
								<div class="text-[8px] text-gray-600">Total gastado</div>
							</div>
							<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
								<div class="text-sm font-light text-white">$767</div>
								<div class="text-[8px] text-gray-600">Ticket prom.</div>
							</div>
						</div>
						<!-- Tags -->
						<div class="mb-4">
							<div class="text-[9px] text-gray-500 mb-2">Etiquetas</div>
							<div class="flex flex-wrap gap-1.5">
								<span class="text-[8px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.04 10); color: ${ROSE};`}>Alergica a amoniaco</span>
								<span class="text-[8px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 340); color: ${MAGENTA};`}>Prefiere Diana</span>
								<span class="text-[8px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 75); color: ${AMBER};`}>Horario matutino</span>
								<span class="text-[8px] px-2 py-0.5 rounded-full bg-avoqado-green/10 text-avoqado-green">Cumpleanos: 15 abr</span>
							</div>
						</div>
						<!-- Preferences -->
						<div class="mb-4">
							<div class="text-[9px] text-gray-500 mb-2">Preferencias registradas</div>
							<div class="space-y-1.5">
								<div class="flex items-center justify-between p-2 rounded-lg" style="background: oklch(0.16 0.005 155);">
									<span class="text-[9px] text-gray-300">Formula de tinte</span>
									<span class="text-[9px] text-white">6N + 7G (40vol) — 35 min</span>
								</div>
								<div class="flex items-center justify-between p-2 rounded-lg" style="background: oklch(0.16 0.005 155);">
									<span class="text-[9px] text-gray-300">Corte favorito</span>
									<span class="text-[9px] text-white">Capas largas con fleco cortina</span>
								</div>
								<div class="flex items-center justify-between p-2 rounded-lg" style="background: oklch(0.16 0.005 155);">
									<span class="text-[9px] text-gray-300">Bebida</span>
									<span class="text-[9px] text-white">Cafe americano sin azucar</span>
								</div>
							</div>
						</div>
						<!-- Recent history -->
						<div>
							<div class="text-[9px] text-gray-500 mb-2">Historial reciente</div>
							<div class="space-y-1.5">
								<div class="flex items-center justify-between p-2 rounded-lg" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${MAGENTA};`}>
									<div>
										<span class="text-[9px] text-white">Balayage + Corte</span>
										<span class="text-[7px] text-gray-600 block">5 mar — Diana</span>
									</div>
									<span class="text-[9px] text-white">$1,850</span>
								</div>
								<div class="flex items-center justify-between p-2 rounded-lg" style="background: oklch(0.16 0.005 155); border-left: 3px solid oklch(0.40 0.005 155);">
									<div>
										<span class="text-[9px] text-white">Retoque raiz</span>
										<span class="text-[7px] text-gray-600 block">12 feb — Diana</span>
									</div>
									<span class="text-[9px] text-white">$650</span>
								</div>
							</div>
						</div>
					</div>

					<div class="order-1 lg:order-2">
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${MAGENTA};`}>Clientes VIP</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
							Conoce a cada cliente.
