---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingChatbot from '../components/interactive/FloatingChatbot';
import TrajeMedidaHero from '../components/interactive/TrajeMedidaHero';

const GREEN = '#69E185';
const GREEN_BG = 'oklch(0.18 0.04 155)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Traje a la medida | Avoqado</title>
		<meta name="description" content="Construimos funcionalidades a la medida de tu operacion sobre la infraestructura de Avoqado. Entrega en 48 horas promedio. 6 plataformas simultaneas." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- 1. HERO — Scrollytelling with animated module blocks -->
		<TrajeMedidaHero client:visible />


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. QUE CONSTRUIMOS — WHITE BG               -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="max-w-2xl mb-16">
					<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${GREEN};`}>Servicios</span>
					<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
						Lo que necesites. Como lo necesites.
					</h2>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					<!-- Card 1: Interfaces personalizadas — green -->
					<div class="rounded-2xl overflow-hidden p-6 hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155); border-left: 3px solid #69E185;">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center mb-5" style="background: oklch(0.18 0.04 155);">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#69E185" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
						</div>
						<h3 class="text-lg text-white font-medium mb-2">Interfaces personalizadas</h3>
						<p class="text-sm text-gray-500 leading-relaxed">Pantallas, flujos y dashboards disenados para tu operacion especifica. UI/UX que se adapta a como trabaja tu equipo, no al reves.</p>
					</div>

					<!-- Card 2: Modulos de negocio — blue -->
					<div class="rounded-2xl overflow-hidden p-6 hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155); border-left: 3px solid oklch(0.72 0.14 240);">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center mb-5" style="background: oklch(0.18 0.04 240);">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.72 0.14 240)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
						</div>
						<h3 class="text-lg text-white font-medium mb-2">Modulos de negocio</h3>
						<p class="text-sm text-gray-500 leading-relaxed">Funcionalidades especificas por industria: avaluos para joyerias, inventario serializado para telecom, consignacion con comisiones y mas.</p>
					</div>

					<!-- Card 3: Integraciones a terceros — amber -->
					<div class="rounded-2xl overflow-hidden p-6 hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155); border-left: 3px solid oklch(0.78 0.14 75);">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center mb-5" style="background: oklch(0.18 0.04 75);">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.78 0.14 75)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
						</div>
						<h3 class="text-lg text-white font-medium mb-2">Integraciones a terceros</h3>
						<p class="text-sm text-gray-500 leading-relaxed">Conectamos con tu ERP, CRM, contabilidad o cualquier API. Webhooks, sync bidireccional, mapeo de datos — lo que necesites.</p>
					</div>

					<!-- Card 4: White-label completo — magenta -->
					<div class="rounded-2xl overflow-hidden p-6 hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155); border-left: 3px solid oklch(0.72 0.15 340);">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center mb-5" style="background: oklch(0.18 0.04 340);">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.72 0.15 340)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
						</div>
						<h3 class="text-lg text-white font-medium mb-2">White-label completo</h3>
						<p class="text-sm text-gray-500 leading-relaxed">Tu marca, tus colores, tus funcionalidades. Dashboard, app movil y TPV completamente personalizados bajo tu identidad.</p>
					</div>

					<!-- Card 5: Reportes y analytics custom — teal -->
					<div class="rounded-2xl overflow-hidden p-6 hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155); border-left: 3px solid oklch(0.75 0.14 195);">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center mb-5" style="background: oklch(0.18 0.04 195);">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.75 0.14 195)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
						</div>
						<h3 class="text-lg text-white font-medium mb-2">Reportes y analytics custom</h3>
						<p class="text-sm text-gray-500 leading-relaxed">Dashboards ejecutivos, reportes automatizados, KPIs a la medida. Exportacion a Excel y PDF con la estructura que tu definas.</p>
					</div>

					<!-- Card 6: Automatizacion — indigo -->
					<div class="rounded-2xl overflow-hidden p-6 hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155); border-left: 3px solid oklch(0.68 0.15 290);">
						<div class="w-10 h-10 rounded-xl flex items-center justify-center mb-5" style="background: oklch(0.18 0.04 290);">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.68 0.15 290)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/></svg>
						</div>
						<h3 class="text-lg text-white font-medium mb-2">Automatizacion</h3>
						<p class="text-sm text-gray-500 leading-relaxed">Workflows, tareas programadas, alertas inteligentes. Tu operacion en piloto automatico.</p>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 3. PLATAFORMAS — DARK BG                    -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="text-center max-w-2xl mx-auto mb-16">
					<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${GREEN};`}>Plataformas</span>
					<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
						En cualquier plataforma.
					</h2>
					<p class="text-gray-400 text-lg leading-relaxed">
						Tu funcionalidad custom vive donde la necesites. Construimos en paralelo para todas las plataformas del ecosistema Avoqado.
					</p>
				</div>

				<div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 max-w-4xl mx-auto">
					<!-- iOS — Apple logo -->
					<div class="rounded-2xl border border-white/5 p-6 text-center hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155);" onmouseenter="this.style.borderColor='rgba(105,225,133,0.3)'" onmouseleave="this.style.borderColor=''">
						<div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style="background: oklch(0.18 0.04 155);">
							<svg width="20" height="20" viewBox="0 0 384 512" fill="#69E185"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5c0 26.2 4.8 53.3 14.4 81.2 12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
						</div>
						<h3 class="text-base text-white font-medium mb-1">iOS</h3>
						<span class="text-xs text-gray-600">Swift nativo</span>
					</div>

					<!-- Android — Android robot logo -->
					<div class="rounded-2xl border border-white/5 p-6 text-center hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155);" onmouseenter="this.style.borderColor='rgba(105,225,133,0.3)'" onmouseleave="this.style.borderColor=''">
						<div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style="background: oklch(0.18 0.04 155);">
							<svg width="20" height="20" viewBox="0 0 576 512" fill="#69E185"><path d="M420.55 301.93a24 24 0 1 1 24-24 24 24 0 0 1-24 24zm-265.1 0a24 24 0 1 1 24-24 24 24 0 0 1-24 24zm273.7-144.48l47.94-83a10 10 0 1 0-17.27-10l-48.54 84.07a301.25 301.25 0 0 0-246.56 0L116.18 64.45a10 10 0 1 0-17.27 10l47.94 83C64.53 202.22 8.24 285.55 0 384h576c-8.24-98.45-64.54-181.78-146.85-226.55z"/></svg>
						</div>
						<h3 class="text-base text-white font-medium mb-1">Android</h3>
						<span class="text-xs text-gray-600">Kotlin nativo</span>
					</div>

					<!-- Web — blue -->
					<div class="rounded-2xl border border-white/5 p-6 text-center hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155);" onmouseenter="this.style.borderColor='oklch(0.72 0.14 240 / 0.3)'" onmouseleave="this.style.borderColor=''">
						<div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style="background: oklch(0.18 0.04 240);">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.72 0.14 240)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
						</div>
						<h3 class="text-base text-white font-medium mb-1">Web</h3>
						<span class="text-xs text-gray-600">React + Astro</span>
					</div>

					<!-- Terminal — amber -->
					<div class="rounded-2xl border border-white/5 p-6 text-center hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155);" onmouseenter="this.style.borderColor='oklch(0.78 0.14 75 / 0.3)'" onmouseleave="this.style.borderColor=''">
						<div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style="background: oklch(0.18 0.04 75);">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.78 0.14 75)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01"/><path d="M10 8h.01"/><path d="M14 8h.01"/><line x1="6" y1="12" x2="18" y2="12"/></svg>
						</div>
						<h3 class="text-base text-white font-medium mb-1">Terminal</h3>
						<span class="text-xs text-gray-600">PAX / Nexgo</span>
					</div>

					<!-- Widget — magenta -->
					<div class="rounded-2xl border border-white/5 p-6 text-center hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155);" onmouseenter="this.style.borderColor='oklch(0.72 0.15 340 / 0.3)'" onmouseleave="this.style.borderColor=''">
						<div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style="background: oklch(0.18 0.04 340);">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.72 0.15 340)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h10a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M9 7h6"/><path d="M9 11h6"/><path d="M9 15h4"/></svg>
						</div>
						<h3 class="text-base text-white font-medium mb-1">Widget</h3>
						<span class="text-xs text-gray-600">Embeddable</span>
					</div>

					<!-- Kiosko — indigo -->
					<div class="rounded-2xl border border-white/5 p-6 text-center hover:-translate-y-0.5 transition-all duration-200" style="background: oklch(0.12 0.005 155);" onmouseenter="this.style.borderColor='oklch(0.68 0.15 290 / 0.3)'" onmouseleave="this.style.borderColor=''">
						<div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style="background: oklch(0.18 0.04 290);">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.68 0.15 290)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="16" rx="2"/><path d="M4 18h16"/><path d="M8 22h8"/><line x1="12" y1="18" x2="12" y2="22"/></svg>
						</div>
						<h3 class="text-base text-white font-medium mb-1">Kiosko</h3>
						<span class="text-xs text-gray-600">Self-service</span>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 4. PROCESO — WHITE BG                       -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="max-w-2xl mb-16">
					<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${GREEN};`}>Proceso</span>
					<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
						De la idea a produccion en 48 horas.
					</h2>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
					<!-- Step 01 -->
					<div class="relative">
						<div class="text-6xl font-light mb-4" style={`color: ${GREEN}; opacity: 0.25;`}>01</div>
						<h3 class="text-xl text-black font-medium mb-3">Cuentanos</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Describe lo que necesitas por llamada o mensaje. No necesitas documentos tecnicos — nosotros traducimos tu idea a arquitectura.</p>
					</div>

					<!-- Step 02 -->
					<div class="relative">
						<div class="text-6xl font-light mb-4" style={`color: ${GREEN}; opacity: 0.25;`}>02</div>
						<h3 class="text-xl text-black font-medium mb-3">Disenamos</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Creamos la arquitectura y UX sobre tu infraestructura existente. Sin empezar de cero — aprovechamos lo que ya esta construido.</p>
					</div>

					<!-- Step 03 -->
					<div class="relative">
						<div class="text-6xl font-light mb-4" style={`color: ${GREEN}; opacity: 0.25;`}>03</div>
						<h3 class="text-xl text-black font-medium mb-3">Construimos</h3>
						<p class="text-sm text-gray-600 leading-relaxed">Nuestro equipo construye en todas las plataformas simultaneamente. Backend, frontend, mobile y terminal en paralelo.</p>
					</div>

					<!-- Step 04 -->
					<div class="relative">
						<div class="text-6xl font-light mb-4" style={`color: ${GREEN}; opacity: 0.25;`}>04</div>
						<h3 class="text-xl text-black font-medium mb-3">Entregamos</h3>
						<p class="text-sm text-gray-600 leading-relaxed">QA completo, deploy a produccion y documentacion. Tu funcionalidad en vivo, integrada con todo tu ecosistema.</p>
					</div>
				</div>

				<!-- Speed emphasis -->
				<div class="mt-16 pt-8 border-t border-black/5">
					<div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-8">
						<div class="flex items-center gap-3">
							<span class="relative flex h-3 w-3">
								<span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style={`background: ${GREEN};`}></span>
								<span class="relative inline-flex rounded-full h-3 w-3" style={`background: ${GREEN};`}></span>
							</span>
							<span class="text-base text-black font-medium">Promedio 48 horas.</span>
						</div>
						<span class="text-sm text-gray-500">Proyectos grandes en dias, no meses.</span>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 5. EQUIPO — DARK BG                         -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
					<!-- Left: description -->
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${GREEN};`}>Equipo</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
							Equipo dedicado.<br/>No freelancers.
						</h2>
						<p class="text-gray-400 text-lg leading-relaxed mb-8">
							No subcontratamos ni delegamos a terceros. Cada proyecto es ejecutado por nuestras divisiones internas especializadas, con contexto completo de la plataforma y acceso directo a la base de codigo.
						</p>
						<p class="text-gray-500 text-base leading-relaxed">
							Esto significa velocidad real: el ingeniero que construye tu modulo conoce la arquitectura completa, los modelos de datos y las integraciones existentes. Sin curva de aprendizaje.
						</p>
					</div>

					<!-- Right: team division cards -->
					<div class="space-y-3">
						<!-- Ingenieria -->
						<div class="flex items-start gap-4 p-5 rounded-xl border border-white/5" style="background: oklch(0.12 0.005 155);">
							<div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style={`background: ${GREEN_BG};`}>
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={GREEN} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
							</div>
							<div>
								<h3 class="text-white font-medium mb-1">Ingenieria</h3>
								<p class="text-sm text-gray-500">Frontend, backend, mobile, DevOps, IA</p>
							</div>
						</div>

						<!-- Diseno -->
						<div class="flex items-start gap-4 p-5 rounded-xl border border-white/5" style="background: oklch(0.12 0.005 155);">
							<div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style={`background: ${GREEN_BG};`}>
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={GREEN} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
							</div>
							<div>
								<h3 class="text-white font-medium mb-1">Diseno</h3>
								<p class="text-sm text-gray-500">UI/UX, branding, visual storytelling</p>
							</div>
						</div>

						<!-- Producto -->
						<div class="flex items-start gap-4 p-5 rounded-xl border border-white/5" style="background: oklch(0.12 0.005 155);">
							<div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style={`background: ${GREEN_BG};`}>
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={GREEN} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
							</div>
							<div>
								<h3 class="text-white font-medium mb-1">Producto</h3>
