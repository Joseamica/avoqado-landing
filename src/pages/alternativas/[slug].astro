---
/**
 * /alternativas/[slug] — páginas comparativas honestas contra los competidores
 * que la gente busca en Google Ads (Loyverse, Eleventa, SICAR, Fresha).
 * Destino de los ad groups "Comp - *"; también rankean orgánico.
 *
 * Reglas: CTAs de WhatsApp SIEMPRE via /wa (conversión whatsapp_click);
 * claims del competidor hedged + disclaimer; sin emojis (SVG only).
 */
import '../../styles/global.css';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import SEO from '../../components/layout/SEO.astro';
import { AVOQADO_FEATURES, COMPETITORS } from '../../data/competitors';

export const prerender = true;

export function getStaticPaths() {
  return COMPETITORS.map(c => ({ params: { slug: c.slug }, props: { comp: c } }));
}

const { comp } = Astro.props;

const waText = `Hola, estoy comparando ${comp.name} con Avoqado y quiero saber más.`;
const waHref = `/wa?src=vs_${comp.slug}&text=${encodeURIComponent(waText)}`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<SEO
			title={`Alternativa a ${comp.name} en México — Avoqado`}
			description={`¿Buscas una alternativa a ${comp.name}? Compara honestamente: punto de venta, cobros con terminal, citas, inventario, CFDI e IA — todo en uno, hecho en México.`}
			url={`/alternativas/${comp.slug}`}
		/>
		<link rel="icon" type="image/png" href="/favicon.png?v=3" />
	</head>
	<body class="bg-black m-0 p-0 w-full antialiased overflow-x-hidden">
		<Navbar position="fixed" transparentOnTop={false} />

		<main class="pt-24 md:pt-28">
			<!-- HERO (oscuro) -->
			<section class="px-4 sm:px-6 pb-16 md:pb-20 text-center max-w-3xl mx-auto">
				<p class="text-xs font-bold tracking-wide uppercase" style="color: #98EA5C;">Comparativa honesta</p>
				<h1 class="mt-3 text-3xl md:text-5xl font-medium tracking-tight text-white text-balance">
					La alternativa a {comp.name} {comp.tagline}
				</h1>
				<p class="mt-4 text-base md:text-lg text-gray-400 text-pretty">{comp.intro}</p>
				<div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
					<a
						href={waHref}
						class="inline-flex items-center justify-center gap-2 rounded-full px-7 py-3.5 font-semibold text-black transition-transform hover:-translate-y-0.5"
						style="background: #7ADD2C;"
					>
						Hablar con un humano
					</a>
					<a
						href="/demo"
						class="inline-flex items-center justify-center rounded-full px-7 py-3.5 font-semibold text-white border border-white/20 transition-colors hover:bg-white/5"
					>
						Probar el demo en 60 seg
					</a>
				</div>
			</section>

			<!-- TABLA (clara) -->
			<section class="bg-white px-4 sm:px-6 py-16 md:py-20">
				<div class="max-w-3xl mx-auto">
					<h2 class="text-2xl md:text-3xl font-medium tracking-tight text-black text-center">
						Avoqado vs {comp.name}, sin rodeos
					</h2>
					<div class="mt-8 overflow-x-auto">
						<table class="w-full text-sm border-collapse">
							<thead>
								<tr class="border-b border-black/10">
									<th class="text-left py-3 pr-3 font-semibold text-black/60"></th>
									<th class="py-3 px-3 font-bold text-black">Avoqado</th>
									<th class="py-3 pl-3 font-semibold text-black/60">{comp.name}</th>
								</tr>
							</thead>
							<tbody>
								{AVOQADO_FEATURES.map((feature, i) => {
									const row = comp.rows.find(r => r.feature === feature);
									const them = row?.them ?? false;
									return (
										<tr class="border-b border-black/5 align-top">
											<td class="py-3 pr-3 text-black/80">
												{feature}
												{row?.note && <span class="block text-xs text-black/45 mt-0.5">{comp.name}: {row.note}</span>}
											</td>
											<td class="py-3 px-3 text-center">
												<svg class="inline w-5 h-5" viewBox="0 0 24 24" fill="none" aria-label="Sí">
													<circle cx="12" cy="12" r="10" fill="#7ADD2C" />
													<path d="m7.8 12.4 2.7 2.7 5.7-5.9" stroke="#17300A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
												</svg>
											</td>
											<td class="py-3 pl-3 text-center">
												{them === true ? (
													<svg class="inline w-5 h-5" viewBox="0 0 24 24" fill="none" aria-label="Sí">
														<circle cx="12" cy="12" r="10" fill="#d8dcd6" />
														<path d="m7.8 12.4 2.7 2.7 5.7-5.9" stroke="#3a423a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
													</svg>
												) : them === 'partial' ? (
													<span class="inline-block text-xs font-semibold text-black/50 border border-black/15 rounded-full px-2.5 py-0.5">Parcial</span>
												) : (
													<svg class="inline w-5 h-5 opacity-30" viewBox="0 0 24 24" fill="none" aria-label="No">
														<path d="M6 18L18 6M6 6l12 12" stroke="#1d231c" stroke-width="2.2" stroke-linecap="round" />
													</svg>
												)}
											</td>
										</tr>
									);
								})}
							</tbody>
						</table>
					</div>
					<p class="mt-4 text-xs text-black/40 text-pretty">
						Comparativa con base en información pública de {comp.name} a julio de 2026; sus planes y funciones pueden cambiar — verifica su sitio
						para tu caso. Lo que sí controlamos: todo lo de la columna Avoqado.
					</p>
				</div>
			</section>

			<!-- HONESTIDAD (oscuro) -->
			<section class="px-4 sm:px-6 py-16 md:py-20 border-t border-white/5">
				<div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-10">
					<div>
						<h3 class="text-xl font-medium text-white">Lo que {comp.name} hace bien</h3>
						<ul class="mt-4 space-y-2.5">
							{comp.goodAt.map(item => (
								<li class="flex items-start gap-2.5 text-gray-400 text-sm">
									<span class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style="background: #98EA5C;"></span>
									{item}
								</li>
							))}
						</ul>
						<p class="mt-5 text-sm text-gray-500 text-pretty">{comp.whenThemFits}</p>
					</div>
					<div>
						<h3 class="text-xl font-medium text-white">Cuándo te conviene Avoqado</h3>
						<p class="mt-4 text-sm text-gray-400 text-pretty">{comp.whenUsFits}</p>
						<p class="mt-4 text-sm text-gray-400 text-pretty">
							Además, con el <b class="text-white">Programa Fundador</b> obtienes 50% de descuento de por vida — y puedes empezar gratis, sin
							tarjeta. Nosotros migramos tu catálogo y clientes sin costo.
						</p>
					</div>
				</div>
			</section>

			<!-- FAQ (claro) -->
			<section class="bg-white px-4 sm:px-6 py-16 md:py-20">
				<div class="max-w-3xl mx-auto">
					<h2 class="text-2xl md:text-3xl font-medium tracking-tight text-black text-center">Preguntas frecuentes</h2>
					<div class="mt-8 space-y-6">
						{comp.faq.map(({ q, a }) => (
							<div class="border-b border-black/5 pb-6">
								<h3 class="font-semibold text-black">{q}</h3>
								<p class="mt-2 text-sm text-black/60 text-pretty">{a}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- CTA FINAL (oscuro) -->
			<section class="px-4 sm:px-6 py-20 md:py-24 text-center border-t border-white/5">
				<div class="max-w-2xl mx-auto">
					<h2 class="text-3xl md:text-4xl font-medium tracking-tight text-white text-balance">
						Compara tú mismo — en 60 segundos
					</h2>
					<p class="mt-3 text-gray-400">
						Cobra en una terminal real, recibe una reserva y mira cómo una venta dispara todo tu negocio. Sin registro, sin tarjeta.
					</p>
					<div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
						<a
							href="/demo"
							class="inline-flex items-center justify-center rounded-full px-7 py-3.5 font-semibold text-black transition-transform hover:-translate-y-0.5"
							style="background: #7ADD2C;"
						>
							Probar el demo interactivo
						</a>
						<a
							href={waHref}
							class="inline-flex items-center justify-center rounded-full px-7 py-3.5 font-semibold text-white border border-white/20 transition-colors hover:bg-white/5"
						>
							Escríbenos por WhatsApp
						</a>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
