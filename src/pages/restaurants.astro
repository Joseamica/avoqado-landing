---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingChatbot from '../components/interactive/FloatingChatbot';

const ACCENT = '#69E185';
const AMBER = 'oklch(0.78 0.14 75)';
const BLUE = 'oklch(0.72 0.14 240)';
const RED = 'oklch(0.65 0.20 25)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado para Restaurantes y Bares | Gestion Integral</title>
		<meta name="description" content="Plataforma todo-en-uno para restaurantes, cafes, bares, food trucks, dark kitchens y catering. Mesas, ordenes, menu, pagos QR, delivery y gestion de equipo." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">R</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style={`color: ${ACCENT};`}>Restaurantes y Bares</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Todo lo que tu restaurante necesita.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							De la cocina a la mesa, del menu al cobro. Una sola plataforma para gestionar mesas, ordenes, inventario, pagos y equipo — sin importar si tienes un cafe, un bar, un food truck o una dark kitchen.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://demo.dashboard.avoqado.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200" style={`background: ${ACCENT};`}>
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Hablar con ventas
							</a>
						</div>
					</div>

					<!-- Floor plan mockup -->
					<div class="hidden lg:block">
						<div class="rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
							<!-- Header -->
							<div class="flex items-center justify-between mb-4">
								<div class="flex items-center gap-2">
									<div class="w-6 h-6 rounded-lg flex items-center justify-center" style={`background: oklch(0.18 0.04 155); color: ${ACCENT};`}>
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
									</div>
									<span class="text-[11px] text-white font-medium">Floor Plan — Sala Principal</span>
								</div>
								<div class="flex gap-1.5">
									<span class="text-[8px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.04 155); color: ${ACCENT};`}>14 mesas</span>
									<span class="text-[8px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 75); color: ${AMBER};`}>2 reservadas</span>
								</div>
							</div>
							<!-- Floor plan grid -->
							<div class="grid grid-cols-4 gap-2.5 mb-4">
								<!-- Row 1 -->
								<div class="aspect-square rounded-xl flex flex-col items-center justify-center" style={`background: oklch(0.18 0.04 155); border: 1px solid oklch(0.30 0.08 155);`}>
									<span class="text-[10px] text-white font-medium">M1</span>
									<span class="text-[7px] mt-0.5" style={`color: ${ACCENT};`}>4 pax</span>
									<span class="text-[7px] mt-0.5" style={`color: ${ACCENT};`}>$1,840</span>
								</div>
								<div class="aspect-square rounded-xl flex flex-col items-center justify-center" style={`background: oklch(0.18 0.04 155); border: 1px solid oklch(0.30 0.08 155);`}>
									<span class="text-[10px] text-white font-medium">M2</span>
									<span class="text-[7px] mt-0.5" style={`color: ${ACCENT};`}>2 pax</span>
									<span class="text-[7px] mt-0.5" style={`color: ${ACCENT};`}>$650</span>
								</div>
								<div class="aspect-square rounded-xl flex flex-col items-center justify-center" style="background: oklch(0.16 0.005 155); border: 1px solid oklch(0.22 0.005 155);">
									<span class="text-[10px] text-gray-500 font-medium">M3</span>
									<span class="text-[7px] text-gray-600 mt-0.5">Libre</span>
								</div>
								<div class="aspect-square rounded-full flex flex-col items-center justify-center" style={`background: oklch(0.18 0.02 75); border: 1px solid oklch(0.30 0.04 75);`}>
									<span class="text-[10px] text-white font-medium">M4</span>
									<span class="text-[7px] mt-0.5" style={`color: ${AMBER};`}>20:00</span>
								</div>
								<!-- Row 2 -->
								<div class="aspect-square rounded-xl flex flex-col items-center justify-center" style="background: oklch(0.16 0.005 155); border: 1px solid oklch(0.22 0.005 155);">
									<span class="text-[10px] text-gray-500 font-medium">M5</span>
									<span class="text-[7px] text-gray-600 mt-0.5">Libre</span>
								</div>
								<div class="aspect-square rounded-xl flex flex-col items-center justify-center col-span-2" style={`background: oklch(0.18 0.04 155); border: 1px solid oklch(0.30 0.08 155);`}>
									<span class="text-[10px] text-white font-medium">M6 — VIP</span>
									<span class="text-[7px] mt-0.5" style={`color: ${ACCENT};`}>8 pax</span>
									<span class="text-[7px] mt-0.5" style={`color: ${ACCENT};`}>$4,520</span>
								</div>
								<div class="aspect-square rounded-full flex flex-col items-center justify-center" style={`background: oklch(0.18 0.04 155); border: 1px solid oklch(0.30 0.08 155);`}>
									<span class="text-[10px] text-white font-medium">M7</span>
									<span class="text-[7px] mt-0.5" style={`color: ${ACCENT};`}>2 pax</span>
								</div>
								<!-- Row 3 -->
								<div class="aspect-square rounded-xl flex flex-col items-center justify-center" style={`background: oklch(0.18 0.04 155); border: 1px solid oklch(0.30 0.08 155);`}>
									<span class="text-[10px] text-white font-medium">M8</span>
									<span class="text-[7px] mt-0.5" style={`color: ${ACCENT};`}>3 pax</span>
									<span class="text-[7px] mt-0.5" style={`color: ${ACCENT};`}>$980</span>
								</div>
								<div class="aspect-square rounded-xl flex flex-col items-center justify-center" style="background: oklch(0.16 0.005 155); border: 1px solid oklch(0.22 0.005 155);">
									<span class="text-[10px] text-gray-500 font-medium">M9</span>
									<span class="text-[7px] text-gray-600 mt-0.5">Libre</span>
								</div>
								<div class="aspect-square rounded-xl flex flex-col items-center justify-center" style="background: oklch(0.16 0.005 155); border: 1px solid oklch(0.22 0.005 155);">
									<span class="text-[10px] text-gray-500 font-medium">M10</span>
									<span class="text-[7px] text-gray-600 mt-0.5">Libre</span>
								</div>
								<div class="aspect-square rounded-full flex flex-col items-center justify-center" style={`background: oklch(0.18 0.02 75); border: 1px solid oklch(0.30 0.04 75);`}>
									<span class="text-[10px] text-white font-medium">M11</span>
									<span class="text-[7px] mt-0.5" style={`color: ${AMBER};`}>21:00</span>
								</div>
							</div>
							<!-- Legend -->
							<div class="flex items-center gap-4 pt-3 border-t border-white/5">
								<div class="flex items-center gap-1.5">
									<div class="w-2 h-2 rounded-sm" style={`background: ${ACCENT};`}></div>
									<span class="text-[8px] text-gray-500">Ocupada</span>
								</div>
								<div class="flex items-center gap-1.5">
									<div class="w-2 h-2 rounded-sm" style="background: oklch(0.25 0.005 155);"></div>
									<span class="text-[8px] text-gray-500">Libre</span>
								</div>
								<div class="flex items-center gap-1.5">
									<div class="w-2 h-2 rounded-sm" style={`background: ${AMBER};`}></div>
									<span class="text-[8px] text-gray-500">Reservada</span>
								</div>
								<div class="flex items-center gap-1.5">
									<div class="w-2 h-2 rounded-full" style="background: oklch(0.25 0.005 155);"></div>
									<span class="text-[8px] text-gray-500">Redonda</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. MESAS Y ORDENES                          -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${ACCENT};`}>Mesas y Ordenes</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							De la mesa a la cocina al instante.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Floor plan visual con estado de cada mesa en tiempo real. Crea ordenes de cualquier tipo — dine-in, takeout o delivery — y envialas a cocina con un tap. El KDS muestra todo al instante con timer de preparacion.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${ACCENT};`}></div>
								<span class="text-sm text-gray-600"><span class="text-black font-medium">Dine-in:</span> Orden vinculada a mesa con cuenta abierta, split y propina</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${BLUE};`}></div>
								<span class="text-sm text-gray-600"><span class="text-black font-medium">Takeout:</span> Para llevar con tiempo estimado y notificacion al cliente</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${AMBER};`}></div>
								<span class="text-sm text-gray-600"><span class="text-black font-medium">Delivery:</span> Direccion, zona de cobertura y asignacion de repartidor</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${RED};`}></div>
								<span class="text-sm text-gray-600"><span class="text-black font-medium">KDS integrado:</span> Timer por orden, estado por platillo, notas y modificadores visibles</span>
							</div>
						</div>
					</div>

					<!-- Order flow mockup -->
					<div class="rounded-2xl overflow-hidden border border-black/5 p-5" style="background: #0A0A0A;">
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-gray-500">Orden activa — Mesa 6</span>
							<div class="flex gap-1.5">
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.04 155); color: ${ACCENT};`}>Dine-in</span>
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 75); color: ${AMBER};`}>8 pax</span>
							</div>
						</div>
						<!-- Order items -->
						<div class="space-y-1.5 mb-4">
							<div class="flex items-center justify-between p-2.5 rounded-lg" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${ACCENT};`}>
								<div class="flex items-center gap-3">
									<span class="text-[10px] font-bold w-5 text-center" style={`color: ${ACCENT};`}>3x</span>
									<div>
										<span class="text-[11px] text-white">Tacos al Pastor</span>
										<span class="text-[8px] text-gray-600 block">Sin cebolla, extra salsa</span>
									</div>
								</div>
								<div class="text-right">
									<span class="text-[10px] text-white">$285</span>
									<span class="text-[8px] block" style={`color: ${ACCENT};`}>En cocina</span>
								</div>
							</div>
							<div class="flex items-center justify-between p-2.5 rounded-lg" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${ACCENT};`}>
								<div class="flex items-center gap-3">
									<span class="text-[10px] font-bold w-5 text-center" style={`color: ${ACCENT};`}>1x</span>
									<div>
										<span class="text-[11px] text-white">Arrachera 300g</span>
										<span class="text-[8px] text-gray-600 block">Termino medio</span>
									</div>
								</div>
								<div class="text-right">
									<span class="text-[10px] text-white">$320</span>
									<span class="text-[8px] block" style={`color: ${AMBER};`}>Preparando</span>
								</div>
							</div>
							<div class="flex items-center justify-between p-2.5 rounded-lg" style="background: oklch(0.16 0.005 155); border-left: 3px solid oklch(0.40 0.005 155);">
								<div class="flex items-center gap-3">
									<span class="text-[10px] font-bold w-5 text-center text-gray-500">2x</span>
									<span class="text-[11px] text-white">Michelada Clasica</span>
								</div>
								<div class="text-right">
									<span class="text-[10px] text-white">$190</span>
									<span class="text-[8px] text-gray-600 block">Barra</span>
								</div>
							</div>
							<div class="flex items-center justify-between p-2.5 rounded-lg" style="background: oklch(0.16 0.005 155); border-left: 3px solid oklch(0.40 0.005 155);">
								<div class="flex items-center gap-3">
									<span class="text-[10px] font-bold w-5 text-center text-gray-500">1x</span>
									<span class="text-[11px] text-white">Guacamole</span>
								</div>
								<div class="text-right">
									<span class="text-[10px] text-white">$120</span>
									<span class="text-[8px] text-avoqado-green block">Servido</span>
								</div>
							</div>
						</div>
						<!-- KDS mini preview -->
						<div class="rounded-lg p-3 mb-3" style="background: oklch(0.14 0.005 155); border: 1px solid oklch(0.22 0.005 155);">
							<div class="flex items-center justify-between mb-2">
								<span class="text-[10px] text-gray-400">Kitchen Display</span>
								<span class="text-[8px]" style={`color: ${AMBER};`}>2 preparando</span>
							</div>
							<div class="grid grid-cols-3 gap-1.5">
								<div class="rounded p-1.5 text-center" style={`background: oklch(0.16 0.005 155); border-top: 2px solid ${AMBER};`}>
									<span class="text-[8px] text-white block">M6</span>
									<span class="text-[7px]" style={`color: ${AMBER};`}>4:12</span>
								</div>
								<div class="rounded p-1.5 text-center" style={`background: oklch(0.16 0.005 155); border-top: 2px solid ${ACCENT};`}>
									<span class="text-[8px] text-white block">M2</span>
									<span class="text-[7px]" style={`color: ${ACCENT};`}>Lista</span>
								</div>
								<div class="rounded p-1.5 text-center" style="background: oklch(0.16 0.005 155); border-top: 2px solid oklch(0.40 0.005 155);">
									<span class="text-[8px] text-white block">#47</span>
									<span class="text-[7px] text-gray-600">Takeout</span>
								</div>
							</div>
						</div>
						<!-- Total -->
						<div class="flex items-center justify-between p-3 rounded-xl" style={`background: oklch(0.18 0.04 155);`}>
							<div>
								<span class="text-[11px] text-white font-semibold">7 items</span>
								<span class="text-[9px] text-gray-500 ml-2">Mesero: Carlos R.</span>
							</div>
							<span class="text-sm font-semibold" style={`color: ${ACCENT};`}>$4,520</span>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. MENU E INVENTARIO                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Menu editor mockup -->
					<div class="order-2 lg:order-1 rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-gray-500">MenuMaker — 48 productos</span>
							<div class="flex gap-1.5">
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.04 155); color: ${ACCENT};`}>Publicado</span>
							</div>
						</div>
						<!-- Categories -->
						<div class="flex gap-1.5 mb-4 overflow-hidden">
							<div class="px-3 py-1.5 rounded-full text-[9px] text-black shrink-0" style={`background: ${ACCENT};`}>Todo</div>
							<div class="px-3 py-1.5 rounded-full text-[9px] text-gray-500 shrink-0" style="background: oklch(0.16 0.005 155);">Entradas</div>
							<div class="px-3 py-1.5 rounded-full text-[9px] text-gray-500 shrink-0" style="background: oklch(0.16 0.005 155);">Platos fuertes</div>
							<div class="px-3 py-1.5 rounded-full text-[9px] text-gray-500 shrink-0" style="background: oklch(0.16 0.005 155);">Bebidas</div>
							<div class="px-3 py-1.5 rounded-full text-[9px] text-gray-500 shrink-0" style="background: oklch(0.16 0.005 155);">Postres</div>
						</div>
						<!-- Product grid -->
						<div class="grid grid-cols-2 gap-2 mb-4">
							<div class="rounded-xl p-3" style={`background: oklch(0.16 0.005 155); border: 1px solid oklch(0.30 0.08 155);`}>
								<div class="w-full aspect-[4/3] rounded-lg mb-2 flex items-center justify-center" style="background: oklch(0.20 0.005 155);">
									<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="oklch(0.35 0.005 155)" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
								</div>
								<span class="text-[11px] text-white">Tacos al Pastor</span>
								<div class="flex items-center justify-between mt-1">
									<span class="text-[10px]" style={`color: ${ACCENT};`}>$95</span>
									<span class="text-[8px] text-gray-600">6 modif.</span>
								</div>
							</div>
							<div class="rounded-xl p-3" style="background: oklch(0.16 0.005 155);">
								<div class="w-full aspect-[4/3] rounded-lg mb-2 flex items-center justify-center" style="background: oklch(0.20 0.005 155);">
									<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="oklch(0.35 0.005 155)" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
								</div>
								<span class="text-[11px] text-white">Arrachera 300g</span>
								<div class="flex items-center justify-between mt-1">
									<span class="text-[10px] text-gray-500">$320</span>
									<span class="text-[8px] text-gray-600">3 modif.</span>
								</div>
							</div>
							<div class="rounded-xl p-3" style="background: oklch(0.16 0.005 155);">
								<div class="w-full aspect-[4/3] rounded-lg mb-2 flex items-center justify-center" style="background: oklch(0.20 0.005 155);">
									<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="oklch(0.35 0.005 155)" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
								</div>
								<span class="text-[11px] text-white">Michelada</span>
								<div class="flex items-center justify-between mt-1">
									<span class="text-[10px] text-gray-500">$95</span>
									<span class="text-[8px] text-gray-600">2 modif.</span>
								</div>
							</div>
							<div class="rounded-xl p-3" style="background: oklch(0.16 0.005 155);">
								<div class="w-full aspect-[4/3] rounded-lg mb-2 flex items-center justify-center" style="background: oklch(0.20 0.005 155);">
