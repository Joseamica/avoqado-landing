---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import HelpSearch from '../../components/help/HelpSearch';
import { DASHBOARD_HELP_CATEGORIES, getArticleUrl, sortHelpArticles, toSearchItem } from '../../lib/help';

export const prerender = true;

const articles = sortHelpArticles(await getCollection('help', (article) => article.data.product === 'dashboard'));
const popularArticles = articles.filter((article) => article.data.popular).slice(0, 6);
const searchItems = articles.map(toSearchItem);
const articleCountByCategory = new Map<string, number>();

for (const article of articles) {
	articleCountByCategory.set(article.data.category, (articleCountByCategory.get(article.data.category) ?? 0) + 1);
}
---

<Layout title="Ayuda Dashboard | Avoqado" description="Guias de soporte para el Dashboard de Avoqado.">
	<Navbar position="fixed" />
	<main class="min-h-screen bg-[#f7f8f4] pt-32 text-black">
		<section class="border-b border-black/10 bg-[#f7f8f4]">
			<div class="mx-auto max-w-6xl px-6 py-14">
				<nav aria-label="Breadcrumb" class="text-sm text-gray-600">
					<ol class="flex flex-wrap items-center gap-2">
						<li><a href="/help" class="hover:text-black">Centro de ayuda</a></li>
						<li aria-hidden="true" class="text-gray-400">/</li>
						<li class="text-black" aria-current="page">Dashboard</li>
					</ol>
				</nav>

				<div class="mt-8 grid gap-10 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-end">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.18em] text-green-800">Dashboard Web</p>
						<h1 class="mt-4 max-w-3xl text-5xl font-light tracking-tight md:text-6xl">¿Que necesitas hacer?</h1>
						<p class="mt-5 max-w-2xl text-lg leading-relaxed text-gray-700">
							Encuentra pasos, rutas y recomendaciones para resolver tareas del Dashboard sin depender del slug del local.
						</p>
						<div class="mt-8 max-w-3xl">
							<HelpSearch items={searchItems} client:load />
						</div>
					</div>

					<aside class="rounded-[1.5rem] border border-black/10 bg-white p-6 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
						<p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500">Acceso directo</p>
						<h2 class="mt-3 text-2xl font-medium">Abre Dashboard desde una guia</h2>
						<p class="mt-3 text-sm leading-6 text-gray-600">
							Cada articulo incluye botones que detectan tu sesion y te llevan al local correcto.
						</p>
						<a href="https://dashboard.avoqado.io/login" class="mt-5 inline-flex w-full justify-center rounded-full bg-black px-4 py-3 text-sm font-semibold text-white transition hover:bg-gray-800">
							Iniciar sesion
						</a>
					</aside>
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-6xl px-6 py-12">
			<div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Temas</p>
					<h2 class="mt-2 text-3xl font-medium tracking-tight">Explora por area del Dashboard</h2>
				</div>
				<p class="text-sm text-gray-500">{articles.length} articulos publicados</p>
			</div>
			<div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
				{DASHBOARD_HELP_CATEGORIES.map((category) => (
					<a href={`/help/dashboard/${category.slug}`} class="group rounded-[1.25rem] border border-black/10 bg-white p-5 transition hover:-translate-y-0.5 hover:border-black/25 hover:shadow-[0_18px_50px_rgba(15,23,42,0.07)]">
						<div class="flex items-start justify-between gap-4">
							<h3 class="text-xl font-semibold">{category.title}</h3>
							<span class="rounded-full bg-[#eef7e9] px-3 py-1 text-xs font-semibold text-green-800">
								{articleCountByCategory.get(category.slug) ?? 0}
							</span>
						</div>
						<p class="mt-3 text-sm leading-6 text-gray-600">{category.description}</p>
						<span class="mt-5 inline-flex text-sm font-semibold text-gray-900 group-hover:text-green-800">Ver articulos -></span>
					</a>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-6xl px-6 pb-20">
			<div class="grid gap-8 border-t border-black/10 pt-10 lg:grid-cols-[minmax(0,1fr)_340px]">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Populares</p>
					<h2 class="mt-2 text-3xl font-medium tracking-tight">Articulos que resuelven rapido</h2>
					<div class="mt-6 divide-y divide-black/10 rounded-[1.25rem] border border-black/10 bg-white">
						{popularArticles.map((article) => (
							<a href={getArticleUrl(article)} class="group block p-5 transition hover:bg-[#f7fbf5]">
								<span class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">{article.data.category}</span>
								<h3 class="mt-2 font-semibold group-hover:text-green-800">{article.data.title}</h3>
								<p class="mt-1 text-sm leading-6 text-gray-600">{article.data.description}</p>
							</a>
						))}
					</div>
				</div>
				<aside class="rounded-[1.25rem] border border-black/10 bg-black p-6 text-white">
					<p class="text-xs font-semibold uppercase tracking-[0.16em] text-white/50">No encontraste algo</p>
					<h2 class="mt-3 text-2xl font-medium">Dinos que falta documentar</h2>
					<p class="mt-3 text-sm leading-6 text-white/70">
						El help debe seguir al producto. Si un flujo cambia o falta una guia, soporte puede priorizarlo.
					</p>
					<a href="/contact" class="mt-5 inline-flex rounded-full bg-white px-4 py-3 text-sm font-semibold text-black transition hover:bg-gray-100">
						Contactar soporte
					</a>
				</aside>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
