---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/layout/Navbar.astro'
import Footer from '../components/layout/Footer.astro'

const WINDOWS_INSTALLER_URL = '/descargar/windows'
const WINDOWS_PORTABLE_URL = '/descargar/windows-portable'
const MAC_INSTALLER_URL = '/descargar/mac'
const WHATSAPP_HELP_URL = '/wa?src=descargar_ayuda&text=Hola%2C%20necesito%20ayuda%20para%20instalar%20Avoqado%20POS.'
const GREEN = '#7ADD2C'
---

<Layout
  title="Descargar Avoqado POS para Windows y Mac | Avoqado"
  description="Descarga Avoqado POS para Windows o Mac. Instálalo con doble clic — sin permisos de administrador, firmado y notarizado en Mac."
>
  <Navbar />

  <main class="bg-white min-h-screen">
    <!-- Hero -->
    <section class="bg-black text-white pt-32 pb-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm uppercase tracking-widest text-gray-400 mb-4">Avoqado POS · Windows y Mac</p>
        <h1 class="font-light tracking-tight text-4xl md:text-5xl lg:text-6xl mb-6">
          Tu punto de venta,<br class="hidden md:block" /> listo en un minuto
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-10">
          Descarga el instalador, haz doble clic y empieza a cobrar. Sin permisos de
          administrador y siempre con la última versión.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href={WINDOWS_INSTALLER_URL}
            class="inline-block px-10 py-4 rounded-full font-medium text-black text-lg transition-transform hover:scale-105 w-full sm:w-auto"
            style={`background-color: ${GREEN}`}
          >
            Descargar para Windows
          </a>
          <a
            href={MAC_INSTALLER_URL}
            class="inline-block px-10 py-4 rounded-full font-medium text-white text-lg border border-white/30 transition-transform hover:scale-105 hover:bg-white/10 w-full sm:w-auto"
          >
            Descargar para Mac
          </a>
        </div>
        <p class="text-gray-500 text-sm mt-4">
          Windows 10/11 · 64 bits &nbsp;·&nbsp; macOS 12+ (Apple Silicon) — siempre la última versión
        </p>
      </div>
    </section>

    <!-- Windows -->
    <section class="py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-light tracking-tight text-3xl md:text-4xl mb-10 text-center">
          En Windows: tres pasos y estás cobrando
        </h2>
        <ol class="grid md:grid-cols-3 gap-8">
          <li class="border border-gray-200 rounded-2xl p-6">
            <span class="text-gray-400 text-sm">Paso 1</span>
            <h3 class="text-xl font-medium mt-1 mb-2">Descarga el instalador</h3>
            <p class="text-gray-600">
              Haz clic en «Descargar para Windows». Obtienes <code>AvoqadoPOS-Setup.exe</code>.
            </p>
          </li>
          <li class="border border-gray-200 rounded-2xl p-6">
            <span class="text-gray-400 text-sm">Paso 2</span>
            <h3 class="text-xl font-medium mt-1 mb-2">Doble clic e instala</h3>
            <p class="text-gray-600">
              Sigue el asistente. No pide permisos de administrador y crea un acceso
              directo en tu escritorio y menú de inicio.
            </p>
          </li>
          <li class="border border-gray-200 rounded-2xl p-6">
            <span class="text-gray-400 text-sm">Paso 3</span>
            <h3 class="text-xl font-medium mt-1 mb-2">Abre Avoqado POS</h3>
            <p class="text-gray-600">
              Ábrelo desde el acceso directo, inicia sesión con tu cuenta de Avoqado y listo.
            </p>
          </li>
        </ol>

        <!-- Aviso SmartScreen -->
        <div class="mt-10 bg-gray-50 border border-gray-200 rounded-2xl p-6">
          <h3 class="text-lg font-medium mb-2">¿Windows te muestra «Windows protegió tu PC»?</h3>
          <p class="text-gray-600">
            Es el aviso estándar de SmartScreen para aplicaciones nuevas. Haz clic en
            <strong>Más información</strong> y luego en <strong>Ejecutar de todas formas</strong>.
          </p>
        </div>

        <!-- Versión portable -->
        <div class="mt-6 border border-gray-200 rounded-2xl p-6">
          <h3 class="text-lg font-medium mb-2">¿Prefieres la versión portable?</h3>
          <p class="text-gray-600">
            Sin instalación: <a href={WINDOWS_PORTABLE_URL} class="underline font-medium">descarga el ZIP</a>,
            descomprímelo (incluso en una USB) y ejecuta <code>AvoqadoPOS\AvoqadoPOS.exe</code>.
          </p>
        </div>
      </div>
    </section>

    <!-- Mac -->
    <section class="py-16 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-light tracking-tight text-3xl md:text-4xl mb-10 text-center">
          En Mac: tres pasos y estás cobrando
        </h2>
        <ol class="grid md:grid-cols-3 gap-8">
          <li class="bg-white border border-gray-200 rounded-2xl p-6">
            <span class="text-gray-400 text-sm">Paso 1</span>
            <h3 class="text-xl font-medium mt-1 mb-2">Descarga el instalador</h3>
            <p class="text-gray-600">
              Haz clic en «Descargar para Mac». Obtienes <code>AvoqadoPOS.dmg</code>.
            </p>
          </li>
          <li class="bg-white border border-gray-200 rounded-2xl p-6">
            <span class="text-gray-400 text-sm">Paso 2</span>
            <h3 class="text-xl font-medium mt-1 mb-2">Arrastra a Aplicaciones</h3>
            <p class="text-gray-600">
              Abre el <code>.dmg</code> y arrastra <strong>AvoqadoPOS</strong> a la carpeta
              Aplicaciones.
            </p>
          </li>
          <li class="bg-white border border-gray-200 rounded-2xl p-6">
            <span class="text-gray-400 text-sm">Paso 3</span>
            <h3 class="text-xl font-medium mt-1 mb-2">Abre Avoqado POS</h3>
            <p class="text-gray-600">
              Ábrelo desde Launchpad, inicia sesión con tu cuenta de Avoqado y listo.
            </p>
          </li>
        </ol>

        <!-- Firmado y notarizado: sin avisos de Gatekeeper -->
        <div class="mt-10 bg-white border border-gray-200 rounded-2xl p-6">
          <h3 class="text-lg font-medium mb-2">✓ Firmado y notarizado por Apple</h3>
          <p class="text-gray-600">
            A diferencia de otras apps nuevas, no verás ningún aviso de seguridad al abrirlo —
            Apple ya verificó que el instalador es de Avoqado.
          </p>
        </div>
      </div>
    </section>

    <!-- Ayuda -->
    <section class="py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-light tracking-tight text-3xl mb-4">¿Necesitas ayuda?</h2>
        <p class="text-gray-600 mb-8">
          Te acompañamos en la instalación y la puesta en marcha de tu punto de venta.
        </p>
        <a
          href={WHATSAPP_HELP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 rounded-full font-medium bg-black text-white transition-transform hover:scale-105"
        >
          Hablar con nosotros
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
