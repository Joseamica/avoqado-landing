---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingChatbot from '../components/interactive/FloatingChatbot';

const ACCENT = 'oklch(0.75 0.14 195)'; // teal for services
const GREEN = '#69E185';
const AMBER = 'oklch(0.78 0.14 75)';
const BLUE = 'oklch(0.72 0.14 240)';
const RED = 'oklch(0.65 0.20 25)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado para Servicios | Clinicas, Gimnasios, Veterinarias y mas</title>
		<meta name="description" content="Gestiona citas, clases grupales, membresias, turnos de personal y pagos recurrentes. Para clinicas, gimnasios, veterinarias, talleres, autolavados y lavanderias." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">S</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style={`color: ${ACCENT};`}>Avoqado Servicios</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Gestiona tu negocio<br/>de servicios.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							Agenda citas, programa clases grupales, administra membresias y controla a tu equipo desde una sola plataforma. Para clinicas, gimnasios, veterinarias, talleres, autolavados y lavanderias.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://demo.dashboard.avoqado.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-white font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200" style={`background: ${ACCENT};`}>
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Hablar con ventas
							</a>
						</div>
					</div>

					<!-- Schedule grid mockup — iPad frame -->
					<div class="hidden lg:block">
						<div class="rounded-[1.2rem] p-[5px]" style="background: linear-gradient(145deg, oklch(0.84 0.005 155), oklch(0.70 0.005 155)); box-shadow: 0 15px 40px rgba(0,0,0,0.12);">
							<div class="rounded-[0.9rem] p-[3px] relative" style="background: oklch(0.12 0.005 155);">
								<div class="absolute top-[5px] left-1/2 -translate-x-1/2 w-[4px] h-[4px] rounded-full" style="background: oklch(0.22 0.005 155);"></div>
								<div class="rounded-[0.6rem] overflow-hidden p-5" style="background: oklch(0.12 0.005 155);">
							<!-- Header -->
							<div class="flex items-center justify-between mb-4">
								<div class="flex items-center gap-2">
									<div class="w-6 h-6 rounded-lg flex items-center justify-center" style={`background: oklch(0.18 0.02 195); color: ${ACCENT};`}>
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>
									</div>
									<span class="text-[11px] text-white font-medium">Agenda — Hoy, 19 mar</span>
								</div>
								<div class="flex gap-1.5">
									<span class="text-[8px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 195); color: ${ACCENT};`}>8 citas</span>
									<span class="text-[8px] px-2 py-0.5 rounded-full bg-avoqado-green text-black">2 clases</span>
								</div>
							</div>
							<!-- Time grid -->
							<div class="space-y-1.5 mb-4">
								<!-- 9:00 -->
								<div class="flex gap-2">
									<span class="text-[8px] text-gray-600 w-8 pt-1 shrink-0">09:00</span>
									<div class="flex-1 rounded-lg p-2" style={`background: oklch(0.18 0.02 195); border-left: 3px solid ${ACCENT};`}>
										<div class="flex items-center justify-between">
											<div>
												<span class="text-[10px] text-white">Maria Lopez — Consulta dental</span>
												<span class="text-[8px] text-gray-500 block">Dr. Ramirez — 45 min</span>
											</div>
											<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.22 0.03 195); color: ${ACCENT};`}>Confirmada</span>
										</div>
									</div>
								</div>
								<!-- 10:00 -->
								<div class="flex gap-2">
									<span class="text-[8px] text-gray-600 w-8 pt-1 shrink-0">10:00</span>
									<div class="flex-1 rounded-lg p-2" style="background: oklch(0.14 0.02 155); border-left: 3px solid #69E185;">
										<div class="flex items-center justify-between">
											<div>
												<span class="text-[10px] text-white">Yoga Principiantes</span>
												<span class="text-[8px] text-gray-500 block">Sala 2 — 12/15 inscritos</span>
											</div>
											<span class="text-[8px] px-1.5 py-0.5 rounded bg-avoqado-green text-black">Clase</span>
										</div>
									</div>
								</div>
								<!-- 10:45 -->
								<div class="flex gap-2">
									<span class="text-[8px] text-gray-600 w-8 pt-1 shrink-0">10:45</span>
									<div class="flex-1 rounded-lg p-2" style={`background: oklch(0.18 0.02 195); border-left: 3px solid ${ACCENT};`}>
										<div class="flex items-center justify-between">
											<div>
												<span class="text-[10px] text-white">Carlos Mendez — Limpieza dental</span>
												<span class="text-[8px] text-gray-500 block">Dra. Soto — 30 min</span>
											</div>
											<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.18 0.02 75); color: ${AMBER};`}>Pendiente</span>
										</div>
									</div>
								</div>
								<!-- 11:30 -->
								<div class="flex gap-2">
									<span class="text-[8px] text-gray-600 w-8 pt-1 shrink-0">11:30</span>
									<div class="flex-1 rounded-lg p-2" style={`background: oklch(0.18 0.02 195); border-left: 3px solid ${ACCENT};`}>
										<div class="flex items-center justify-between">
											<div>
												<span class="text-[10px] text-white">Ana Torres — Revision general</span>
												<span class="text-[8px] text-gray-500 block">Dr. Ramirez — 60 min</span>
											</div>
											<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.22 0.03 195); color: ${ACCENT};`}>Confirmada</span>
										</div>
									</div>
								</div>
								<!-- 12:30 -->
								<div class="flex gap-2">
									<span class="text-[8px] text-gray-600 w-8 pt-1 shrink-0">12:30</span>
									<div class="flex-1 rounded-lg p-2" style="background: oklch(0.14 0.02 155); border-left: 3px solid #69E185;">
										<div class="flex items-center justify-between">
											<div>
												<span class="text-[10px] text-white">CrossFit Intermedio</span>
												<span class="text-[8px] text-gray-500 block">Box 1 — 18/20 inscritos</span>
											</div>
											<span class="text-[8px] px-1.5 py-0.5 rounded bg-avoqado-green text-black">Clase</span>
										</div>
									</div>
								</div>
							</div>
							<!-- Summary -->
							<div class="grid grid-cols-3 gap-2">
								<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
									<div class="text-sm font-light text-white">8</div>
									<div class="text-[8px] text-gray-600">Citas hoy</div>
								</div>
								<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
									<div class="text-sm font-light text-white">2</div>
									<div class="text-[8px] text-gray-600">Clases</div>
								</div>
								<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
									<div class="text-sm font-light" style={`color: ${ACCENT};`}>3</div>
									<div class="text-[8px] text-gray-600">Disponibles</div>
								</div>
							</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. CITAS Y CLASES                           -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${ACCENT};`}>Citas y Clases</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Agenda citas y clases grupales.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Citas individuales con duracion configurable y clases grupales con capacidad maxima. Tus clientes reservan desde una pagina publica — sin llamadas, sin WhatsApp, sin confusiones.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${ACCENT};`}></div>
								<span class="text-sm text-gray-600"><span class="text-black font-medium">Citas individuales:</span> Duracion, profesional asignado, sala o consultorio, recordatorio automatico</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-600"><span class="text-black font-medium">Clases grupales:</span> Capacidad maxima, lista de espera, repeticion semanal, instructor asignado</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${AMBER};`}></div>
								<span class="text-sm text-gray-600"><span class="text-black font-medium">Booking publico:</span> Pagina con tu marca donde el cliente escoge servicio, horario y paga</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${BLUE};`}></div>
								<span class="text-sm text-gray-600"><span class="text-black font-medium">Recordatorios:</span> WhatsApp, SMS o email 24h antes. Reduce no-shows hasta 60%</span>
							</div>
						</div>
					</div>

					<!-- Class schedule mockup — Browser frame -->
					<div class="rounded-2xl overflow-hidden" style="border: 1px solid oklch(0.22 0.005 155); box-shadow: 0 20px 60px rgba(0,0,0,0.15);">
						<!-- Browser chrome -->
						<div class="flex items-center gap-2 px-4 py-2.5" style="background: oklch(0.14 0.005 155); border-bottom: 1px solid oklch(0.20 0.005 155);">
							<div class="flex gap-1.5">
								<div class="w-2.5 h-2.5 rounded-full" style="background: oklch(0.40 0.15 25);"></div>
								<div class="w-2.5 h-2.5 rounded-full" style="background: oklch(0.60 0.15 85);"></div>
								<div class="w-2.5 h-2.5 rounded-full" style="background: oklch(0.55 0.15 145);"></div>
							</div>
							<div class="flex-1 mx-4 px-3 py-1 rounded-lg text-[10px] flex items-center gap-2" style="background: oklch(0.10 0.005 155); color: oklch(0.50 0.005 155);">
								<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
								dashboard.avoqado.io/clases
							</div>
						</div>
						<!-- Page content -->
						<div class="p-5" style="background: #0A0A0A;">
							<div class="flex items-center justify-between mb-4">
								<span class="text-[11px] text-gray-500">Clases esta semana — 14 programadas</span>
								<div class="flex gap-1.5">
									<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 195); color: ${ACCENT};`}>Lun-Vie</span>
									<span class="text-[9px] px-2 py-0.5 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">Sabado</span>
								</div>
							</div>
							<div class="space-y-2 mb-4">
								<!-- Class 1 -->
								<div class="flex items-center justify-between p-3 rounded-lg" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${ACCENT};`}>
									<div class="flex items-center gap-3">
										<div class="w-10 h-10 rounded-lg flex flex-col items-center justify-center" style={`background: oklch(0.18 0.02 195); color: ${ACCENT};`}>
											<span class="text-[8px] font-bold leading-none">LUN</span>
											<span class="text-[10px] font-light leading-none mt-0.5">07:00</span>
										</div>
										<div>
											<span class="text-xs text-white">Spinning Intenso</span>
											<span class="text-[9px] text-gray-600 block">Coach Daniel — Sala Cardio — 45 min</span>
										</div>
									</div>
									<div class="text-right">
										<span class="text-xs text-white">18/20</span>
										<span class="text-[8px] block" style={`color: ${ACCENT};`}>2 lugares</span>
									</div>
								</div>
								<!-- Class 2 -->
								<div class="flex items-center justify-between p-3 rounded-lg" style="background: oklch(0.16 0.005 155); border-left: 3px solid #69E185;">
									<div class="flex items-center gap-3">
										<div class="w-10 h-10 rounded-lg flex flex-col items-center justify-center" style="background: oklch(0.14 0.02 155); color: #69E185;">
											<span class="text-[8px] font-bold leading-none">LUN</span>
											<span class="text-[10px] font-light leading-none mt-0.5">10:00</span>
										</div>
										<div>
											<span class="text-xs text-white">Yoga Principiantes</span>
											<span class="text-[9px] text-gray-600 block">Laura M. — Sala Zen — 60 min</span>
										</div>
									</div>
									<div class="text-right">
										<span class="text-xs text-white">12/15</span>
										<span class="text-[8px] text-avoqado-green block">3 lugares</span>
									</div>
								</div>
								<!-- Class 3 -->
								<div class="flex items-center justify-between p-3 rounded-lg" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${AMBER};`}>
									<div class="flex items-center gap-3">
										<div class="w-10 h-10 rounded-lg flex flex-col items-center justify-center" style={`background: oklch(0.18 0.02 75); color: ${AMBER};`}>
											<span class="text-[8px] font-bold leading-none">MAR</span>
											<span class="text-[10px] font-light leading-none mt-0.5">18:00</span>
										</div>
										<div>
											<span class="text-xs text-white">CrossFit Intermedio</span>
											<span class="text-[9px] text-gray-600 block">Coach Alex — Box 1 — 50 min</span>
										</div>
									</div>
									<div class="text-right">
										<span class="text-xs" style={`color: ${AMBER};`}>20/20</span>
										<span class="text-[8px] text-gray-600 block">Lista de espera: 3</span>
									</div>
								</div>
								<!-- Class 4 -->
								<div class="flex items-center justify-between p-3 rounded-lg" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${ACCENT};`}>
									<div class="flex items-center gap-3">
										<div class="w-10 h-10 rounded-lg flex flex-col items-center justify-center" style={`background: oklch(0.18 0.02 195); color: ${ACCENT};`}>
											<span class="text-[8px] font-bold leading-none">MIE</span>
											<span class="text-[10px] font-light leading-none mt-0.5">09:00</span>
										</div>
										<div>
											<span class="text-xs text-white">Pilates Reformer</span>
											<span class="text-[9px] text-gray-600 block">Fernanda R. — Studio A — 55 min</span>
										</div>
									</div>
									<div class="text-right">
										<span class="text-xs text-white">6/8</span>
										<span class="text-[8px] block" style={`color: ${ACCENT};`}>2 lugares</span>
									</div>
								</div>
							</div>
							<!-- Booking link -->
							<div class="rounded-lg p-3 flex items-center justify-between" style="background: oklch(0.14 0.02 155); border: 1px solid oklch(0.25 0.03 155);">
								<div>
									<span class="text-[10px] text-white">Pagina de reservas publica</span>
									<span class="text-[9px] text-avoqado-green block">book.avoqado.io/tu-negocio</span>
								</div>
								<span class="text-[9px] px-2 py-0.5 rounded bg-avoqado-green text-black font-medium">Compartir</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. MEMBRESIAS                               -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Membership mockup — Browser frame -->
					<div class="order-2 lg:order-1 rounded-2xl overflow-hidden" style="border: 1px solid oklch(0.22 0.005 155); box-shadow: 0 20px 60px rgba(0,0,0,0.4);">
						<!-- Browser chrome -->
						<div class="flex items-center gap-2 px-4 py-2.5" style="background: oklch(0.14 0.005 155); border-bottom: 1px solid oklch(0.20 0.005 155);">
							<div class="flex gap-1.5">
								<div class="w-2.5 h-2.5 rounded-full" style="background: oklch(0.40 0.15 25);"></div>
								<div class="w-2.5 h-2.5 rounded-full" style="background: oklch(0.60 0.15 85);"></div>
								<div class="w-2.5 h-2.5 rounded-full" style="background: oklch(0.55 0.15 145);"></div>
							</div>
							<div class="flex-1 mx-4 px-3 py-1 rounded-lg text-[10px] flex items-center gap-2" style="background: oklch(0.10 0.005 155); color: oklch(0.50 0.005 155);">
								<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
								dashboard.avoqado.io/membresias
							</div>
						</div>
						<!-- Page content -->
						<div class="p-5" style="background: oklch(0.12 0.005 155);">
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-gray-500">Membresias activas — 243 miembros</span>
							<span class="text-[9px] px-2 py-0.5 rounded-full bg-avoqado-green text-black font-medium">96% retencion</span>
						</div>
						<!-- Membership cards -->
						<div class="space-y-2.5 mb-4">
							<!-- Plan Premium -->
							<div class="rounded-xl p-4" style={`background: oklch(0.16 0.005 155); border: 1px solid oklch(0.25 0.04 195);`}>
								<div class="flex items-center justify-between mb-3">
									<div class="flex items-center gap-2">
										<div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background: oklch(0.20 0.04 195); color: ${ACCENT};`}>
											<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
										</div>
										<div>
											<span class="text-xs text-white font-medium">Premium</span>
											<span class="text-[9px] text-gray-500 block">$1,499/mes — Clases ilimitadas + pesas</span>
										</div>
									</div>
									<span class="text-xs text-white">127</span>
								</div>
								<div class="flex gap-2">
									<div class="flex-1 rounded-lg p-2 text-center" style="background: oklch(0.20 0.005 155);">
										<div class="text-[10px] text-white">$190,373</div>
										<div class="text-[7px] text-gray-600">Ingreso mensual</div>
									</div>
									<div class="flex-1 rounded-lg p-2 text-center" style="background: oklch(0.20 0.005 155);">
										<div class="text-[10px] text-avoqado-green">98%</div>
										<div class="text-[7px] text-gray-600">Renovacion</div>
									</div>
								</div>
							</div>
							<!-- Plan Basico -->
							<div class="rounded-xl p-4" style="background: oklch(0.16 0.005 155);">
