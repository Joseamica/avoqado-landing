---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingChatbot from '../components/interactive/FloatingChatbot';

const ACCENT = 'oklch(0.78 0.14 75)'; // amber for entertainment
const GREEN = '#69E185';
const BLUE = 'oklch(0.72 0.14 240)';
const RED = 'oklch(0.65 0.20 25)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado para Entretenimiento | Cines, Antros, Eventos y Mas</title>
		<meta name="description" content="Gestion integral para venues de entretenimiento. Boletos, consumo en barra, reservaciones VIP, control de acceso y pagos de alto volumen en una sola plataforma." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">05</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style={`color: ${ACCENT};`}>Avoqado Entertainment</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Experiencias que se pagan solas.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							Venta de boletos, consumo en barra, control de acceso y pagos de alto volumen. Todo desde una sola plataforma para cines, antros, eventos, arcades, boliches y salones de fiestas.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://demo.dashboard.avoqado.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200" style={`background: ${ACCENT};`}>
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Hablar con ventas
							</a>
						</div>
					</div>

					<!-- Mockup: Event ticket / admission card -->
					<div class="hidden lg:block">
						<div class="rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
							<!-- Header -->
							<div class="flex items-center justify-between mb-4">
								<div class="flex items-center gap-2">
									<div class="w-6 h-6 rounded-lg flex items-center justify-center" style={`background: oklch(0.18 0.02 75); color: ${ACCENT};`}>
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 10s3-3 3-8"/><path d="M22 10s-3-3-3-8"/><path d="M10 2c0 4.4-3.6 8-8 8"/><path d="M14 2c0 4.4 3.6 8 8 8"/><path d="M2 10s2 2 2 5"/><path d="M22 10s-2 2-2 5"/><path d="M8 15h8"/><path d="M2 22h20"/><path d="M12 15v7"/></svg>
									</div>
									<span class="text-[11px] text-white font-medium">Eventos Activos — Hoy</span>
								</div>
								<span class="text-[8px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 75); color: ${ACCENT};`}>3 eventos</span>
							</div>

							<!-- Main ticket card -->
							<div class="rounded-xl p-4 mb-3 relative overflow-hidden" style={`background: linear-gradient(135deg, oklch(0.20 0.04 75), oklch(0.14 0.02 75)); border: 1px solid oklch(0.30 0.06 75);`}>
								<div class="flex items-start justify-between mb-3">
									<div>
										<span class="text-sm text-white font-medium block">Noche Electronica Vol. 12</span>
										<span class="text-[10px] text-gray-400">Sabado 22 Mar — 22:00 a 04:00</span>
									</div>
									<span class="text-[9px] px-2 py-0.5 rounded-full bg-avoqado-green text-black font-medium">En venta</span>
								</div>
								<div class="grid grid-cols-3 gap-2 mb-3">
									<div class="rounded-lg p-2 text-center" style="background: oklch(0.16 0.005 155);">
										<div class="text-sm font-light text-white">342</div>
										<div class="text-[7px] text-gray-500">Vendidos</div>
									</div>
									<div class="rounded-lg p-2 text-center" style="background: oklch(0.16 0.005 155);">
										<div class="text-sm font-light" style={`color: ${ACCENT};`}>158</div>
										<div class="text-[7px] text-gray-500">Disponibles</div>
									</div>
									<div class="rounded-lg p-2 text-center" style="background: oklch(0.16 0.005 155);">
										<div class="text-sm font-light text-avoqado-green">$171k</div>
										<div class="text-[7px] text-gray-500">Recaudado</div>
									</div>
								</div>
								<!-- Ticket types -->
								<div class="space-y-1.5">
									<div class="flex items-center justify-between px-2 py-1.5 rounded-lg" style="background: oklch(0.16 0.005 155);">
										<div class="flex items-center gap-2">
											<div class="w-1.5 h-1.5 rounded-full" style={`background: ${ACCENT};`}></div>
											<span class="text-[10px] text-white">General</span>
										</div>
										<div class="flex items-center gap-3">
											<span class="text-[9px] text-gray-500">280/400</span>
											<span class="text-[10px]" style={`color: ${ACCENT};`}>$350</span>
										</div>
									</div>
									<div class="flex items-center justify-between px-2 py-1.5 rounded-lg" style="background: oklch(0.16 0.005 155);">
										<div class="flex items-center gap-2">
											<div class="w-1.5 h-1.5 rounded-full" style={`background: ${BLUE};`}></div>
											<span class="text-[10px] text-white">VIP</span>
										</div>
										<div class="flex items-center gap-3">
											<span class="text-[9px] text-gray-500">52/80</span>
											<span class="text-[10px]" style={`color: ${BLUE};`}>$750</span>
										</div>
									</div>
									<div class="flex items-center justify-between px-2 py-1.5 rounded-lg" style="background: oklch(0.16 0.005 155);">
										<div class="flex items-center gap-2">
											<div class="w-1.5 h-1.5 rounded-full bg-avoqado-green"></div>
											<span class="text-[10px] text-white">Mesa VIP (10 pax)</span>
										</div>
										<div class="flex items-center gap-3">
											<span class="text-[9px] text-gray-500">10/20</span>
											<span class="text-[10px] text-avoqado-green">$5,000</span>
										</div>
									</div>
								</div>
							</div>

							<!-- QR validation preview -->
							<div class="flex items-center justify-between p-3 rounded-xl" style="background: oklch(0.16 0.005 155); border: 1px solid oklch(0.22 0.005 155);">
								<div class="flex items-center gap-3">
									<div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background: oklch(0.18 0.02 75); color: ${ACCENT};`}>
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 14h3v3h-3z"/><path d="M20 14v3h-3"/><path d="M14 20h3"/><path d="M20 20h0"/></svg>
									</div>
									<div>
										<span class="text-[11px] text-white">Escanear boleto QR</span>
										<span class="text-[9px] text-gray-600 block">Validacion instantanea en puerta</span>
									</div>
								</div>
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 75); color: ${ACCENT};`}>Listo</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. EVENTOS Y BOLETOS                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${ACCENT};`}>Boletos</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Vende entradas sin complicarte.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Crea eventos con multiples tipos de boleto, precios early-bird y limites de capacidad. Cada entrada genera un QR unico que se valida en puerta al instante. Sin apps de terceros, sin comisiones ocultas.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${ACCENT};`}></div>
								<span class="text-sm text-gray-600">Crea eventos con fecha, hora, descripcion y imagen desde el dashboard</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-600">General, VIP, mesa, early-bird — cada tipo con precio y stock independiente</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${BLUE};`}></div>
								<span class="text-sm text-gray-600">QR unico por boleto con validacion instantanea en puerta</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${RED};`}></div>
								<span class="text-sm text-gray-600">Control de aforo en tiempo real — sabe cuantos estan adentro ahora</span>
							</div>
						</div>
					</div>

					<!-- Event cards mockup -->
					<div class="rounded-2xl overflow-hidden border border-black/5 p-5" style="background: #0A0A0A;">
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-gray-500">Proximos eventos — 3</span>
							<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 75); color: ${ACCENT};`}>+ Crear evento</span>
						</div>
						<div class="space-y-2.5">
							<!-- Event 1 -->
							<div class="rounded-xl p-3.5" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${ACCENT};`}>
								<div class="flex items-start justify-between mb-2">
									<div>
										<span class="text-xs text-white font-medium">Noche Electronica Vol. 12</span>
										<span class="text-[9px] text-gray-500 block mt-0.5">Sab 22 Mar — 22:00 a 04:00</span>
									</div>
									<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.18 0.02 75); color: ${ACCENT};`}>En venta</span>
								</div>
								<div class="flex items-center gap-4">
									<div class="flex items-center gap-1.5">
										<div class="w-full bg-gray-800 rounded-full h-1.5 w-20">
											<div class="h-1.5 rounded-full" style={`background: ${ACCENT}; width: 68%;`}></div>
										</div>
										<span class="text-[9px] text-gray-500">342/500</span>
									</div>
									<span class="text-[9px] text-avoqado-green">$171,000</span>
								</div>
							</div>
							<!-- Event 2 -->
							<div class="rounded-xl p-3.5" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${BLUE};`}>
								<div class="flex items-start justify-between mb-2">
									<div>
										<span class="text-xs text-white font-medium">Stand-Up Comedy Night</span>
										<span class="text-[9px] text-gray-500 block mt-0.5">Vie 28 Mar — 20:00 a 23:00</span>
									</div>
									<span class="text-[8px] px-1.5 py-0.5 rounded" style={`background: oklch(0.18 0.02 240); color: ${BLUE};`}>Early-bird</span>
								</div>
								<div class="flex items-center gap-4">
									<div class="flex items-center gap-1.5">
										<div class="w-full bg-gray-800 rounded-full h-1.5 w-20">
											<div class="h-1.5 rounded-full" style={`background: ${BLUE}; width: 35%;`}></div>
										</div>
										<span class="text-[9px] text-gray-500">105/300</span>
									</div>
									<span class="text-[9px] text-avoqado-green">$31,500</span>
								</div>
							</div>
							<!-- Event 3 -->
							<div class="rounded-xl p-3.5" style="background: oklch(0.16 0.005 155); border-left: 3px solid oklch(0.40 0.005 155);">
								<div class="flex items-start justify-between mb-2">
									<div>
										<span class="text-xs text-gray-400 font-medium">Karaoke Retro 80s</span>
										<span class="text-[9px] text-gray-600 block mt-0.5">Sab 5 Abr — 19:00 a 01:00</span>
									</div>
									<span class="text-[8px] px-1.5 py-0.5 rounded" style="background: oklch(0.20 0.005 155); color: oklch(0.50 0.005 155);">Borrador</span>
								</div>
								<div class="flex items-center gap-4">
									<div class="flex items-center gap-1.5">
										<div class="w-full bg-gray-800 rounded-full h-1.5 w-20">
											<div class="h-1.5 rounded-full bg-gray-700" style="width: 0%;"></div>
										</div>
										<span class="text-[9px] text-gray-600">0/200</span>
									</div>
									<span class="text-[9px] text-gray-600">$0</span>
								</div>
							</div>
						</div>
						<!-- Access control footer -->
						<div class="mt-4 pt-3 border-t border-white/5">
							<div class="grid grid-cols-3 gap-2">
								<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
									<div class="text-sm font-light text-white">447</div>
									<div class="text-[8px] text-gray-600">Vendidos hoy</div>
								</div>
								<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
									<div class="text-sm font-light" style={`color: ${ACCENT};`}>289</div>
									<div class="text-[8px] text-gray-600">Escaneados</div>
								</div>
								<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
									<div class="text-sm font-light text-avoqado-green">$202k</div>
									<div class="text-[8px] text-gray-600">Recaudado</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. CONSUMO EN BARRA                         -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Bar tab mockup -->
					<div class="order-2 lg:order-1 rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-gray-500">Barra Principal — 8 cuentas abiertas</span>
							<div class="flex gap-1.5">
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 75); color: ${ACCENT};`}>$47,230</span>
							</div>
						</div>

						<!-- Active tab - expanded -->
						<div class="rounded-xl p-3.5 mb-2.5" style={`background: oklch(0.16 0.005 155); border: 1px solid oklch(0.30 0.06 75);`}>
							<div class="flex items-center justify-between mb-2.5">
								<div class="flex items-center gap-2">
									<div class="w-7 h-7 rounded-full flex items-center justify-center text-[9px] font-bold" style={`background: oklch(0.18 0.02 75); color: ${ACCENT};`}>DV</div>
									<div>
										<span class="text-[11px] text-white font-medium">Daniel V. — Tab</span>
										<span class="text-[8px] text-gray-600 block">Abierta hace 1h 23m</span>
									</div>
								</div>
								<div class="text-right">
									<span class="text-xs text-white font-medium">$2,870</span>
									<span class="text-[8px] block" style={`color: ${ACCENT};`}>Pre-auth $5,000</span>
								</div>
							</div>
							<div class="space-y-1">
								<div class="flex items-center justify-between text-[9px] px-2 py-1 rounded" style="background: oklch(0.14 0.005 155);">
									<span class="text-gray-300">3x Whisky Doble</span>
									<span class="text-gray-500">$1,350</span>
								</div>
								<div class="flex items-center justify-between text-[9px] px-2 py-1 rounded" style="background: oklch(0.14 0.005 155);">
									<span class="text-gray-300">2x Bucket Corona (6)</span>
									<span class="text-gray-500">$720</span>
								</div>
								<div class="flex items-center justify-between text-[9px] px-2 py-1 rounded" style="background: oklch(0.14 0.005 155);">
									<span class="text-gray-300">4x Nachos Supremos</span>
									<span class="text-gray-500">$800</span>
								</div>
							</div>
							<div class="flex gap-1.5 mt-2.5">
								<span class="text-[8px] px-2 py-1 rounded-full" style={`background: ${ACCENT}; color: black;`}>+ Agregar</span>
								<span class="text-[8px] px-2 py-1 rounded-full" style="background: oklch(0.20 0.005 155); color: oklch(0.60 0.005 155);">Cerrar tab</span>
							</div>
						</div>

						<!-- Other tabs - compact -->
						<div class="space-y-1.5">
							<div class="flex items-center justify-between p-2.5 rounded-lg" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-center gap-2">
									<div class="w-6 h-6 rounded-full flex items-center justify-center text-[8px] font-bold" style={`background: oklch(0.18 0.02 240); color: ${BLUE};`}>MR</div>
									<span class="text-[10px] text-white">Maria R.</span>
								</div>
								<div class="flex items-center gap-3">
									<span class="text-[9px] text-gray-500">5 items</span>
									<span class="text-[10px] text-white">$1,430</span>
								</div>
							</div>
							<div class="flex items-center justify-between p-2.5 rounded-lg" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-center gap-2">
									<div class="w-6 h-6 rounded-full flex items-center justify-center text-[8px] font-bold" style="background: oklch(0.18 0.02 155); color: oklch(0.60 0.10 155);">AG</div>
									<span class="text-[10px] text-white">Andrea G.</span>
								</div>
								<div class="flex items-center gap-3">
									<span class="text-[9px] text-gray-500">3 items</span>
									<span class="text-[10px] text-white">$890</span>
								</div>
							</div>
							<div class="flex items-center justify-between p-2.5 rounded-lg" style={`background: oklch(0.16 0.005 155); border-left: 2px solid ${RED};`}>
								<div class="flex items-center gap-2">
									<div class="w-6 h-6 rounded-full flex items-center justify-center text-[8px] font-bold" style={`background: oklch(0.18 0.02 25); color: ${RED};`}>LP</div>
									<span class="text-[10px] text-white">Luis P.</span>
								</div>
								<div class="flex items-center gap-3">
									<span class="text-[9px]" style={`color: ${RED};`}>Cerca del limite</span>
									<span class="text-[10px] text-white">$4,750</span>
								</div>
							</div>
						</div>
					</div>

					<div class="order-1 lg:order-2">
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${ACCENT};`}>Barra</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
							Del pedido a la barra en segundos.
						</h2>
						<p class="text-gray-400 text-lg leading-relaxed mb-8">
							Abre tabs con pre-autorizacion de tarjeta. Agrega consumos con un tap, ve el acumulado en tiempo real y cierra la cuenta cuando el cliente quiera. Ideal para noches de alto volumen donde la velocidad es todo.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${ACCENT};`}></div>
								<span class="text-sm text-gray-400"><span class="text-white">Tab con pre-auth:</span> Retiene un monto en tarjeta y cobra solo lo consumido al cerrar</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-400"><span class="text-white">Pedido rapido:</span> Favoritos, recientes y busqueda para servir en 3 taps</span>
