---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import HomepageStory from '../components/interactive/home-story/HomepageStory';
import Footer from '../components/layout/Footer.astro';
import FloatingChatbot from '../components/interactive/FloatingChatbot';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado — Punto de venta, cobros y citas para tiendas, gyms y estéticas | México</title>
		<meta name="description" content="Avoqado junta punto de venta, cobros, citas, inventario y reportes en una sola app. Para tiendas, gyms, estéticas, clínicas y negocios con varias sucursales en México." />
        <link rel="icon" type="image/png" href="/favicon.png?v=3" />
		<!-- Google Fonts - Diferentes estilos para cada industria -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Monoton&family=Black+Ops+One&family=Special+Elite&family=Bungee+Shade&display=swap" rel="stylesheet">
	</head>
	<body class="m-0 w-full bg-neutral-950 p-0">
		<Navbar position="fixed" transparentOnTop={true} />
		<main data-scrollytelling>
			<HomepageStory client:load />
		</main>
		<Footer />
		<FloatingChatbot client:idle />
	</body>
</html>
