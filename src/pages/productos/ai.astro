---
import '../../styles/global.css';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import FloatingChatbot from '../../components/interactive/FloatingChatbot';

const TEAL = 'oklch(0.75 0.14 195)';
const GREEN = '#69E185';
const AMBER = 'oklch(0.78 0.14 75)';
const RED = 'oklch(0.65 0.20 25)';
const BLUE = 'oklch(0.72 0.14 240)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Asistente IA | Avoqado</title>
		<meta name="description" content="Asistente de inteligencia artificial con Text-to-SQL. Pregunta en lenguaje natural, genera graficas, exporta reportes Excel y toma acciones directas sobre tu negocio." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">05</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style={`color: ${TEAL};`}>Asistente IA</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Pregunta lo que sea.<br/>
							Obten respuestas reales.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							Text-to-SQL sobre tus datos reales. Haz preguntas en espanol, genera graficas, exporta reportes y toma acciones — todo desde una conversacion.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://demo.dashboard.avoqado.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200 bg-white">
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Hablar con ventas
							</a>
						</div>
					</div>

					<!-- Hero chat mockup -->
					<div class="rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
						<div class="flex items-center gap-2 mb-5">
							<div class="w-7 h-7 rounded-full flex items-center justify-center" style={`background: oklch(0.20 0.02 195);`}>
								<div class="w-3 h-3 rounded-full" style={`background: ${TEAL};`}></div>
							</div>
							<span class="text-[11px] text-gray-500">Avoqado AI — Conectado a tus datos</span>
						</div>
						<div class="space-y-3">
							<!-- User message -->
							<div class="flex justify-end">
								<div class="px-4 py-2.5 rounded-2xl rounded-br-sm max-w-[80%]" style="background: oklch(0.22 0.005 155);">
									<span class="text-sm text-gray-300">Cuanto vendi esta semana vs la anterior?</span>
								</div>
							</div>
							<!-- AI response -->
							<div class="flex gap-2.5">
								<div class="w-6 h-6 rounded-full shrink-0 flex items-center justify-center mt-0.5" style={`background: oklch(0.20 0.02 195);`}>
									<div class="w-2.5 h-2.5 rounded-full" style={`background: ${TEAL};`}></div>
								</div>
								<div class="px-4 py-2.5 rounded-2xl rounded-bl-sm max-w-[85%]" style="background: oklch(0.16 0.005 155);">
									<span class="text-sm text-gray-300">
										Esta semana: <span class="text-white font-medium">$187,400</span>. Semana anterior: $162,100. Eso es un <span style={`color: ${GREEN};`} class="font-medium">+15.6%</span> de crecimiento. El pico fue el viernes con $42,800.
									</span>
								</div>
							</div>
							<!-- User message 2 -->
							<div class="flex justify-end">
								<div class="px-4 py-2.5 rounded-2xl rounded-br-sm max-w-[80%]" style="background: oklch(0.22 0.005 155);">
									<span class="text-sm text-gray-300">Generame la grafica de ventas por dia</span>
								</div>
							</div>
							<!-- AI chart response -->
							<div class="flex gap-2.5">
								<div class="w-6 h-6 rounded-full shrink-0 flex items-center justify-center mt-0.5" style={`background: oklch(0.20 0.02 195);`}>
									<div class="w-2.5 h-2.5 rounded-full" style={`background: ${TEAL};`}></div>
								</div>
								<div class="rounded-2xl rounded-bl-sm max-w-[85%] overflow-hidden" style="background: oklch(0.16 0.005 155);">
									<div class="px-4 pt-2.5 pb-2">
										<span class="text-sm text-gray-300">Aqui tienes el desglose diario:</span>
									</div>
									<!-- Mini chart -->
									<div class="px-4 pb-3">
										<div class="flex items-end gap-1 h-16">
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 50%; background: ${TEAL}; opacity: 0.5;`}></div>
												<span class="text-[7px] text-gray-600">Lun</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 60%; background: ${TEAL}; opacity: 0.6;`}></div>
												<span class="text-[7px] text-gray-600">Mar</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 45%; background: ${TEAL}; opacity: 0.5;`}></div>
												<span class="text-[7px] text-gray-600">Mie</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 70%; background: ${TEAL}; opacity: 0.7;`}></div>
												<span class="text-[7px] text-gray-600">Jue</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 95%; background: ${TEAL};`}></div>
												<span class="text-[7px] text-gray-600">Vie</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 85%; background: ${TEAL}; opacity: 0.85;`}></div>
												<span class="text-[7px] text-gray-600">Sab</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 55%; background: ${TEAL}; opacity: 0.55;`}></div>
												<span class="text-[7px] text-gray-600">Dom</span>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
						<!-- Input bar -->
						<div class="flex items-center gap-2 mt-4 px-4 py-2.5 rounded-full" style="background: oklch(0.18 0.005 155); border: 1px solid oklch(0.25 0.005 155);">
							<div class="w-4 h-4 rounded-full opacity-50" style={`background: ${TEAL};`}></div>
							<span class="text-sm text-gray-600">Pregunta lo que sea...</span>
							<div class="ml-auto w-6 h-6 rounded-full flex items-center justify-center" style={`background: ${TEAL};`}>
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. LENGUAJE NATURAL                         -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${TEAL};`}>Lenguaje natural</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
							Pregunta como le preguntarias a un experto.
						</h2>
						<p class="text-gray-400 text-lg leading-relaxed mb-8">
							No necesitas saber SQL, ni filtros, ni navegar reportes. Escribe tu pregunta en espanol y el asistente consulta directamente tus datos reales — ventas, inventario, clientes, empleados, ordenes.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${TEAL};`}></div>
								<span class="text-sm text-gray-400"><span class="text-white">Schema-aware:</span> entiende la estructura exacta de tu base de datos</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${GREEN};`}></div>
								<span class="text-sm text-gray-400"><span class="text-white">Intent routing:</span> detecta automaticamente que tipo de consulta necesitas</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${AMBER};`}></div>
								<span class="text-sm text-gray-400"><span class="text-white">Feedback loop:</span> correcto, incorrecto o parcial — el modelo aprende de ti</span>
							</div>
						</div>
					</div>

					<!-- Example questions mockup -->
					<div class="rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
						<div class="text-[11px] text-gray-500 mb-4">Preguntas frecuentes</div>
						<div class="space-y-3">
							<!-- Question 1 -->
							<div class="rounded-xl p-4" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-start gap-3 mb-2.5">
									<svg class="w-4 h-4 mt-0.5 shrink-0" style={`color: ${TEAL};`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
									<span class="text-sm text-white">Cual fue mi producto mas vendido este mes?</span>
								</div>
								<div class="pl-7">
									<div class="text-[10px] text-gray-500 mb-1">Respuesta</div>
									<span class="text-[11px] text-gray-400"><span class="text-white font-medium">Tacos al Pastor</span> — 1,247 unidades, $118,465 en ventas. 23% del total.</span>
								</div>
							</div>
							<!-- Question 2 -->
							<div class="rounded-xl p-4" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-start gap-3 mb-2.5">
									<svg class="w-4 h-4 mt-0.5 shrink-0" style={`color: ${TEAL};`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
									<span class="text-sm text-white">Cuantos clientes nuevos tuve esta semana?</span>
								</div>
								<div class="pl-7">
									<div class="text-[10px] text-gray-500 mb-1">Respuesta</div>
									<span class="text-[11px] text-gray-400"><span class="font-medium" style={`color: ${TEAL};`}>47 clientes nuevos</span>. Martes fue el dia con mas registros (14). Ticket promedio de nuevos: $385.</span>
								</div>
							</div>
							<!-- Question 3 -->
							<div class="rounded-xl p-4" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-start gap-3 mb-2.5">
									<svg class="w-4 h-4 mt-0.5 shrink-0" style={`color: ${TEAL};`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
									<span class="text-sm text-white">Que ingredientes necesito comprar para manana?</span>
								</div>
								<div class="pl-7">
									<div class="text-[10px] text-gray-500 mb-1">Respuesta</div>
									<span class="text-[11px] text-gray-400">Basado en proyeccion de demanda: <span style={`color: ${AMBER};`}>Limon (stock al 12%)</span>, <span style={`color: ${RED};`}>Queso (stock al 8%)</span>, Aguacate (stock al 22%).</span>
								</div>
							</div>
							<!-- Question 4 -->
							<div class="rounded-xl p-4" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-start gap-3 mb-2.5">
									<svg class="w-4 h-4 mt-0.5 shrink-0" style={`color: ${TEAL};`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
									<span class="text-sm text-white">Quien genero mas propinas el fin de semana?</span>
								</div>
								<div class="pl-7">
									<div class="text-[10px] text-gray-500 mb-1">Respuesta</div>
									<span class="text-[11px] text-gray-400"><span class="text-white font-medium">Maria G.</span> — $3,240 en propinas (18.4% de sus ventas). Promedio del equipo: 12.1%.</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. GRAFICAS Y VISUALIZACION — WHITE BG       -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="text-center max-w-2xl mx-auto mb-12">
					<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${TEAL};`}>Visualizacion</span>
					<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
						Visualiza tus datos al instante.
					</h2>
					<p class="text-gray-600 text-lg leading-relaxed">
						El asistente genera graficas automaticamente cuando la respuesta lo amerita. Barras, lineas, pastel — el formato que mejor cuente la historia de tus datos.
					</p>
				</div>

				<!-- Large chart mockup centered -->
				<div class="max-w-3xl mx-auto rounded-2xl overflow-hidden border border-white/5 p-6" style="background: oklch(0.12 0.005 155);">
					<!-- Chart header -->
					<div class="flex items-center justify-between mb-6">
						<div>
							<span class="text-sm text-white font-medium">Ventas por categoria — Ultima semana</span>
							<span class="text-[10px] text-gray-600 block mt-0.5">Generado por AI a las 14:32</span>
						</div>
						<div class="flex gap-2">
							<span class="text-[9px] px-2 py-1 rounded-full" style={`background: oklch(0.18 0.02 195); color: ${TEAL};`}>Excel</span>
							<span class="text-[9px] px-2 py-1 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.40 0.005 155);">PNG</span>
						</div>
					</div>

					<!-- Bar chart -->
					<div class="rounded-xl p-5 mb-4" style="background: oklch(0.14 0.005 155);">
						<!-- Y axis labels + bars -->
						<div class="flex gap-4">
							<!-- Y axis -->
							<div class="flex flex-col justify-between text-[8px] text-gray-600 py-1 shrink-0 w-8 text-right">
								<span>$50k</span>
								<span>$40k</span>
								<span>$30k</span>
								<span>$20k</span>
								<span>$10k</span>
								<span>$0</span>
							</div>
							<!-- Bars -->
							<div class="flex-1 flex items-end gap-3 h-48 md:h-56">
								<div class="flex-1 flex flex-col items-center gap-1.5 h-full justify-end">
									<div class="w-full rounded-t" style={`height: 85%; background: ${TEAL};`}></div>
									<span class="text-[9px] text-gray-500">Alimentos</span>
									<span class="text-[9px] text-white">$42,800</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-1.5 h-full justify-end">
									<div class="w-full rounded-t" style={`height: 58%; background: ${TEAL}; opacity: 0.75;`}></div>
									<span class="text-[9px] text-gray-500">Bebidas</span>
									<span class="text-[9px] text-white">$29,100</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-1.5 h-full justify-end">
									<div class="w-full rounded-t" style={`height: 32%; background: ${TEAL}; opacity: 0.55;`}></div>
									<span class="text-[9px] text-gray-500">Postres</span>
									<span class="text-[9px] text-white">$16,200</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-1.5 h-full justify-end">
									<div class="w-full rounded-t" style={`height: 22%; background: ${TEAL}; opacity: 0.45;`}></div>
									<span class="text-[9px] text-gray-500">Entradas</span>
									<span class="text-[9px] text-white">$11,400</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-1.5 h-full justify-end">
									<div class="w-full rounded-t" style={`height: 14%; background: ${TEAL}; opacity: 0.35;`}></div>
									<span class="text-[9px] text-gray-500">Extras</span>
									<span class="text-[9px] text-white">$7,100</span>
								</div>
							</div>
						</div>
					</div>

					<!-- Trend line chart -->
					<div class="rounded-xl p-5" style="background: oklch(0.14 0.005 155);">
						<div class="text-[10px] text-gray-500 mb-3">Tendencia semanal — Alimentos vs Bebidas</div>
						<div class="relative h-20">
							<!-- Grid lines -->
							<div class="absolute inset-0 flex flex-col justify-between">
								<div class="border-t border-white/5"></div>
								<div class="border-t border-white/5"></div>
								<div class="border-t border-white/5"></div>
								<div class="border-t border-white/5"></div>
							</div>
							<!-- SVG trend lines -->
							<svg class="w-full h-full" viewBox="0 0 300 80" preserveAspectRatio="none">
								<!-- Alimentos line -->
								<polyline
									points="0,60 50,45 100,50 150,35 200,20 250,15 300,25"
									fill="none"
									stroke={TEAL}
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
								<!-- Bebidas line -->
								<polyline
									points="0,70 50,65 100,60 150,55 200,40 250,45 300,50"
									fill="none"
									stroke={TEAL}
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									opacity="0.4"
								/>
							</svg>
						</div>
						<div class="flex gap-4 mt-2">
							<div class="flex items-center gap-1.5">
								<div class="w-3 h-0.5 rounded-full" style={`background: ${TEAL};`}></div>
								<span class="text-[9px] text-gray-500">Alimentos</span>
							</div>
							<div class="flex items-center gap-1.5">
								<div class="w-3 h-0.5 rounded-full" style={`background: ${TEAL}; opacity: 0.4;`}></div>
								<span class="text-[9px] text-gray-500">Bebidas</span>
							</div>
						</div>
					</div>

					<!-- Prompt that generated this -->
					<div class="mt-4 pt-4 border-t border-white/5">
						<div class="flex items-center gap-2">
							<div class="w-4 h-4 rounded-full shrink-0 flex items-center justify-center" style="background: oklch(0.22 0.005 155);">
								<svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="oklch(0.50 0.005 155)" stroke-width="2.5" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
							</div>
							<span class="text-[10px] text-gray-600 italic">"Muestrame las ventas por categoria de esta semana con grafica"</span>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 3. EXPORTAR REPORTES                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Report files mockup -->
					<div class="order-2 lg:order-1 rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
						<div class="text-[11px] text-gray-500 mb-4">Reportes generados por AI</div>
						<div class="space-y-2.5">
							<!-- File 1 -->
							<div class="flex items-center justify-between p-4 rounded-xl" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-center gap-3">
									<div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background: oklch(0.14 0.04 155);">
