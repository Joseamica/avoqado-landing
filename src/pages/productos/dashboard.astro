---
import '../../styles/global.css';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import FloatingChatbot from '../../components/interactive/FloatingChatbot';

// Paleta: tokens compartidos de src/styles/global.css (--color-product-*,
// --color-alert-*, --color-mockup-*, --color-neutral-*). Sin consts locales.
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Dashboard Web | Avoqado</title>
		<meta name="description" content="Panel de control integral con 31 modulos: reportes, ligas de pago, gestion de terminales, CRM, inventario, asistente IA y mas." />
		<link rel="icon" type="image/png" href="/favicon.png?v=3" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={false} />
		<main>


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="bg-white min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-black/10">01</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style="color: var(--color-product-dashboard-deep);">Dashboard Web</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-black mb-8">
							31 modulos.<br/>
							Un solo panel.
						</h1>
						<p class="text-lg md:text-xl text-neutral-600 max-w-xl leading-relaxed mb-10">
							Reportes detallados, ligas de pago, gestion remota de terminales, CRM con programa de lealtad, asistente de IA y mucho mas — todo conectado en tiempo real.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://avoqado.io/demo" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200" style="background: var(--color-product-dashboard);">
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-black/15 text-black font-medium rounded-full hover:bg-black/5 hover:-translate-y-0.5 transition-all duration-200">
								Agendar demo
							</a>
						</div>
					</div>

					<!-- Browser mockup — visible en todos los tamanos; tilt 3D solo en desktop -->
					<div>
						<div aria-hidden="true" class="rounded-xl overflow-hidden lg:[transform:perspective(1200px)_rotateY(-8deg)_rotateX(2deg)]" style="box-shadow: 0 25px 80px rgba(0,0,0,0.4);">
							<!-- Browser chrome -->
							<div class="flex items-center gap-2 px-4 py-2.5" style="background: var(--color-mockup-chrome);">
								<div class="flex gap-1.5">
									<div class="w-3 h-3 rounded-full" style="background: #FF5F57;"></div>
									<div class="w-3 h-3 rounded-full" style="background: #FEBC2E;"></div>
									<div class="w-3 h-3 rounded-full" style="background: #28C840;"></div>
								</div>
								<div class="flex-1 flex items-center gap-1.5 mx-3 px-3 py-1 rounded-md" style="background: var(--color-mockup-dim);">
									<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--color-mockup-ink-faint);" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
									<span class="text-[10px]" style="color: var(--color-mockup-ink-faint);">dashboard.avoqado.io</span>
								</div>
							</div>
							<!-- Dashboard screen -->
							<div class="flex" style="background: var(--color-mockup-bg); min-height: 340px;">
								<!-- Sidebar — en moviles se oculta para que el contenido respire -->
								<div class="hidden sm:block w-[140px] shrink-0 border-r py-4 px-3 space-y-1" style="border-color: var(--color-mockup-raised);">
									<div class="flex items-center gap-2 px-2 py-1.5 rounded-md" style="background: var(--color-product-dashboard-tint);">
										<div class="w-3.5 h-3.5 rounded" style="background: var(--color-product-dashboard); opacity: 0.92;"></div>
										<span class="text-[9px] font-medium" style="color: var(--color-product-dashboard);">Overview</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: var(--color-mockup-muted);"></div>
										<span class="text-[9px] text-neutral-500">Ventas</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: var(--color-mockup-muted);"></div>
										<span class="text-[9px] text-neutral-500">Ordenes</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: var(--color-mockup-muted);"></div>
										<span class="text-[9px] text-neutral-500">Productos</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: var(--color-mockup-muted);"></div>
										<span class="text-[9px] text-neutral-500">Clientes</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: var(--color-mockup-muted);"></div>
										<span class="text-[9px] text-neutral-500">Terminales</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: var(--color-mockup-muted);"></div>
										<span class="text-[9px] text-neutral-500">Ligas de pago</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: var(--color-mockup-muted);"></div>
										<span class="text-[9px] text-neutral-500">Empleados</span>
									</div>
								</div>
								<!-- Main content -->
								<div class="flex-1 p-4">
									<!-- Header -->
									<div class="flex items-center justify-between mb-4">
										<span class="text-[11px] text-white font-medium">Overview</span>
										<span class="text-[9px] px-2 py-0.5 rounded" style="background: var(--color-mockup-raised); color: var(--color-mockup-ink-faint);">Hoy</span>
									</div>
									<!-- KPI Cards -->
									<div class="grid grid-cols-3 gap-2 mb-4">
										<div class="rounded-lg p-3" style="background: var(--color-product-dashboard-tint);">
											<div class="text-[8px] mb-1" style="color: var(--color-product-dashboard); opacity: 0.7;">Ventas</div>
											<div class="text-base font-light text-white">$24,850</div>
											<div class="text-[8px] mt-0.5" style="color: var(--color-product-dashboard);">+12%</div>
										</div>
										<div class="rounded-lg p-3" style="background: var(--color-product-tpv-tint);">
											<div class="text-[8px] text-avoqado-green mb-1" style="opacity: 0.7;">Ordenes</div>
											<div class="text-base font-light text-white">127</div>
											<div class="text-[8px] text-avoqado-green mt-0.5">+8%</div>
										</div>
										<div class="rounded-lg p-3" style="background: var(--color-alert-amber-tint);">
											<div class="text-[8px] mb-1" style="color: var(--color-alert-amber); opacity: 0.7;">Ticket prom.</div>
											<div class="text-base font-light text-white">$195</div>
											<div class="text-[8px] mt-0.5" style="color: var(--color-alert-amber);">+3%</div>
										</div>
									</div>
									<!-- Bar Chart -->
									<div class="rounded-lg p-3" style="background: var(--color-mockup-elevated);">
										<div class="flex items-center justify-between mb-2">
											<span class="text-[8px] text-neutral-500">Ventas por dia</span>
											<span class="text-[8px] text-neutral-500">Ultima semana</span>
										</div>
										<div class="flex items-end gap-1.5 h-16">
											<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
												<div class="w-full rounded-t" style="height: 45%; background: var(--color-product-dashboard); opacity: 0.72;"></div>
												<span class="text-[6px] text-neutral-500">L</span>
											</div>
											<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
												<div class="w-full rounded-t" style="height: 60%; background: var(--color-product-dashboard); opacity: 0.82;"></div>
												<span class="text-[6px] text-neutral-500">M</span>
											</div>
											<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
												<div class="w-full rounded-t" style="height: 50%; background: var(--color-product-dashboard); opacity: 0.77;"></div>
												<span class="text-[6px] text-neutral-500">X</span>
											</div>
											<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
												<div class="w-full rounded-t" style="height: 70%; background: var(--color-product-dashboard); opacity: 0.92;"></div>
												<span class="text-[6px] text-neutral-500">J</span>
											</div>
											<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
												<div class="w-full rounded-t" style="height: 90%; background: var(--color-product-dashboard); opacity: 1;"></div>
												<span class="text-[6px] text-neutral-500">V</span>
											</div>
											<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
												<div class="w-full rounded-t" style="height: 100%; background: var(--color-product-dashboard);"></div>
												<span class="text-[6px] text-neutral-500">S</span>
											</div>
											<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
												<div class="w-full rounded-t" style="height: 75%; background: var(--color-product-dashboard); opacity: 0.92;"></div>
												<span class="text-[6px] text-neutral-500">D</span>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. REPORTES DETALLADOS                      -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/10">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style="color: var(--color-product-dashboard);">Reportes</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
							Datos que si sirven para decidir.
						</h2>
						<p class="text-neutral-400 text-lg leading-relaxed mb-8">
							No son graficas bonitas sin contexto. Cada reporte cruza datos de ventas, pagos, inventario y personal para darte respuestas que puedes actuar hoy.
						</p>
						<div class="space-y-4">
							<div class="border-t border-white/10 pt-3">
								<h3 class="text-base text-white font-medium mb-1">Sales Summary</h3>
								<p class="text-sm text-neutral-400">Ventas por periodo con desglose por metodo de pago, canal, y empleado. Compara dia vs dia, semana vs semana.</p>
							</div>
							<div class="border-t border-white/10 pt-3">
								<h3 class="text-base text-white font-medium mb-1">Sales by Item</h3>
								<p class="text-sm text-neutral-400">Que se vende, que no, margenes por producto, variacion vs periodo anterior.</p>
							</div>
							<div class="border-t border-white/10 pt-3">
								<h3 class="text-base text-white font-medium mb-1">Payment Analytics</h3>
								<p class="text-sm text-neutral-400">Profit metrics, comparativa entre procesadores de pago, time series, export a Excel.</p>
							</div>
							<div class="border-t border-white/10 pt-3">
								<h3 class="text-base text-white font-medium mb-1">Closing Report</h3>
								<p class="text-sm text-neutral-400">Reporte de cierre diario: ventas, devoluciones, propinas, corte de caja, varianza.</p>
							</div>
						</div>
					</div>

					<!-- Reports mockup -->
					<div aria-hidden="true" class="rounded-2xl overflow-hidden border border-black/10 p-5" style="background: var(--color-mockup-light-bg);">
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-neutral-500">Sales Summary — Ultima semana</span>
							<div class="flex gap-2">
								<span class="text-[9px] px-2 py-1 rounded-full" style="background: var(--color-product-dashboard-tint-light); color: var(--color-product-dashboard-deep);">Excel</span>
								<span class="text-[9px] px-2 py-1 rounded-full" style="background: var(--color-mockup-light-card); color: var(--color-neutral-500);">PDF</span>
							</div>
						</div>
						<!-- KPIs -->
						<div class="grid grid-cols-3 gap-2 mb-4">
							<div class="rounded-lg p-3 text-center" style="background: var(--color-mockup-light-card);">
								<div class="text-lg font-light text-neutral-900">$142,800</div>
								<div class="text-[9px] text-neutral-400">Ventas totales</div>
								<div class="text-[9px] text-[var(--color-product-tpv-deep)] mt-1">+14% vs anterior</div>
							</div>
							<div class="rounded-lg p-3 text-center" style="background: var(--color-mockup-light-card);">
								<div class="text-lg font-light text-neutral-900">312</div>
								<div class="text-[9px] text-neutral-400">Transacciones</div>
								<div class="text-[9px]" style="color: var(--color-product-dashboard-deep);">$457 prom.</div>
							</div>
							<div class="rounded-lg p-3 text-center" style="background: var(--color-mockup-light-card);">
								<div class="text-lg font-light text-neutral-900">$12,450</div>
								<div class="text-[9px] text-neutral-400">Propinas</div>
								<div class="text-[9px] text-[var(--color-product-tpv-deep)]">8.7% del total</div>
							</div>
						</div>
						<!-- Chart -->
						<div class="rounded-lg p-3 mb-3" style="background: var(--color-mockup-light-card);">
							<div class="flex items-end gap-1 h-20">
								<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
									<div class="w-full rounded-t" style="height: 40%; background: var(--color-product-dashboard-deep); opacity: 0.72;"></div>
									<span class="text-[7px] text-neutral-400">Lun</span>
								</div>
								<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
									<div class="w-full rounded-t" style="height: 55%; background: var(--color-product-dashboard-deep); opacity: 0.82;"></div>
									<span class="text-[7px] text-neutral-400">Mar</span>
								</div>
								<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
									<div class="w-full rounded-t" style="height: 45%; background: var(--color-product-dashboard-deep); opacity: 0.77;"></div>
									<span class="text-[7px] text-neutral-400">Mie</span>
								</div>
								<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
									<div class="w-full rounded-t" style="height: 65%; background: var(--color-product-dashboard-deep); opacity: 0.92;"></div>
									<span class="text-[7px] text-neutral-400">Jue</span>
								</div>
								<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
									<div class="w-full rounded-t" style="height: 90%; background: var(--color-product-dashboard-deep); opacity: 1;"></div>
									<span class="text-[7px] text-neutral-400">Vie</span>
								</div>
								<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
									<div class="w-full rounded-t" style="height: 95%; background: var(--color-product-dashboard-deep);"></div>
									<span class="text-[7px] text-neutral-400">Sab</span>
								</div>
								<div class="flex-1 h-full flex flex-col items-center justify-end gap-0.5">
									<div class="w-full rounded-t" style="height: 70%; background: var(--color-product-dashboard-deep); opacity: 0.97;"></div>
									<span class="text-[7px] text-neutral-400">Dom</span>
								</div>
							</div>
						</div>
						<!-- Payment breakdown -->
						<div class="space-y-1.5">
							<div class="flex items-center justify-between p-2 rounded" style="background: var(--color-mockup-light-card);">
								<div class="flex items-center gap-2">
									<div class="w-2 h-2 rounded-full" style="background: var(--color-product-dashboard-deep);"></div>
									<span class="text-[10px] text-neutral-400">Tarjeta</span>
								</div>
								<span class="text-[10px] text-neutral-900">$98,400 (69%)</span>
							</div>
							<div class="flex items-center justify-between p-2 rounded" style="background: var(--color-mockup-light-card);">
								<div class="flex items-center gap-2">
									<div class="w-2 h-2 rounded-full bg-avoqado-green"></div>
									<span class="text-[10px] text-neutral-400">Efectivo</span>
								</div>
								<span class="text-[10px] text-neutral-900">$32,100 (22%)</span>
							</div>
							<div class="flex items-center justify-between p-2 rounded" style="background: var(--color-mockup-light-card);">
								<div class="flex items-center gap-2">
									<div class="w-2 h-2 rounded-full" style="background: var(--color-alert-amber-deep);"></div>
									<span class="text-[10px] text-neutral-400">Transferencia</span>
								</div>
								<span class="text-[10px] text-neutral-900">$12,300 (9%)</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. LIGAS DE PAGO                            -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/10">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Payment link mockup -->
					<div aria-hidden="true" class="order-2 lg:order-1 rounded-2xl overflow-hidden border border-black/10 p-5" style="background: var(--color-mockup-surface);">
						<div class="text-[11px] text-neutral-500 mb-4">Liga de pago activa</div>
						<!-- Link card -->
						<div class="rounded-xl p-4 mb-4" style="background: var(--color-mockup-raised);">
							<div class="flex items-center justify-between mb-3">
								<span class="text-sm text-white font-medium">Paquete 10 clases — Yoga</span>
								<span class="text-[9px] px-2 py-0.5 rounded-full bg-avoqado-green text-black font-medium">Activa</span>
							</div>
							<div class="flex items-center gap-2 mb-3 p-2 rounded-lg" style="background: var(--color-mockup-elevated);">
								<span class="text-[10px] text-neutral-400 truncate flex-1">avoqado.io/pay/xK3mN8p2</span>
								<span class="text-[9px] px-2 py-0.5 rounded" style="background: var(--color-product-dashboard-tint-strong); color: var(--color-product-dashboard);">Copiar</span>
							</div>
							<div class="grid grid-cols-2 gap-3">
								<div>
									<div class="text-[9px] text-neutral-500 mb-1">Monto</div>
									<div class="text-sm text-white">$2,500.00</div>
								</div>
								<div>
									<div class="text-[9px] text-neutral-500 mb-1">Propina</div>
									<div class="text-sm text-white">10%, 15%, 20%</div>
								</div>
								<div>
									<div class="text-[9px] text-neutral-500 mb-1">Expira</div>
									<div class="text-sm text-white">24 mar, 23:59</div>
								</div>
								<div>
									<div class="text-[9px] text-neutral-500 mb-1">Recolectado</div>
									<div class="text-sm text-avoqado-green">$7,500 / 3 pagos</div>
								</div>
							</div>
						</div>
						<!-- Share options -->
						<div class="flex gap-2">
							<div class="flex-1 h-9 rounded-lg flex items-center justify-center gap-1.5" style="background: var(--color-mockup-raised);">
								<div class="w-3.5 h-3.5 rounded-full bg-avoqado-green"></div>
								<span class="text-[10px] text-white">WhatsApp</span>
							</div>
							<div class="flex-1 h-9 rounded-lg flex items-center justify-center gap-1.5" style="background: var(--color-mockup-raised);">
								<div class="w-3.5 h-3.5 rounded-full" style="background: var(--color-product-dashboard);"></div>
								<span class="text-[10px] text-white">Email</span>
							</div>
							<div class="flex-1 h-9 rounded-lg flex items-center justify-center gap-1.5" style="background: var(--color-mockup-raised);">
								<div class="w-3.5 h-3.5 rounded-full" style="background: var(--color-alert-amber);"></div>
								<span class="text-[10px] text-white">QR</span>
							</div>
						</div>
					</div>

					<div class="order-1 lg:order-2">
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style="color: var(--color-product-dashboard-deep);">Cobra sin terminal</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Un link. Cualquier lugar.
