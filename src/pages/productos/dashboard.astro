---
import '../../styles/global.css';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import FloatingChatbot from '../../components/interactive/FloatingChatbot';

const BLUE = 'oklch(0.72 0.14 240)';
const GREEN = '#69E185';
const AMBER = 'oklch(0.78 0.14 75)';
const RED = 'oklch(0.65 0.20 25)';
const INDIGO = 'oklch(0.68 0.15 290)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Dashboard Web | Avoqado</title>
		<meta name="description" content="Panel de control integral con 31 modulos: reportes, ligas de pago, gestion de terminales, CRM, inventario, asistente IA y mas." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">01</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style={`color: ${BLUE};`}>Dashboard Web</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							31 modulos.<br/>
							Un solo panel.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							Reportes detallados, ligas de pago, gestion remota de terminales, CRM con programa de lealtad, asistente de IA y mucho mas — todo conectado en tiempo real.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://demo.dashboard.avoqado.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200" style={`background: ${BLUE};`}>
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Agendar demo
							</a>
						</div>
					</div>

					<!-- Browser mockup -->
					<div class="hidden lg:block">
						<div class="rounded-xl overflow-hidden" style="transform: perspective(1200px) rotateY(-8deg) rotateX(2deg); box-shadow: 0 25px 80px rgba(0,0,0,0.4);">
							<!-- Browser chrome -->
							<div class="flex items-center gap-2 px-4 py-2.5" style="background: oklch(0.18 0.005 155);">
								<div class="flex gap-1.5">
									<div class="w-3 h-3 rounded-full" style="background: #FF5F57;"></div>
									<div class="w-3 h-3 rounded-full" style="background: #FEBC2E;"></div>
									<div class="w-3 h-3 rounded-full" style="background: #28C840;"></div>
								</div>
								<div class="flex-1 flex items-center gap-1.5 mx-3 px-3 py-1 rounded-md" style="background: oklch(0.14 0.005 155);">
									<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="oklch(0.45 0.005 155)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
									<span class="text-[10px]" style="color: oklch(0.45 0.005 155);">dashboard.avoqado.io</span>
								</div>
							</div>
							<!-- Dashboard screen -->
							<div class="flex" style="background: oklch(0.10 0.005 155); min-height: 340px;">
								<!-- Sidebar -->
								<div class="w-[140px] shrink-0 border-r py-4 px-3 space-y-1" style="border-color: oklch(0.16 0.005 155);">
									<div class="flex items-center gap-2 px-2 py-1.5 rounded-md" style={`background: oklch(0.16 0.02 240);`}>
										<div class="w-3.5 h-3.5 rounded" style={`background: ${BLUE}; opacity: 0.7;`}></div>
										<span class="text-[9px] font-medium" style={`color: ${BLUE};`}>Overview</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: oklch(0.22 0.005 155);"></div>
										<span class="text-[9px] text-gray-600">Ventas</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: oklch(0.22 0.005 155);"></div>
										<span class="text-[9px] text-gray-600">Ordenes</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: oklch(0.22 0.005 155);"></div>
										<span class="text-[9px] text-gray-600">Productos</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: oklch(0.22 0.005 155);"></div>
										<span class="text-[9px] text-gray-600">Clientes</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: oklch(0.22 0.005 155);"></div>
										<span class="text-[9px] text-gray-600">Terminales</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: oklch(0.22 0.005 155);"></div>
										<span class="text-[9px] text-gray-600">Ligas de pago</span>
									</div>
									<div class="flex items-center gap-2 px-2 py-1.5">
										<div class="w-3.5 h-3.5 rounded" style="background: oklch(0.22 0.005 155);"></div>
										<span class="text-[9px] text-gray-600">Empleados</span>
									</div>
								</div>
								<!-- Main content -->
								<div class="flex-1 p-4">
									<!-- Header -->
									<div class="flex items-center justify-between mb-4">
										<span class="text-[11px] text-white font-medium">Overview</span>
										<span class="text-[9px] px-2 py-0.5 rounded" style="background: oklch(0.16 0.005 155); color: oklch(0.45 0.005 155);">Hoy</span>
									</div>
									<!-- KPI Cards -->
									<div class="grid grid-cols-3 gap-2 mb-4">
										<div class="rounded-lg p-3" style={`background: oklch(0.14 0.02 240);`}>
											<div class="text-[8px] mb-1" style={`color: ${BLUE}; opacity: 0.7;`}>Ventas</div>
											<div class="text-base font-light text-white">$24,850</div>
											<div class="text-[8px] mt-0.5" style={`color: ${BLUE};`}>+12%</div>
										</div>
										<div class="rounded-lg p-3" style="background: oklch(0.14 0.02 155);">
											<div class="text-[8px] text-avoqado-green mb-1" style="opacity: 0.7;">Ordenes</div>
											<div class="text-base font-light text-white">127</div>
											<div class="text-[8px] text-avoqado-green mt-0.5">+8%</div>
										</div>
										<div class="rounded-lg p-3" style="background: oklch(0.14 0.02 75);">
											<div class="text-[8px] mb-1" style={`color: ${AMBER}; opacity: 0.7;`}>Ticket prom.</div>
											<div class="text-base font-light text-white">$195</div>
											<div class="text-[8px] mt-0.5" style={`color: ${AMBER};`}>+3%</div>
										</div>
									</div>
									<!-- Bar Chart -->
									<div class="rounded-lg p-3" style="background: oklch(0.13 0.005 155);">
										<div class="flex items-center justify-between mb-2">
											<span class="text-[8px] text-gray-600">Ventas por dia</span>
											<span class="text-[8px] text-gray-600">Ultima semana</span>
										</div>
										<div class="flex items-end gap-1.5 h-16">
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 45%; background: ${BLUE}; opacity: 0.5;`}></div>
												<span class="text-[6px] text-gray-600">L</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 60%; background: ${BLUE}; opacity: 0.6;`}></div>
												<span class="text-[6px] text-gray-600">M</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 50%; background: ${BLUE}; opacity: 0.55;`}></div>
												<span class="text-[6px] text-gray-600">X</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 70%; background: ${BLUE}; opacity: 0.7;`}></div>
												<span class="text-[6px] text-gray-600">J</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 90%; background: ${BLUE}; opacity: 0.85;`}></div>
												<span class="text-[6px] text-gray-600">V</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 100%; background: ${BLUE};`}></div>
												<span class="text-[6px] text-gray-600">S</span>
											</div>
											<div class="flex-1 flex flex-col items-center gap-0.5">
												<div class="w-full rounded-t" style={`height: 75%; background: ${BLUE}; opacity: 0.7;`}></div>
												<span class="text-[6px] text-gray-600">D</span>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. REPORTES DETALLADOS                      -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${BLUE};`}>Reportes</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Datos que si sirven para decidir.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							No son graficas bonitas sin contexto. Cada reporte cruza datos de ventas, pagos, inventario y personal para darte respuestas que puedes actuar hoy.
						</p>
						<div class="space-y-4">
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Sales Summary</h3>
								<p class="text-sm text-gray-500">Ventas por periodo con desglose por metodo de pago, canal, y empleado. Compara dia vs dia, semana vs semana.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Sales by Item</h3>
								<p class="text-sm text-gray-500">Que se vende, que no, margenes por producto, variacion vs periodo anterior.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Payment Analytics</h3>
								<p class="text-sm text-gray-500">Profit metrics, comparativa entre procesadores de pago, time series, export a Excel.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Closing Report</h3>
								<p class="text-sm text-gray-500">Reporte de cierre diario: ventas, devoluciones, propinas, corte de caja, varianza.</p>
							</div>
						</div>
					</div>

					<!-- Reports mockup -->
					<div class="rounded-2xl overflow-hidden border border-black/5 p-5" style="background: #0A0A0A;">
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-gray-500">Sales Summary — Ultima semana</span>
							<div class="flex gap-2">
								<span class="text-[9px] px-2 py-1 rounded-full" style={`background: oklch(0.18 0.02 240); color: ${BLUE};`}>Excel</span>
								<span class="text-[9px] px-2 py-1 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.40 0.005 155);">PDF</span>
							</div>
						</div>
						<!-- KPIs -->
						<div class="grid grid-cols-3 gap-2 mb-4">
							<div class="rounded-lg p-3 text-center" style="background: oklch(0.16 0.005 155);">
								<div class="text-lg font-light text-white">$142,800</div>
								<div class="text-[9px] text-gray-600">Ventas totales</div>
								<div class="text-[9px] text-avoqado-green mt-1">+14% vs anterior</div>
							</div>
							<div class="rounded-lg p-3 text-center" style="background: oklch(0.16 0.005 155);">
								<div class="text-lg font-light text-white">312</div>
								<div class="text-[9px] text-gray-600">Transacciones</div>
								<div class="text-[9px]" style={`color: ${BLUE};`}>$457 prom.</div>
							</div>
							<div class="rounded-lg p-3 text-center" style="background: oklch(0.16 0.005 155);">
								<div class="text-lg font-light text-white">$12,450</div>
								<div class="text-[9px] text-gray-600">Propinas</div>
								<div class="text-[9px] text-avoqado-green">8.7% del total</div>
							</div>
						</div>
						<!-- Chart -->
						<div class="rounded-lg p-3 mb-3" style="background: oklch(0.14 0.005 155);">
							<div class="flex items-end gap-1 h-20">
								<div class="flex-1 flex flex-col items-center gap-0.5">
									<div class="w-full rounded-t" style={`height: 40%; background: ${BLUE}; opacity: 0.5;`}></div>
									<span class="text-[7px] text-gray-600">Lun</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-0.5">
									<div class="w-full rounded-t" style={`height: 55%; background: ${BLUE}; opacity: 0.6;`}></div>
									<span class="text-[7px] text-gray-600">Mar</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-0.5">
									<div class="w-full rounded-t" style={`height: 45%; background: ${BLUE}; opacity: 0.55;`}></div>
									<span class="text-[7px] text-gray-600">Mie</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-0.5">
									<div class="w-full rounded-t" style={`height: 65%; background: ${BLUE}; opacity: 0.7;`}></div>
									<span class="text-[7px] text-gray-600">Jue</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-0.5">
									<div class="w-full rounded-t" style={`height: 90%; background: ${BLUE}; opacity: 0.9;`}></div>
									<span class="text-[7px] text-gray-600">Vie</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-0.5">
									<div class="w-full rounded-t" style={`height: 95%; background: ${BLUE};`}></div>
									<span class="text-[7px] text-gray-600">Sab</span>
								</div>
								<div class="flex-1 flex flex-col items-center gap-0.5">
									<div class="w-full rounded-t" style={`height: 70%; background: ${BLUE}; opacity: 0.75;`}></div>
									<span class="text-[7px] text-gray-600">Dom</span>
								</div>
							</div>
						</div>
						<!-- Payment breakdown -->
						<div class="space-y-1.5">
							<div class="flex items-center justify-between p-2 rounded" style="background: oklch(0.15 0.005 155);">
								<div class="flex items-center gap-2">
									<div class="w-2 h-2 rounded-full" style={`background: ${BLUE};`}></div>
									<span class="text-[10px] text-gray-300">Tarjeta</span>
								</div>
								<span class="text-[10px] text-white">$98,400 (69%)</span>
							</div>
							<div class="flex items-center justify-between p-2 rounded" style="background: oklch(0.15 0.005 155);">
								<div class="flex items-center gap-2">
									<div class="w-2 h-2 rounded-full bg-avoqado-green"></div>
									<span class="text-[10px] text-gray-300">Efectivo</span>
								</div>
								<span class="text-[10px] text-white">$32,100 (22%)</span>
							</div>
							<div class="flex items-center justify-between p-2 rounded" style="background: oklch(0.15 0.005 155);">
								<div class="flex items-center gap-2">
									<div class="w-2 h-2 rounded-full" style={`background: ${AMBER};`}></div>
									<span class="text-[10px] text-gray-300">Transferencia</span>
								</div>
								<span class="text-[10px] text-white">$12,300 (9%)</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. LIGAS DE PAGO                            -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Payment link mockup -->
					<div class="order-2 lg:order-1 rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
						<div class="text-[11px] text-gray-500 mb-4">Liga de pago activa</div>
						<!-- Link card -->
						<div class="rounded-xl p-4 mb-4" style="background: oklch(0.16 0.005 155);">
							<div class="flex items-center justify-between mb-3">
								<span class="text-sm text-white font-medium">Cena privada — Mesa VIP</span>
								<span class="text-[9px] px-2 py-0.5 rounded-full bg-avoqado-green text-black font-medium">Activa</span>
							</div>
							<div class="flex items-center gap-2 mb-3 p-2 rounded-lg" style="background: oklch(0.13 0.005 155);">
								<span class="text-[10px] text-gray-400 truncate flex-1">avoqado.io/pay/xK3mN8p2</span>
								<span class="text-[9px] px-2 py-0.5 rounded" style={`background: oklch(0.18 0.02 240); color: ${BLUE};`}>Copiar</span>
							</div>
							<div class="grid grid-cols-2 gap-3">
								<div>
									<div class="text-[9px] text-gray-600 mb-1">Monto</div>
									<div class="text-sm text-white">$2,500.00</div>
								</div>
								<div>
									<div class="text-[9px] text-gray-600 mb-1">Propina</div>
									<div class="text-sm text-white">10%, 15%, 20%</div>
								</div>
								<div>
									<div class="text-[9px] text-gray-600 mb-1">Expira</div>
									<div class="text-sm text-white">24 mar, 23:59</div>
								</div>
								<div>
									<div class="text-[9px] text-gray-600 mb-1">Recolectado</div>
									<div class="text-sm text-avoqado-green">$7,500 / 3 pagos</div>
								</div>
							</div>
						</div>
						<!-- Share options -->
						<div class="flex gap-2">
							<div class="flex-1 h-9 rounded-lg flex items-center justify-center gap-1.5" style="background: oklch(0.16 0.005 155);">
								<div class="w-3.5 h-3.5 rounded-full bg-avoqado-green"></div>
								<span class="text-[10px] text-white">WhatsApp</span>
							</div>
							<div class="flex-1 h-9 rounded-lg flex items-center justify-center gap-1.5" style="background: oklch(0.16 0.005 155);">
								<div class="w-3.5 h-3.5 rounded-full" style={`background: ${BLUE};`}></div>
								<span class="text-[10px] text-white">Email</span>
							</div>
							<div class="flex-1 h-9 rounded-lg flex items-center justify-center gap-1.5" style="background: oklch(0.16 0.005 155);">
								<div class="w-3.5 h-3.5 rounded-full" style={`background: ${AMBER};`}></div>
								<span class="text-[10px] text-white">QR</span>
							</div>
						</div>
					</div>

					<div class="order-1 lg:order-2">
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${BLUE};`}>Cobra sin terminal</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
							Un link. Cualquier lugar.
						</h2>
						<p class="text-gray-400 text-lg leading-relaxed mb-8">
							Genera ligas de pago en segundos y comparte via WhatsApp, email o QR. Montos fijos o abiertos, reusables o de un solo uso, con propinas configurables y fecha de expiracion. Cada pago se sincroniza automaticamente con tu dashboard.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-400">Montos fijos, abiertos, o con producto vinculado (descuenta inventario)</span>
							</div>
