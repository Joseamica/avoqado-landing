---
import '../../styles/global.css';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import FloatingChatbot from '../../components/interactive/FloatingChatbot';
import WidgetTimeline from '../../components/interactive/WidgetTimeline';

const MAGENTA = 'oklch(0.72 0.15 340)';
const GREEN = '#69E185';
const BLUE = 'oklch(0.72 0.14 240)';
const AMBER = 'oklch(0.78 0.14 75)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado Widget | Avoqado</title>
		<meta name="description" content="Incrusta ordenes, pagos y reservaciones en cualquier sitio web con una linea de codigo." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">06</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style={`color: ${MAGENTA};`}>Avoqado Widget</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Tu negocio.<br/>En cualquier sitio web.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							Una linea de codigo. Tus clientes ordenan, pagan y reservan sin salir de tu pagina. Funciona en cualquier sitio — WordPress, Shopify, o tu sitio custom.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200" style={`background: ${MAGENTA};`}>
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Hablar con ventas
							</a>
						</div>
					</div>

					<!-- Hero mockups container -->
					<div class="relative" style="min-height: 420px;">

						<!-- Browser frame mockup — floating behind, desktop only -->
						<div class="hidden lg:block absolute -top-4 -right-6 w-[105%] z-0 rounded-2xl overflow-hidden border border-white/10" style="transform: perspective(1200px) rotateY(-6deg) rotateX(2deg); box-shadow: 0 25px 80px rgba(0,0,0,0.4); background: #FAF8F5;">
							<!-- Browser chrome -->
							<div class="flex items-center gap-2 px-4 py-2.5 border-b border-black/5" style="background: #F0EEEB;">
								<div class="flex items-center gap-1.5">
									<div class="w-2.5 h-2.5 rounded-full" style="background: #E0605E;"></div>
									<div class="w-2.5 h-2.5 rounded-full" style="background: #F2BF4E;"></div>
									<div class="w-2.5 h-2.5 rounded-full" style="background: #62C554;"></div>
								</div>
								<div class="flex-1 mx-3 h-6 rounded-md flex items-center px-3" style="background: #FFFFFF; border: 1px solid rgba(0,0,0,0.08);">
									<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" class="mr-2 shrink-0"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
									<span class="text-[10px]" style="color: #666;">misushi.com.mx</span>
								</div>
							</div>

							<!-- Wireframe page content -->
							<div class="p-5 flex gap-5" style="min-height: 380px;">
								<!-- Left: wireframe site content -->
								<div class="flex-1 space-y-4">
									<!-- Nav wireframe -->
									<div class="flex items-center justify-between">
										<div class="h-4 w-20 rounded" style="background: #E8E5E0;"></div>
										<div class="flex gap-3">
											<div class="h-3 w-12 rounded" style="background: #E8E5E0;"></div>
											<div class="h-3 w-12 rounded" style="background: #E8E5E0;"></div>
											<div class="h-3 w-12 rounded" style="background: #E8E5E0;"></div>
										</div>
									</div>
									<!-- Hero placeholder -->
									<div class="w-full h-28 rounded-xl flex items-center justify-center" style="background: #EDE9E4;">
										<div class="text-center">
											<div class="h-3 w-32 rounded mx-auto mb-2" style="background: #D8D4CF;"></div>
											<div class="h-2 w-24 rounded mx-auto" style="background: #D8D4CF;"></div>
										</div>
									</div>
									<!-- Text lines -->
									<div class="space-y-2">
										<div class="h-2 w-full rounded" style="background: #E8E5E0;"></div>
										<div class="h-2 w-5/6 rounded" style="background: #E8E5E0;"></div>
										<div class="h-2 w-4/6 rounded" style="background: #E8E5E0;"></div>
									</div>
									<!-- Content blocks -->
									<div class="grid grid-cols-3 gap-2">
										<div class="h-16 rounded-lg" style="background: #EDE9E4;"></div>
										<div class="h-16 rounded-lg" style="background: #EDE9E4;"></div>
										<div class="h-16 rounded-lg" style="background: #EDE9E4;"></div>
									</div>
									<!-- More text lines -->
									<div class="space-y-2">
										<div class="h-2 w-full rounded" style="background: #E8E5E0;"></div>
										<div class="h-2 w-3/4 rounded" style="background: #E8E5E0;"></div>
									</div>
								</div>

								<!-- Right: Avoqado widget panel embedded -->
								<div class="w-52 shrink-0 rounded-xl overflow-hidden border" style="background: oklch(0.12 0.005 155); border-color: oklch(0.20 0.005 155);">
									<!-- Widget header -->
									<div class="flex items-center justify-between px-3 py-2.5" style="border-bottom: 1px solid oklch(0.18 0.005 155);">
										<div class="flex items-center gap-2">
											<div class="w-5 h-5 rounded-full flex items-center justify-center" style={`background: ${MAGENTA};`}>
												<span class="text-[7px] font-bold text-white">M</span>
											</div>
											<span class="text-[10px] text-white font-medium">Ordenar</span>
										</div>
										<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="oklch(0.40 0.005 155)" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
									</div>
									<!-- Product items -->
									<div class="p-2.5 space-y-2">
										<!-- Dragon Roll -->
										<div class="flex items-center justify-between p-2 rounded-lg" style="background: oklch(0.16 0.005 155);">
											<div class="flex items-center gap-2">
												<div class="w-8 h-8 rounded-md" style="background: oklch(0.20 0.005 155);"></div>
												<div>
													<span class="text-[9px] text-white block leading-tight">Dragon Roll</span>
													<span class="text-[8px] text-gray-600">8 piezas</span>
												</div>
											</div>
											<div class="text-right">
												<span class="text-[9px] text-white">$195</span>
												<div class="w-4 h-4 rounded-full flex items-center justify-center mt-0.5 ml-auto" style={`background: ${MAGENTA};`}>
													<span class="text-[7px] font-bold text-white">1</span>
												</div>
											</div>
										</div>
										<!-- Edamame -->
										<div class="flex items-center justify-between p-2 rounded-lg" style="background: oklch(0.16 0.005 155);">
											<div class="flex items-center gap-2">
												<div class="w-8 h-8 rounded-md" style="background: oklch(0.20 0.005 155);"></div>
												<div>
													<span class="text-[9px] text-white block leading-tight">Edamame</span>
													<span class="text-[8px] text-gray-600">Con sal de mar</span>
												</div>
											</div>
											<div class="text-right">
												<span class="text-[9px] text-white">$85</span>
												<div class="w-4 h-4 rounded-full flex items-center justify-center mt-0.5 ml-auto" style={`background: ${MAGENTA};`}>
													<span class="text-[7px] font-bold text-white">1</span>
												</div>
											</div>
										</div>
										<!-- Sopa Miso -->
										<div class="flex items-center justify-between p-2 rounded-lg" style="background: oklch(0.16 0.005 155);">
											<div class="flex items-center gap-2">
												<div class="w-8 h-8 rounded-md" style="background: oklch(0.20 0.005 155);"></div>
												<div>
													<span class="text-[9px] text-white block leading-tight">Sopa Miso</span>
													<span class="text-[8px] text-gray-600">Tofu y wakame</span>
												</div>
											</div>
											<span class="text-[9px] text-gray-500">$95</span>
										</div>
									</div>
									<!-- Cart bar -->
									<div class="mx-2.5 mb-2.5 h-8 rounded-lg flex items-center justify-between px-3" style="background: #69E185;">
										<span class="text-[9px] font-semibold text-black">2 items</span>
										<span class="text-[10px] font-bold text-black">Pagar $375</span>
									</div>
								</div>
							</div>
						</div>

						<!-- Code snippet mockup — foreground -->
						<div class="relative z-10 lg:mt-16 rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
							<!-- Title bar -->
							<div class="flex items-center gap-2 mb-4">
								<div class="w-3 h-3 rounded-full" style="background: oklch(0.30 0.005 155);"></div>
								<div class="w-3 h-3 rounded-full" style="background: oklch(0.30 0.005 155);"></div>
								<div class="w-3 h-3 rounded-full" style="background: oklch(0.30 0.005 155);"></div>
								<span class="text-[10px] text-gray-600 ml-2">index.html</span>
							</div>
							<!-- Code block -->
							<div class="rounded-lg p-4 font-mono text-sm leading-relaxed" style="background: oklch(0.10 0.005 155);">
								<div class="text-gray-600 mb-2">&lt;!-- Agrega antes de &lt;/body&gt; --&gt;</div>
								<div>
									<span class="text-gray-500">&lt;</span><span style={`color: ${MAGENTA};`}>script</span>
								</div>
								<div class="pl-4">
									<span style={`color: ${AMBER};`}>src</span><span class="text-gray-500">=</span><span class="text-avoqado-green">"https://widget.avoqado.io/v1.js"</span>
								</div>
								<div class="pl-4">
									<span style={`color: ${AMBER};`}>data-venue</span><span class="text-gray-500">=</span><span class="text-avoqado-green">"tu-negocio"</span>
								</div>
								<div class="pl-4">
									<span style={`color: ${AMBER};`}>data-theme</span><span class="text-gray-500">=</span><span class="text-avoqado-green">"dark"</span>
								</div>
								<div>
									<span class="text-gray-500">&gt;&lt;/</span><span style={`color: ${MAGENTA};`}>script</span><span class="text-gray-500">&gt;</span>
								</div>
							</div>
							<!-- Floating widget preview below code -->
							<div class="mt-4 flex items-center justify-between p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-center gap-2">
									<div class="w-2 h-2 rounded-full bg-avoqado-green animate-pulse"></div>
									<span class="text-[10px] text-gray-400">Widget activo en tu-negocio.com</span>
								</div>
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 340); color: ${MAGENTA};`}>v1.0</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- 1. FACIL DE INTEGRAR — Scrollytelling Timeline -->
		<WidgetTimeline client:visible />


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. ORDENES ONLINE — WHITE BG                -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Widget menu mockup -->
					<div class="order-2 lg:order-1 rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
						<div class="flex items-center justify-between mb-4">
							<div class="flex items-center gap-2">
								<div class="w-6 h-6 rounded-full flex items-center justify-center" style={`background: ${MAGENTA};`}>
									<span class="text-[8px] font-bold text-white">A</span>
								</div>
								<span class="text-[11px] text-white font-medium">La Terraza Rooftop</span>
							</div>
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="oklch(0.40 0.005 155)" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
						</div>
						<!-- Categories -->
						<div class="flex gap-1.5 mb-4">
							<div class="px-3 py-1 rounded-full text-[9px] text-white" style={`background: ${MAGENTA};`}>Todo</div>
							<div class="px-3 py-1 rounded-full text-[9px] text-gray-500" style="background: oklch(0.16 0.005 155);">Entradas</div>
							<div class="px-3 py-1 rounded-full text-[9px] text-gray-500" style="background: oklch(0.16 0.005 155);">Platos</div>
							<div class="px-3 py-1 rounded-full text-[9px] text-gray-500" style="background: oklch(0.16 0.005 155);">Bebidas</div>
						</div>
						<!-- Products -->
						<div class="space-y-2 mb-4">
							<div class="flex items-center justify-between p-3 rounded-lg" style={`background: oklch(0.16 0.005 155); border: 1px solid oklch(0.25 0.02 340);`}>
								<div class="flex items-center gap-3">
									<div class="w-10 h-10 rounded-lg" style="background: oklch(0.20 0.005 155);"></div>
									<div>
										<span class="text-xs text-white">Tacos al Pastor x3</span>
										<span class="text-[9px] text-gray-600 block">Con cilantro y cebolla</span>
									</div>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-xs text-white">$165</span>
									<div class="w-5 h-5 rounded-full flex items-center justify-center" style={`background: ${MAGENTA};`}>
										<span class="text-[8px] font-bold text-white">2</span>
									</div>
								</div>
							</div>
							<div class="flex items-center justify-between p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-center gap-3">
									<div class="w-10 h-10 rounded-lg" style="background: oklch(0.20 0.005 155);"></div>
									<div>
										<span class="text-xs text-white">Guacamole Clasico</span>
										<span class="text-[9px] text-gray-600 block">Con totopos artesanales</span>
									</div>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-xs text-gray-400">$120</span>
									<div class="w-5 h-5 rounded-full flex items-center justify-center" style="background: oklch(0.22 0.005 155);">
										<span class="text-[10px] text-gray-500">+</span>
									</div>
								</div>
							</div>
							<div class="flex items-center justify-between p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-center gap-3">
									<div class="w-10 h-10 rounded-lg" style="background: oklch(0.20 0.005 155);"></div>
									<div>
										<span class="text-xs text-white">Michelada Clasica</span>
										<span class="text-[9px] text-gray-600 block">Con cerveza artesanal</span>
									</div>
								</div>
								<div class="flex items-center gap-2">
									<span class="text-xs text-gray-400">$95</span>
									<div class="w-5 h-5 rounded-full flex items-center justify-center" style="background: oklch(0.22 0.005 155);">
										<span class="text-[10px] text-gray-500">+</span>
									</div>
								</div>
							</div>
						</div>
						<!-- Cart bar -->
						<div class="h-10 rounded-xl flex items-center justify-between px-4" style={`background: ${MAGENTA};`}>
							<span class="text-[11px] font-semibold text-white">2 items — $330</span>
							<span class="text-sm font-semibold text-white">Pagar</span>
						</div>
					</div>

					<div class="order-1 lg:order-2">
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${MAGENTA};`}>Ordenes</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Menu completo dentro de tu pagina.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Tus clientes navegan tu catalogo completo, agregan al carrito y pagan sin salir de tu sitio web. Categorias, modificadores, fotos — todo sincronizado con tu dashboard.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${MAGENTA};`}></div>
								<span class="text-sm text-gray-600">Catalogo completo con categorias, fotos y modificadores</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-600">Carrito persistente con cantidades y notas por producto</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${BLUE};`}></div>
								<span class="text-sm text-gray-600">Sync en tiempo real — cambios en el menu se reflejan al instante</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 3. PAGOS INTEGRADOS                         -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="text-center max-w-2xl mx-auto mb-12">
					<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${MAGENTA};`}>Pagos</span>
					<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
						Cobra directo desde tu sitio.
					</h2>
					<p class="text-gray-400 text-lg leading-relaxed">
						Tus clientes pagan sin redirecciones ni pop-ups externos. Cuatro metodos de pago integrados en el widget, con el mismo nivel de seguridad de tu terminal fisica.
					</p>
				</div>

				<!-- Checkout mockup — full width centered -->
				<div class="max-w-2xl mx-auto rounded-2xl overflow-hidden border border-white/5 p-5 mb-12" style="background: oklch(0.12 0.005 155);">
					<!-- Order summary -->
					<div class="flex items-center justify-between mb-4 p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
						<div>
							<span class="text-[10px] text-gray-500">Total a pagar</span>
							<div class="text-lg text-white font-light">$1,247.00</div>
						</div>
						<div class="text-right">
							<span class="text-[10px] text-gray-500">5 productos</span>
							<div class="text-[10px] text-avoqado-green">Propina incluida</div>
						</div>
					</div>
					<!-- Payment methods -->
					<div class="text-[10px] text-gray-500 mb-3">Selecciona metodo de pago</div>
					<div class="grid grid-cols-2 gap-2 mb-4">
						<div class="p-3 rounded-xl text-center" style={`background: oklch(0.16 0.005 155); border: 1px solid oklch(0.30 0.02 340);`}>
							<div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-center" style={`background: oklch(0.18 0.02 340); color: ${MAGENTA};`}>
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
							</div>
							<span class="text-xs text-white">Tarjeta</span>
							<span class="text-[8px] text-gray-600 block">Credito / Debito</span>
						</div>
						<div class="p-3 rounded-xl text-center" style="background: oklch(0.16 0.005 155);">
							<div class="w-8 h-8 rounded-lg mx-auto mb-2 flex items-center justify-center" style="background: oklch(0.18 0.005 155); color: oklch(0.50 0.005 155);">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/><rect x="7" y="7" width="3" height="3"/><rect x="14" y="7" width="3" height="3"/><rect x="7" y="14" width="3" height="3"/></svg>
							</div>
							<span class="text-xs text-white">QR Code</span>
							<span class="text-[8px] text-gray-600 block">Escanear y pagar</span>
						</div>
						<div class="p-3 rounded-xl text-center" style="background: oklch(0.16 0.005 155);">
