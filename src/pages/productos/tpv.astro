---
import '../../styles/global.css';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import FloatingChatbot from '../../components/interactive/FloatingChatbot';
import TpvFrame from '../../components/ui/TpvFrame.astro';
import AvoqadoTour from '../../components/interactive/tour/AvoqadoTour';

// Paleta: tokens compartidos de src/styles/global.css (--color-product-*,
// --color-alert-*, --color-mockup-*, --color-neutral-*). Los unicos colores
// inline que quedan son decorativos de contenido (grid de categorias e
// iniciales de producto del kiosko).
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado TPV | Terminal de Cobro Inteligente</title>
		<meta name="description" content="Terminal de cobro handheld con 5 procesadores de pago, operacion offline, gestion remota, multi-merchant y modo kiosko. PAX y Nexgo." />
		<link rel="icon" type="image/png" href="/favicon.png?v=3" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />
		<main>


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">02</span>
							<span class="text-xs uppercase tracking-widest font-semibold text-avoqado-green">Terminal de cobro</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Cobra en cualquier lugar.<br/>
							Con o sin internet.
						</h1>
						<p class="text-lg md:text-xl text-neutral-400 max-w-xl leading-relaxed mb-10">
							Terminal handheld para tu staff con 5 procesadores de pago, impresora integrada, operacion offline y sincronizacion automatica. Gestiona remotamente desde el dashboard.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-avoqado-green text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200">
								Solicitar terminal
							</a>
							<a href="https://avoqado.io/demo" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Ver demo
							</a>
						</div>
					</div>
					<!-- Mobile: terminal principal (la composicion 3D es solo desktop) -->
					<div class="lg:hidden relative flex justify-center pt-2 pb-6">
						<div class="absolute bottom-6 left-1/2 -translate-x-1/2 w-56 h-12 rounded-full blur-3xl" style="background: var(--color-avoqado-green); opacity: 0.15;"></div>
						<img src="/pax-avoqado.png" alt="Terminal PAX A910S con Avoqado"
							class="max-h-[340px] w-auto relative"
							style="filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));"
							loading="eager" />
					</div>
					<!-- Terminals composition — floating with 3 devices -->
					<div class="hidden lg:flex justify-center items-center relative" style="min-height: 520px; perspective: 1400px;" data-terminals-root>
						<!-- Green glow underneath (ambient — stays put) -->
						<div class="absolute bottom-8 left-1/2 -translate-x-1/2 w-72 h-16 rounded-full blur-3xl animate-terminal-glow" style="background: var(--color-avoqado-green); opacity: 0.15;"></div>

						<!-- 3D stage — the group subtly turns to face the cursor -->
						<div class="absolute inset-0 flex justify-center items-center" style="transform-style: preserve-3d; will-change: transform;" data-terminals-stage>
							<!-- PAX A910S — main, center-left, largest -->
							<img src="/pax-avoqado.png" alt="Terminal PAX A910S con Avoqado"
								class="max-h-[480px] w-auto animate-terminal-float relative z-20"
								style="filter: drop-shadow(0 25px 50px rgba(0,0,0,0.6)); transform-origin: center bottom; will-change: transform;"
								data-depth="14"
								loading="eager" />

							<!-- Nexgo compact — right, smaller, offset down -->
							<img src="/nexgo-avoqado.png" alt="Terminal Nexgo con Avoqado"
								class="max-h-[220px] w-auto absolute right-0 bottom-16 z-10 animate-terminal-float"
								style="filter: drop-shadow(0 15px 30px rgba(0,0,0,0.4)); animation-delay: -1.8s; will-change: transform;"
								data-depth="24"
								loading="eager" />

							<!-- Nexgo N86 — left-back, angled, behind PAX -->
							<img src="/nexgo86-avoqado.png" alt="Terminal Nexgo N86 con Avoqado"
								class="max-h-[260px] w-auto absolute -left-8 bottom-4 z-0 animate-terminal-float"
								style="filter: drop-shadow(0 15px 30px rgba(0,0,0,0.4)); animation-delay: -3.2s; opacity: 0.85; will-change: transform;"
								data-depth="9"
								loading="eager" />
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 0. ORDENA Y COBRA (Square handheld)         -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 border-t border-white/5" style="background: radial-gradient(900px 620px at 28% 32%, rgba(122,221,44,0.07), transparent 62%), #000;">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block text-avoqado-green">Punto de venta</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
							Ordena productos.<br/>Cobra servicios.
						</h2>
						<p class="text-neutral-400 text-lg leading-relaxed mb-8">
							Toda tu operacion en la palma de la mano — como un handheld de Square, pero tuyo. Arma la venta, agrega productos o servicios, aplica descuentos y cobra en la misma pantalla. Sin caja, sin cables, sin computadora.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-neutral-400">Catalogo de productos y servicios con categorias, modificadores y descuentos</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-neutral-400">Arma la orden y cobra en un solo dispositivo — tarjeta, efectivo o transferencia</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-neutral-400">Cada venta actualiza inventario, reportes y comisiones en tiempo real</span>
							</div>
						</div>
					</div>

					<!-- POS ordering screen inside a real terminal -->
					<div class="flex justify-center lg:justify-end">
						<TpvFrame w="380px">
							<div class="flex flex-col h-full">
								<!-- navbar -->
								<div class="flex items-center gap-2.5 mb-3">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
									<span class="text-[16px] font-semibold text-white">Cobrar</span>
								</div>
								<!-- search + acciones -->
								<div class="flex items-center gap-2 mb-3">
									<div class="flex-1 flex items-center gap-2 rounded-xl px-3 h-9" style="background: var(--color-mockup-elevated);">
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--color-mockup-ink-muted);" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
										<span class="text-[12px] text-neutral-500">Buscar</span>
									</div>
									<div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0" style="background: var(--color-mockup-elevated);">
										<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--color-mockup-ink-muted);" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 4v5h-5"/></svg>
									</div>
									<div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0" style="background: var(--color-mockup-elevated);">
										<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--color-mockup-ink-muted);" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3M20 14v3M17 17v4M20 20h1"/></svg>
									</div>
								</div>
								<!-- tabs -->
								<div class="flex items-center gap-4 mb-3 border-b border-white/10">
									<span class="text-[11.5px] text-neutral-500 pb-2">Shortcuts</span>
									<span class="text-[11.5px] text-white font-medium pb-2 border-b-2 border-avoqado-green -mb-px">Todos los productos</span>
									<span class="text-[11.5px] text-neutral-500 pb-2">Configurar</span>
								</div>
								<!-- category grid — distintos giros de negocio -->
								<div class="grid grid-cols-3 gap-2 flex-1 content-start">
									<div class="aspect-square rounded-xl p-2 flex flex-col justify-between" style="background: oklch(0.62 0.13 200);"><svg width="15" height="15" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="3" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/></svg><span class="text-[10px] font-semibold text-white leading-tight">Cortes</span></div>
									<div class="aspect-square rounded-xl p-2 flex flex-col justify-between" style="background: oklch(0.64 0.17 150);"><svg width="15" height="15" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="3" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/></svg><span class="text-[10px] font-semibold text-white leading-tight">Membresias</span></div>
									<div class="aspect-square rounded-xl p-2 flex flex-col justify-between" style="background: oklch(0.66 0.17 45);"><svg width="15" height="15" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="3" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/></svg><span class="text-[10px] font-semibold text-white leading-tight">Ropa</span></div>
									<div class="aspect-square rounded-xl p-2 flex flex-col justify-between" style="background: oklch(0.55 0.16 265);"><svg width="15" height="15" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="3" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/></svg><span class="text-[10px] font-semibold text-white leading-tight">Cafeteria</span></div>
									<div class="aspect-square rounded-xl p-2 flex flex-col justify-between" style="background: oklch(0.62 0.17 350);"><svg width="15" height="15" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="3" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/></svg><span class="text-[10px] font-semibold text-white leading-tight">Unas y spa</span></div>
									<div class="aspect-square rounded-xl p-2 flex flex-col justify-between" style="background: oklch(0.55 0.17 300);"><svg width="15" height="15" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="3" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/></svg><span class="text-[10px] font-semibold text-white leading-tight">Clases</span></div>
									<div class="aspect-square rounded-xl p-2 flex flex-col justify-between" style="background: oklch(0.68 0.17 128);"><svg width="15" height="15" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="3" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/></svg><span class="text-[10px] font-semibold text-white leading-tight">Suplementos</span></div>
									<div class="aspect-square rounded-xl p-2 flex flex-col justify-between" style="background: oklch(0.63 0.13 210);"><svg width="15" height="15" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="3" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/></svg><span class="text-[10px] font-semibold text-white leading-tight">Farmacia</span></div>
									<div class="aspect-square rounded-xl p-2 flex flex-col justify-between" style="background: oklch(0.60 0.19 25);"><svg width="15" height="15" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="3" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="3" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/><rect x="13" y="13" width="8" height="8" rx="2" fill="rgba(255,255,255,0.92)"/></svg><span class="text-[10px] font-semibold text-white leading-tight">Boletos</span></div>
								</div>
								<!-- resumen del carrito -->
								<div class="mt-3 rounded-xl px-3 py-2.5" style="background: var(--color-mockup-elevated);">
									<div class="flex items-center justify-between mb-2">
										<div class="flex items-center gap-1.5">
											<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--color-avoqado-green);" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
											<span class="text-[12px] font-medium text-white">Carrito · 3 productos</span>
										</div>
										<span class="text-[13px] font-semibold text-white">$320.00</span>
									</div>
									<div class="flex flex-wrap gap-1">
										<span class="text-[9px] px-2 py-0.5 rounded-full text-neutral-300 border border-white/10">Corte de cabello</span>
										<span class="text-[9px] px-2 py-0.5 rounded-full text-neutral-300 border border-white/10">Barba</span>
										<span class="text-[9px] px-2 py-0.5 rounded-full text-neutral-300 border border-white/10">Cafe americano</span>
									</div>
								</div>
								<!-- cobrar -->
								<div class="mt-2 rounded-2xl h-12 flex items-center justify-center gap-2 bg-avoqado-green">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
									<span class="text-[15px] font-semibold text-black">Cobrar $320.00</span>
								</div>
							</div>
						</TpvFrame>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. ENRUTAMIENTO DE PAGOS                     -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style="color: var(--color-product-tpv-deep);">Pagos</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Tu decides a donde va cada peso.
						</h2>
						<p class="text-neutral-600 text-lg leading-relaxed mb-8">
							Configura a que cuenta bancaria se deposita cada transaccion. Enruta pagos a diferentes CLABEs por sucursal, por concepto o por regla de negocio. Acepta tarjeta (NFC, chip, banda), efectivo, transferencia, wallet y criptomonedas.
						</p>
						<div class="space-y-4">
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Enrutamiento inteligente</h3>
								<p class="text-sm text-neutral-500">Asigna cuentas CLABE diferentes por sucursal o concepto. El dinero llega directo a donde debe.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Todos los metodos de pago</h3>
								<p class="text-sm text-neutral-500">Tarjeta contactless (NFC), chip, banda magnetica, efectivo, transferencia bancaria, wallet digital.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Criptomonedas</h3>
								<p class="text-sm text-neutral-500">Acepta BTC, ETH y USDT via B4Bit con verificacion criptografica.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Reconciliacion automatica</h3>
								<p class="text-sm text-neutral-500">Cada pago se reconcilia en 4 capas: terminal, procesador, backend y webhook. Zero discrepancias.</p>
							</div>
						</div>
					</div>

					<!-- Payment methods mockup — inside a physical terminal -->
					<div class="flex justify-center lg:justify-end">
						<TpvFrame w="380px">
							<div class="flex flex-col h-full">
								<div class="flex items-center gap-2.5 mb-4">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
									<span class="text-[16px] font-semibold text-white">Enrutamiento</span>
								</div>
								<div class="rounded-2xl p-3.5" style="background: var(--color-mockup-elevated);">
									<div class="text-[11px] text-neutral-500 mb-2">Pago recibido</div>
									<div class="flex items-center justify-between">
										<div class="flex items-center gap-2"><div class="w-2.5 h-2.5 rounded-full bg-avoqado-green"></div><span class="text-[14px] text-white">Tarjeta Visa *4821</span></div>
										<span class="text-[17px] font-semibold" style="color: var(--color-avoqado-green);">$1,247.00</span>
									</div>
								</div>
								<div class="flex justify-center py-1.5">
									<div class="w-7 h-7 rounded-full flex items-center justify-center" style="background: var(--color-mockup-elevated);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--color-mockup-ink-muted);" stroke-width="2" stroke-linecap="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg></div>
								</div>
								<div class="flex-1 flex flex-col gap-2.5">
									<div class="flex-1 rounded-2xl p-3.5 flex items-center justify-between border" style="background: var(--color-product-tpv-tint); border-color: var(--color-avoqado-green);">
										<div><div class="text-[14px] text-white leading-tight">Cuenta principal</div><div class="text-[11px] text-neutral-400 mt-1">CLABE **** 7832 · BBVA</div></div>
