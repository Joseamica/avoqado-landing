---
import '../../styles/global.css';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import FloatingChatbot from '../../components/interactive/FloatingChatbot';
import TpvFrame from '../../components/ui/TpvFrame.astro';
import AvoqadoTour from '../../components/interactive/tour/AvoqadoTour';

const GREEN = '#7ADD2C';
const BLUE = 'oklch(0.72 0.14 240)';
const AMBER = 'oklch(0.78 0.14 75)';
const RED = 'oklch(0.65 0.20 25)';
const INDIGO = 'oklch(0.68 0.15 290)';

// ─── Light "page" mockup palette ───────────────────────────────
// Mockups render as clean light windows: #f1f1f1 frame + dark border,
// white inner cards, dark text. Accents are darkened so they stay
// legible on light surfaces.
const SURFACE = '#f1f1f1';                     // outer frame ("the page")
const CARD = '#ffffff';                        // inner cards / chips
const NEUTRAL_TINT = 'oklch(0.93 0.004 155)';  // image/placeholder blocks
const TRACK = 'oklch(0.90 0.004 155)';         // progress track
const HAIRLINE = 'oklch(0.60 0.004 155)';      // svg icon stroke on light
const GREEN_INK = 'oklch(0.58 0.16 150)';      // green text/amounts on light
const GREEN_TINT = 'oklch(0.96 0.04 152)';     // active green card fill
const GREEN_LINE = 'oklch(0.84 0.11 152)';     // soft green border on light
const AMBER_INK = 'oklch(0.60 0.15 68)';       // amber text on light
const AMBER_TINT = 'oklch(0.95 0.05 78)';      // amber card fill
const BLUE_INK = 'oklch(0.55 0.15 250)';       // blue text on light
const BLUE_TINT = 'oklch(0.95 0.04 245)';      // blue avatar fill
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado TPV | Terminal de Cobro Inteligente</title>
		<meta name="description" content="Terminal de cobro handheld con 5 procesadores de pago, operacion offline, gestion remota, multi-merchant y modo kiosko. PAX, Ingenico y Verifone." />
		<link rel="icon" type="image/png" href="/favicon.png?v=3" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">02</span>
							<span class="text-xs uppercase tracking-widest font-semibold text-avoqado-green">Terminal de cobro</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Cobra en cualquier lugar.<br/>
							Con o sin internet.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							Terminal handheld para tu staff con 5 procesadores de pago, impresora integrada, operacion offline y sincronizacion automatica. Gestiona remotamente desde el dashboard.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-avoqado-green text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200">
								Solicitar terminal
							</a>
							<a href="https://avoqado.io/demo" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Ver demo del dashboard
							</a>
						</div>
					</div>
					<!-- Terminals composition — floating with 3 devices -->
					<div class="hidden lg:flex justify-center items-center relative" style="min-height: 520px; perspective: 1400px;" data-terminals-root>
						<!-- Green glow underneath (ambient — stays put) -->
						<div class="absolute bottom-8 left-1/2 -translate-x-1/2 w-72 h-16 rounded-full blur-3xl animate-terminal-glow" style="background: #7ADD2C; opacity: 0.15;"></div>

						<!-- 3D stage — the group subtly turns to face the cursor -->
						<div class="absolute inset-0 flex justify-center items-center" style="transform-style: preserve-3d; will-change: transform;" data-terminals-stage>
							<!-- PAX A910S — main, center-left, largest -->
							<img src="/pax-avoqado.png" alt="Terminal PAX A910S con Avoqado"
								class="max-h-[480px] w-auto animate-terminal-float relative z-20"
								style="filter: drop-shadow(0 25px 50px rgba(0,0,0,0.6)); transform-origin: center bottom; will-change: transform;"
								data-depth="14"
								loading="eager" />

							<!-- Nexgo compact — right, smaller, offset down -->
							<img src="/nexgo-avoqado.png" alt="Terminal Nexgo con Avoqado"
								class="max-h-[220px] w-auto absolute right-0 bottom-16 z-10 animate-terminal-float"
								style="filter: drop-shadow(0 15px 30px rgba(0,0,0,0.4)); animation-delay: -1.8s; will-change: transform;"
								data-depth="24"
								loading="eager" />

							<!-- Nexgo N86 — left-back, angled, behind PAX -->
							<img src="/nexgo86-avoqado.png" alt="Terminal Nexgo N86 con Avoqado"
								class="max-h-[260px] w-auto absolute -left-8 bottom-4 z-0 animate-terminal-float"
								style="filter: drop-shadow(0 15px 30px rgba(0,0,0,0.4)); animation-delay: -3.2s; opacity: 0.85; will-change: transform;"
								data-depth="9"
								loading="eager" />
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 0. ORDENA Y COBRA (Square handheld)         -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 border-t border-white/5" style="background: radial-gradient(900px 620px at 28% 32%, rgba(122,221,44,0.07), transparent 62%), #000;">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block text-avoqado-green">Punto de venta</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
							Ordena productos.<br/>Cobra servicios.
						</h2>
						<p class="text-gray-400 text-lg leading-relaxed mb-8">
							Toda tu operacion en la palma de la mano — como un handheld de Square, pero tuyo. Arma la venta, agrega productos o servicios, aplica descuentos y cobra en la misma pantalla. Sin caja, sin cables, sin computadora.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-400">Catalogo de productos y servicios con categorias, modificadores y descuentos</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-400">Arma la orden y cobra en un solo dispositivo — tarjeta, efectivo o transferencia</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-400">Cada venta actualiza inventario, reportes y comisiones en tiempo real</span>
							</div>
						</div>
					</div>

					<!-- POS ordering screen inside a real terminal -->
					<div class="flex justify-center lg:justify-end">
						<TpvFrame maxw="540px" time="13:04">
							<div class="flex flex-col h-full">
								<!-- header -->
								<div class="flex items-center justify-between mb-1.5">
									<div>
										<div class="text-[9px] font-semibold text-gray-900 leading-none">Nueva venta</div>
										<div class="text-[6px] text-gray-400 mt-0.5">Studio Mave · Caja 1</div>
									</div>
									<div class="w-4 h-4 rounded-full flex items-center justify-center border border-black/5" style={`background: ${CARD};`}>
										<svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke={HAIRLINE} stroke-width="2.4" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
									</div>
								</div>
								<!-- category chips -->
								<div class="flex gap-1 mb-1.5">
									<span class="text-[6px] px-1.5 py-0.5 rounded-full text-black font-semibold" style={`background: ${GREEN};`}>Todo</span>
									<span class="text-[6px] px-1.5 py-0.5 rounded-full text-gray-500 border border-black/5" style={`background: ${CARD};`}>Servicios</span>
									<span class="text-[6px] px-1.5 py-0.5 rounded-full text-gray-500 border border-black/5" style={`background: ${CARD};`}>Productos</span>
								</div>
								<!-- catalog grid -->
								<div class="grid grid-cols-2 gap-1 flex-1 content-start">
									<!-- in cart -->
									<div class="rounded-md p-1.5 border" style={`background: ${GREEN_TINT}; border-color: ${GREEN};`}>
										<div class="flex items-center justify-between mb-1">
											<div class="w-4 h-4 rounded flex items-center justify-center text-[6px] font-bold" style={`background: oklch(0.92 0.06 152); color: ${GREEN_INK};`}>CC</div>
											<div class="w-3 h-3 rounded-full bg-avoqado-green flex items-center justify-center"><span class="text-[5px] font-bold text-black">1</span></div>
										</div>
										<div class="text-[7px] text-gray-900 leading-tight">Corte de cabello</div>
										<div class="flex items-center justify-between mt-0.5">
											<span class="text-[6px] font-semibold" style={`color: ${GREEN_INK};`}>$180</span>
											<span class="text-[5px] text-gray-400 uppercase tracking-wide">Serv</span>
										</div>
									</div>
									<div class="rounded-md p-1.5 border border-black/5" style={`background: ${CARD};`}>
										<div class="w-4 h-4 rounded flex items-center justify-center text-[6px] font-bold mb-1" style={`background: ${BLUE_TINT}; color: ${BLUE_INK};`}>BA</div>
										<div class="text-[7px] text-gray-900 leading-tight">Barba y perfilado</div>
										<div class="flex items-center justify-between mt-0.5">
											<span class="text-[6px] font-semibold text-gray-900">$120</span>
											<span class="text-[5px] text-gray-400 uppercase tracking-wide">Serv</span>
										</div>
									</div>
									<div class="rounded-md p-1.5 border border-black/5" style={`background: ${CARD};`}>
										<div class="w-4 h-4 rounded flex items-center justify-center text-[6px] font-bold mb-1" style={`background: ${AMBER_TINT}; color: ${AMBER_INK};`}>PM</div>
										<div class="text-[7px] text-gray-900 leading-tight">Pomada mate</div>
										<div class="flex items-center justify-between mt-0.5">
											<span class="text-[6px] font-semibold text-gray-900">$190</span>
											<span class="text-[5px] text-gray-400 uppercase tracking-wide">Prod</span>
										</div>
									</div>
									<div class="rounded-md p-1.5 border border-black/5" style={`background: ${CARD};`}>
										<div class="w-4 h-4 rounded flex items-center justify-center text-[6px] font-bold mb-1" style="background: oklch(0.93 0.05 300); color: oklch(0.52 0.16 300);">SH</div>
										<div class="text-[7px] text-gray-900 leading-tight">Shampoo Pro</div>
										<div class="flex items-center justify-between mt-0.5">
											<span class="text-[6px] font-semibold text-gray-900">$260</span>
											<span class="text-[5px] text-gray-400 uppercase tracking-wide">Prod</span>
										</div>
									</div>
								</div>
								<!-- cobrar bar -->
								<div class="mt-1.5 rounded-md p-1.5 flex items-center justify-between" style={`background: ${CARD}; border: 1px solid ${GREEN};`}>
									<div class="leading-tight">
										<div class="text-[6px] text-gray-400">2 articulos</div>
										<div class="text-[9px] font-semibold text-gray-900">$440.00</div>
									</div>
									<div class="h-5 px-2 rounded-md flex items-center gap-1 bg-avoqado-green">
										<span class="text-[8px] font-semibold text-black">Cobrar</span>
										<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
									</div>
								</div>
							</div>
						</TpvFrame>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. ENRUTAMIENTO DE PAGOS                     -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block text-avoqado-green">Pagos</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Tu decides a donde va cada peso.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Configura a que cuenta bancaria se deposita cada transaccion. Enruta pagos a diferentes CLABEs por sucursal, por concepto o por regla de negocio. Acepta tarjeta (NFC, chip, banda), efectivo, transferencia, wallet y criptomonedas.
						</p>
						<div class="space-y-4">
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Enrutamiento inteligente</h3>
								<p class="text-sm text-gray-500">Asigna cuentas CLABE diferentes por sucursal o concepto. El dinero llega directo a donde debe.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Todos los metodos de pago</h3>
								<p class="text-sm text-gray-500">Tarjeta contactless (NFC), chip, banda magnetica, efectivo, transferencia bancaria, wallet digital.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Criptomonedas</h3>
								<p class="text-sm text-gray-500">Acepta BTC, ETH y USDT via B4Bit con verificacion criptografica.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Reconciliacion automatica</h3>
								<p class="text-sm text-gray-500">Cada pago se reconcilia en 4 capas: terminal, procesador, backend y webhook. Zero discrepancias.</p>
							</div>
						</div>
					</div>

					<!-- Payment methods mockup — inside a physical terminal -->
					<div class="flex justify-center lg:justify-end">
						<TpvFrame time="10:24">
						<div class="text-[11px] text-gray-500 mb-3 font-medium">Enrutamiento de pagos</div>
						<!-- Payment flow -->
						<div class="space-y-3 mb-4">
							<!-- Payment in -->
							<div class="rounded-xl p-3 border border-black/5" style={`background: ${CARD};`}>
								<div class="text-[9px] text-gray-400 mb-2">Pago recibido</div>
								<div class="flex items-center justify-between">
									<div class="flex items-center gap-2">
										<div class="w-2 h-2 rounded-full bg-avoqado-green"></div>
										<span class="text-xs text-gray-900">Tarjeta Visa *4821</span>
									</div>
									<span class="text-xs font-medium" style={`color: ${GREEN_INK};`}>$1,247.00</span>
								</div>
							</div>
							<!-- Routing arrow -->
							<div class="flex justify-center">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={HAIRLINE} stroke-width="2" stroke-linecap="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
							</div>
							<!-- Routing destinations -->
							<div class="space-y-2">
								<div class="flex items-center justify-between p-3 rounded-xl border" style={`background: ${GREEN_TINT}; border-color: ${GREEN};`}>
									<div>
										<span class="text-xs text-gray-900">Cuenta principal</span>
										<span class="text-[9px] text-gray-500 block">CLABE **** 7832 — BBVA</span>
									</div>
									<span class="text-xs font-medium" style={`color: ${GREEN_INK};`}>Sucursal Centro</span>
								</div>
								<div class="flex items-center justify-between p-3 rounded-xl border border-black/5" style={`background: ${CARD};`}>
									<div>
										<span class="text-xs text-gray-900">Cuenta eventos</span>
										<span class="text-[9px] text-gray-500 block">CLABE **** 1456 — Banorte</span>
									</div>
									<span class="text-[9px] text-gray-500">Sucursal Norte</span>
								</div>
								<div class="flex items-center justify-between p-3 rounded-xl border border-black/5" style={`background: ${CARD};`}>
									<div>
										<span class="text-xs text-gray-900">Cuenta propinas</span>
										<span class="text-[9px] text-gray-500 block">CLABE **** 9021 — HSBC</span>
									</div>
									<span class="text-[9px] text-gray-500">Todas</span>
								</div>
							</div>
						</div>
						<!-- Methods accepted -->
						<div class="flex flex-wrap gap-1.5">
							<span class="text-[9px] px-2 py-1 rounded-full border border-black/5" style={`background: ${CARD}; color: oklch(0.45 0.005 155);`}>NFC</span>
							<span class="text-[9px] px-2 py-1 rounded-full border border-black/5" style={`background: ${CARD}; color: oklch(0.45 0.005 155);`}>Chip</span>
							<span class="text-[9px] px-2 py-1 rounded-full border border-black/5" style={`background: ${CARD}; color: oklch(0.45 0.005 155);`}>Banda</span>
							<span class="text-[9px] px-2 py-1 rounded-full border border-black/5" style={`background: ${CARD}; color: oklch(0.45 0.005 155);`}>Efectivo</span>
							<span class="text-[9px] px-2 py-1 rounded-full border border-black/5" style={`background: ${CARD}; color: oklch(0.45 0.005 155);`}>Transferencia</span>
							<span class="text-[9px] px-2 py-1 rounded-full" style={`background: ${AMBER_TINT}; color: ${AMBER_INK};`}>Crypto</span>
						</div>
						</TpvFrame>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. OPERACION OFFLINE                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Offline mockup -->
					<div class="order-2 lg:order-1 rounded-2xl overflow-hidden border border-black/10 shadow-sm p-5" style={`background: ${SURFACE};`}>
						<div class="space-y-4">
							<!-- Online state -->
							<div class="rounded-xl p-4 border border-black/5" style={`background: ${CARD};`}>
								<div class="flex items-center gap-2 mb-3">
									<div class="w-2.5 h-2.5 rounded-full bg-avoqado-green"></div>
									<span class="text-xs font-medium" style={`color: ${GREEN_INK};`}>Online</span>
								</div>
								<div class="space-y-1.5">
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-500">Ordenes sincronizadas</span>
										<span class="text-gray-900">247 / 247</span>
									</div>
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-500">Pagos procesados</span>
										<span style={`color: ${GREEN_INK};`}>En tiempo real</span>
									</div>
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-500">Menu actualizado</span>
										<span class="text-gray-900">Hace 2 min</span>
									</div>
								</div>
							</div>
							<!-- Offline state -->
							<div class="rounded-xl p-4" style={`background: ${CARD}; border: 1px solid ${AMBER_INK};`}>
								<div class="flex items-center gap-2 mb-3">
									<div class="w-2.5 h-2.5 rounded-full" style={`background: ${AMBER_INK};`}></div>
									<span class="text-xs font-medium" style={`color: ${AMBER_INK};`}>Sin conexion</span>
								</div>
								<div class="space-y-1.5">
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-500">Ordenes pendientes</span>
										<span style={`color: ${AMBER_INK};`}>12 por sincronizar</span>
									</div>
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-500">Pagos en efectivo</span>
										<span class="text-gray-900">Operando normal</span>
									</div>
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-500">Menu local</span>
										<span class="text-gray-900">Cache activo</span>
									</div>
								</div>
							</div>
							<!-- Sync state -->
							<div class="rounded-xl p-4" style={`background: ${GREEN_TINT}; border: 1px solid ${GREEN_LINE};`}>
								<div class="flex items-center gap-2 mb-3">
									<div class="w-2.5 h-2.5 rounded-full bg-avoqado-green animate-pulse"></div>
									<span class="text-xs font-medium" style={`color: ${GREEN_INK};`}>Sincronizando...</span>
								</div>
								<div class="w-full h-1.5 rounded-full overflow-hidden" style={`background: ${TRACK};`}>
									<div class="h-full rounded-full bg-avoqado-green" style="width: 67%;"></div>
								</div>
								<div class="text-[9px] text-gray-500 mt-1.5">8 de 12 ordenes sincronizadas</div>
							</div>
						</div>
					</div>

