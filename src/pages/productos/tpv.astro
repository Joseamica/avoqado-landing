---
import '../../styles/global.css';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';

const GREEN = '#69E185';
const BLUE = 'oklch(0.72 0.14 240)';
const AMBER = 'oklch(0.78 0.14 75)';
const RED = 'oklch(0.65 0.20 25)';
const INDIGO = 'oklch(0.68 0.15 290)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado TPV | Terminal de Cobro Inteligente</title>
		<meta name="description" content="Terminal de cobro handheld con 5 procesadores de pago, operacion offline, gestion remota, multi-merchant y modo kiosko. PAX, Ingenico y Verifone." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">02</span>
							<span class="text-xs uppercase tracking-widest font-semibold text-avoqado-green">Terminal de cobro</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Cobra en cualquier lugar.<br/>
							Con o sin internet.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							Terminal handheld para tu staff con 5 procesadores de pago, impresora integrada, operacion offline y sincronizacion automatica. Gestiona remotamente desde el dashboard.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-avoqado-green text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200">
								Solicitar terminal
							</a>
							<a href="https://demo.dashboard.avoqado.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Ver demo del dashboard
							</a>
						</div>
					</div>
					<!-- Terminals composition — floating with 3 devices -->
					<div class="hidden lg:flex justify-center items-center relative" style="min-height: 520px;">
						<!-- Green glow underneath -->
						<div class="absolute bottom-8 left-1/2 -translate-x-1/2 w-72 h-16 rounded-full blur-3xl animate-terminal-glow" style="background: #69E185; opacity: 0.15;"></div>

						<!-- PAX A910S — main, center-left, largest -->
						<img src="/pax-avoqado.png" alt="Terminal PAX A910S con Avoqado"
							class="max-h-[480px] w-auto animate-terminal-float relative z-20"
							style="filter: drop-shadow(0 25px 50px rgba(0,0,0,0.6)); transform-origin: center bottom;"
							loading="eager" />

						<!-- Nexgo compact — right, smaller, offset down -->
						<img src="/nexgo-avoqado.png" alt="Terminal Nexgo con Avoqado"
							class="max-h-[220px] w-auto absolute right-0 bottom-16 z-10 animate-terminal-float"
							style="filter: drop-shadow(0 15px 30px rgba(0,0,0,0.4)); animation-delay: -1.8s;"
							loading="eager" />

						<!-- Nexgo N86 — left-back, angled, behind PAX -->
						<img src="/nexgo86-avoqado.png" alt="Terminal Nexgo N86 con Avoqado"
							class="max-h-[260px] w-auto absolute -left-8 bottom-4 z-0 animate-terminal-float"
							style="filter: drop-shadow(0 15px 30px rgba(0,0,0,0.4)); animation-delay: -3.2s; opacity: 0.85;"
							loading="eager" />
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. ENRUTAMIENTO DE PAGOS                     -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block text-avoqado-green">Pagos</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Tu decides a donde va cada peso.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Configura a que cuenta bancaria se deposita cada transaccion. Enruta pagos a diferentes CLABEs por sucursal, por concepto o por regla de negocio. Acepta tarjeta (NFC, chip, banda), efectivo, transferencia, wallet y criptomonedas.
						</p>
						<div class="space-y-4">
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Enrutamiento inteligente</h3>
								<p class="text-sm text-gray-500">Asigna cuentas CLABE diferentes por sucursal o concepto. El dinero llega directo a donde debe.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Todos los metodos de pago</h3>
								<p class="text-sm text-gray-500">Tarjeta contactless (NFC), chip, banda magnetica, efectivo, transferencia bancaria, wallet digital.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Criptomonedas</h3>
								<p class="text-sm text-gray-500">Acepta BTC, ETH y USDT via B4Bit con verificacion criptografica.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Reconciliacion automatica</h3>
								<p class="text-sm text-gray-500">Cada pago se reconcilia en 4 capas: terminal, procesador, backend y webhook. Zero discrepancias.</p>
							</div>
						</div>
					</div>

					<!-- Payment methods mockup -->
					<div class="rounded-2xl overflow-hidden border border-black/5 p-5" style="background: #0A0A0A;">
						<div class="text-[11px] text-gray-500 mb-4">Enrutamiento de pagos</div>
						<!-- Payment flow -->
						<div class="space-y-3 mb-4">
							<!-- Payment in -->
							<div class="rounded-xl p-3" style="background: oklch(0.16 0.005 155);">
								<div class="text-[9px] text-gray-600 mb-2">Pago recibido</div>
								<div class="flex items-center justify-between">
									<div class="flex items-center gap-2">
										<div class="w-2 h-2 rounded-full bg-avoqado-green"></div>
										<span class="text-xs text-white">Tarjeta Visa *4821</span>
									</div>
									<span class="text-xs text-avoqado-green">$1,247.00</span>
								</div>
							</div>
							<!-- Routing arrow -->
							<div class="flex justify-center">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="oklch(0.40 0.005 155)" stroke-width="2" stroke-linecap="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
							</div>
							<!-- Routing destinations -->
							<div class="space-y-2">
								<div class="flex items-center justify-between p-3 rounded-xl border" style={`background: oklch(0.14 0.02 155); border-color: ${GREEN};`}>
									<div>
										<span class="text-xs text-white">Cuenta principal</span>
										<span class="text-[9px] text-gray-500 block">CLABE **** 7832 — BBVA</span>
									</div>
									<span class="text-xs text-avoqado-green">Sucursal Centro</span>
								</div>
								<div class="flex items-center justify-between p-3 rounded-xl" style="background: oklch(0.16 0.005 155);">
									<div>
										<span class="text-xs text-white">Cuenta eventos</span>
										<span class="text-[9px] text-gray-500 block">CLABE **** 1456 — Banorte</span>
									</div>
									<span class="text-[9px] text-gray-500">Sucursal Norte</span>
								</div>
								<div class="flex items-center justify-between p-3 rounded-xl" style="background: oklch(0.16 0.005 155);">
									<div>
										<span class="text-xs text-white">Cuenta propinas</span>
										<span class="text-[9px] text-gray-500 block">CLABE **** 9021 — HSBC</span>
									</div>
									<span class="text-[9px] text-gray-500">Todas</span>
								</div>
							</div>
						</div>
						<!-- Methods accepted -->
						<div class="flex flex-wrap gap-1.5">
							<span class="text-[9px] px-2 py-1 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">NFC</span>
							<span class="text-[9px] px-2 py-1 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">Chip</span>
							<span class="text-[9px] px-2 py-1 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">Banda</span>
							<span class="text-[9px] px-2 py-1 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">Efectivo</span>
							<span class="text-[9px] px-2 py-1 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">Transferencia</span>
							<span class="text-[9px] px-2 py-1 rounded-full" style={`background: oklch(0.16 0.02 75); color: ${AMBER};`}>Crypto</span>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. OPERACION OFFLINE                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Offline mockup -->
					<div class="order-2 lg:order-1 rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
						<div class="space-y-4">
							<!-- Online state -->
							<div class="rounded-xl p-4" style="background: oklch(0.16 0.005 155);">
								<div class="flex items-center gap-2 mb-3">
									<div class="w-2.5 h-2.5 rounded-full bg-avoqado-green"></div>
									<span class="text-xs text-avoqado-green font-medium">Online</span>
								</div>
								<div class="space-y-1.5">
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-400">Ordenes sincronizadas</span>
										<span class="text-white">247 / 247</span>
									</div>
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-400">Pagos procesados</span>
										<span class="text-avoqado-green">En tiempo real</span>
									</div>
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-400">Menu actualizado</span>
										<span class="text-white">Hace 2 min</span>
									</div>
								</div>
							</div>
							<!-- Offline state -->
							<div class="rounded-xl p-4" style={`background: oklch(0.16 0.005 155); border: 1px solid ${AMBER};`}>
								<div class="flex items-center gap-2 mb-3">
									<div class="w-2.5 h-2.5 rounded-full" style={`background: ${AMBER};`}></div>
									<span class="text-xs font-medium" style={`color: ${AMBER};`}>Sin conexion</span>
								</div>
								<div class="space-y-1.5">
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-400">Ordenes pendientes</span>
										<span style={`color: ${AMBER};`}>12 por sincronizar</span>
									</div>
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-400">Pagos en efectivo</span>
										<span class="text-white">Operando normal</span>
									</div>
									<div class="flex justify-between text-[10px]">
										<span class="text-gray-400">Menu local</span>
										<span class="text-white">Cache activo</span>
									</div>
								</div>
							</div>
							<!-- Sync state -->
							<div class="rounded-xl p-4" style="background: oklch(0.14 0.02 155); border: 1px solid oklch(0.30 0.04 155);">
								<div class="flex items-center gap-2 mb-3">
									<div class="w-2.5 h-2.5 rounded-full bg-avoqado-green animate-pulse"></div>
									<span class="text-xs text-avoqado-green font-medium">Sincronizando...</span>
								</div>
								<div class="w-full h-1.5 rounded-full overflow-hidden" style="background: oklch(0.20 0.005 155);">
									<div class="h-full rounded-full bg-avoqado-green" style="width: 67%;"></div>
								</div>
								<div class="text-[9px] text-gray-500 mt-1.5">8 de 12 ordenes sincronizadas</div>
							</div>
						</div>
					</div>

					<div class="order-1 lg:order-2">
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block text-avoqado-green">Offline-first</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-white mb-6 leading-tight">
							Se cae el internet. Tu sigues cobrando.
						</h2>
						<p class="text-gray-400 text-lg leading-relaxed mb-8">
							La terminal opera con o sin conexion. Ordenes, menu y configuracion se almacenan localmente. Cuando vuelve el internet, todo se sincroniza automaticamente — sin perder una sola transaccion.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-400">Menu y productos disponibles sin internet via cache local</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${AMBER};`}></div>
								<span class="text-sm text-gray-400">Cobros en efectivo operan 100% normal sin conexion</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${BLUE};`}></div>
								<span class="text-sm text-gray-400">Sincronizacion automatica al reconectar — zero intervencion</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 3. HARDWARE SOPORTADO                       -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${GREEN};`}>Hardware</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Compatible con lo que ya tienes.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Funciona con las principales marcas de terminales. Impresora de tickets integrada, Kitchen Display System para cocina, y activacion en menos de 5 minutos con un codigo de 6 caracteres.
						</p>
						<div class="space-y-4">
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Terminales</h3>
								<p class="text-sm text-gray-500">PAX (A910S, A920), Ingenico (D220), Verifone (VX520) y cualquier dispositivo Android.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Impresora integrada</h3>
								<p class="text-sm text-gray-500">Ticket impreso al instante. Recibos digitales con link a review como alternativa.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Kitchen Display (KDS)</h3>
								<p class="text-sm text-gray-500">Ordenes llegan directo a la pantalla de cocina con tracking de estado por platillo.</p>
							</div>
							<div class="border-t border-black/5 pt-3">
								<h3 class="text-base text-black font-medium mb-1">Activacion rapida</h3>
								<p class="text-sm text-gray-500">Codigo de 6 caracteres, expira en 7 dias, anti-brute force (max 5 intentos).</p>
							</div>
						</div>
					</div>

					<!-- Hardware — real terminal images, staggered heights -->
					<div class="flex items-end justify-center gap-4 relative" style="min-height: 400px;">
						<!-- PAX A910S — tallest, center -->
						<div class="flex flex-col items-center relative z-10">
							<img src="/pax-avoqado.png" alt="PAX A910S" class="h-72 w-auto mb-3" style="filter: drop-shadow(0 12px 24px rgba(0,0,0,0.1));" />
							<span class="text-sm text-black font-medium">PAX A910S</span>
							<span class="text-[10px] text-gray-500">Handheld + impresora</span>
						</div>
						<!-- Nexgo N86 — medium, angled shot -->
						<div class="flex flex-col items-center relative z-0 -ml-4">
							<img src="/nexgo86-avoqado.png" alt="Nexgo N86" class="h-52 w-auto mb-3" style="filter: drop-shadow(0 12px 24px rgba(0,0,0,0.1));" />
							<span class="text-sm text-black font-medium">Nexgo N86</span>
							<span class="text-[10px] text-gray-500">Robusta + escaner</span>
						</div>
						<!-- Nexgo compact — smallest, right -->
						<div class="flex flex-col items-center relative z-0 -ml-2">
							<img src="/nexgo-avoqado.png" alt="Nexgo Compact" class="h-40 w-auto mb-3" style="filter: drop-shadow(0 12px 24px rgba(0,0,0,0.1));" />
							<span class="text-sm text-black font-medium">Nexgo</span>
							<span class="text-[10px] text-gray-500">Compacta + NFC</span>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 4. MULTI-MERCHANT + LOGIN                   -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-16">
					<!-- Multi-merchant -->
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block text-avoqado-green">Multi-merchant</span>
						<h2 class="text-3xl font-light tracking-tight text-white mb-4 leading-tight">
							Una terminal, multiples negocios.
						</h2>
						<p class="text-gray-400 text-base leading-relaxed mb-6">
							Un solo dispositivo puede operar con diferentes cuentas de merchant. Ideal para plazas comerciales, food halls o negocios con multiples conceptos.
						</p>
						<div class="rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
							<div class="text-[10px] text-gray-600 mb-3">Selecciona merchant</div>
							<div class="space-y-2">
								<div class="flex items-center gap-3 p-3 rounded-lg" style={`background: oklch(0.14 0.02 155); border: 1px solid ${GREEN};`}>
									<div class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold" style="background: oklch(0.20 0.03 155); color: #69E185;">LT</div>
									<div>
										<span class="text-xs text-white">La Terraza Rooftop</span>
										<span class="text-[9px] text-avoqado-green block">Activo</span>
									</div>
								</div>
								<div class="flex items-center gap-3 p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
									<div class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold" style={`background: oklch(0.18 0.02 240); color: ${BLUE};`}>CB</div>
									<div>
										<span class="text-xs text-white">Cafe Botanico</span>
										<span class="text-[9px] text-gray-600 block">Cambiar</span>
									</div>
								</div>
								<div class="flex items-center gap-3 p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
									<div class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold" style={`background: oklch(0.18 0.02 75); color: ${AMBER};`}>BN</div>
									<div>
										<span class="text-xs text-white">Bar Norte</span>
										<span class="text-[9px] text-gray-600 block">Cambiar</span>
									</div>
								</div>
							</div>
						</div>
					</div>

					<!-- Login rapido -->
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block text-avoqado-green">Acceso rapido</span>
						<h2 class="text-3xl font-light tracking-tight text-white mb-4 leading-tight">
							Login en 2 segundos.
						</h2>
						<p class="text-gray-400 text-base leading-relaxed mb-6">
							PIN numerico por venue para acceso rapido. Biometricos y passkeys (Face ID, Touch ID) para seguridad sin friccion. Sin esperar, sin escribir passwords.
						</p>
						<div class="rounded-2xl overflow-hidden border border-white/5 p-5" style="background: oklch(0.12 0.005 155);">
							<div class="text-center mb-4">
								<span class="text-xs text-gray-500">Ingresa tu PIN</span>
							</div>
							<!-- PIN dots -->
							<div class="flex justify-center gap-3 mb-6">
								<div class="w-4 h-4 rounded-full bg-avoqado-green"></div>
								<div class="w-4 h-4 rounded-full bg-avoqado-green"></div>
								<div class="w-4 h-4 rounded-full" style="background: oklch(0.25 0.005 155);"></div>
