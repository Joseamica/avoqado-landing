			0%, 100% { box-shadow: 0 0 0 0 rgba(105, 225, 133, 0); }
			50% { box-shadow: 0 0 20px 4px rgba(105, 225, 133, 0.15); }
		}

		/* Section border accent animation */
		@keyframes border-slide {
			from { background-position: 200% 0; }
			to { background-position: -200% 0; }
		}
	</style>

	<script>
		// TPV hero — the terminals subtly turn to "look at" the cursor.
		// The whole group tilts in 3D toward the mouse, and each device drifts
		// by a different amount (its data-depth) for a parallax sense of depth.
		// Desktop + fine pointer only; disabled under prefers-reduced-motion.
		const root = document.querySelector('[data-terminals-root]');
		const stage = document.querySelector('[data-terminals-stage]');

		if (root && stage) {
			const layers = Array.from(stage.querySelectorAll('img[data-depth]')).map((el) => ({
				el,
				depth: parseFloat(el.getAttribute('data-depth')) || 0,
			}));

			const MAX_ROT = 6; // degrees of group tilt at full deflection
			const EASE = 0.09; // lower = smoother, more trailing
			const EPS = 0.0004;

			let tx = 0, ty = 0; // target offset, normalized to [-1, 1]
			let cx = 0, cy = 0; // current (eased) offset
			let raf = 0;
			let bound = false;

			const fine = window.matchMedia('(min-width: 1024px) and (pointer: fine)');
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

			const render = () => {
				stage.style.transform =
					`rotateX(${(-cy * MAX_ROT).toFixed(3)}deg) rotateY(${(cx * MAX_ROT).toFixed(3)}deg)`;
				for (const { el, depth } of layers) {
					el.style.setProperty('--mx', `${(cx * depth).toFixed(2)}px`);
					el.style.setProperty('--my', `${(cy * depth).toFixed(2)}px`);
				}
			};

			const tick = () => {
				cx += (tx - cx) * EASE;
				cy += (ty - cy) * EASE;
				render();
				raf = (Math.abs(tx - cx) > EPS || Math.abs(ty - cy) > EPS)
					? requestAnimationFrame(tick)
					: 0;
			};

			const kick = () => { if (!raf) raf = requestAnimationFrame(tick); };

			const onMove = (e) => {
				const hw = window.innerWidth / 2;
				const hh = window.innerHeight / 2;
				tx = Math.max(-1, Math.min(1, (e.clientX - hw) / hw));
				ty = Math.max(-1, Math.min(1, (e.clientY - hh) / hh));
				kick();
			};

			const recenter = () => { tx = 0; ty = 0; kick(); };
			const onOut = (e) => { if (!e.relatedTarget) recenter(); };

			const bind = () => {
				if (bound) return;
				bound = true;
				window.addEventListener('mousemove', onMove, { passive: true });
				document.addEventListener('mouseout', onOut, { passive: true });
				window.addEventListener('blur', recenter);
			};

			const unbind = () => {
				if (!bound) return;
				bound = false;
				window.removeEventListener('mousemove', onMove);
				document.removeEventListener('mouseout', onOut);
				window.removeEventListener('blur', recenter);
				tx = ty = cx = cy = 0;
				if (raf) { cancelAnimationFrame(raf); raf = 0; }
				stage.style.transform = '';
				for (const { el } of layers) {
					el.style.removeProperty('--mx');
					el.style.removeProperty('--my');
				}
			};

			const apply = () => { (fine.matches && !reduce.matches) ? bind() : unbind(); };
			apply();
			fine.addEventListener('change', apply);
			reduce.addEventListener('change', apply);
		}
	</script>
