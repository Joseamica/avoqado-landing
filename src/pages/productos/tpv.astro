		<style>
			@keyframes terminal-float {
				0%, 100% { transform: translate(var(--mx, 0px), calc(0px + var(--my, 0px))) rotate(0deg); }
				25% { transform: translate(var(--mx, 0px), calc(-12px + var(--my, 0px))) rotate(0.5deg); }
				50% { transform: translate(var(--mx, 0px), calc(-6px + var(--my, 0px))) rotate(-0.3deg); }
