			/* Host the already-approved light-card mockup UIs inside the terminal
			   screen: fill the screen and vertically center the content. The
			   TpvFrame stage handles all scaling (transform), so no per-element
			   scaling is needed here — content is authored at 330px native. */
			.tpv-fit {
				flex: 1 1 auto;
				min-height: 0;
				display: flex;
				flex-direction: column;
			}
			.tpv-fit-inner {
