---
import '../../styles/global.css';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import FloatingChatbot from '../../components/interactive/FloatingChatbot';

const INDIGO = 'oklch(0.68 0.15 290)';
const INDIGO_DEEP = 'oklch(0.48 0.15 290)'; // acento indigo legible sobre blanco (eyebrows / mockups claros)
const GREEN = '#7ADD2C';
const BLUE = 'oklch(0.72 0.14 240)';
const AMBER = 'oklch(0.78 0.14 75)';
const RED = 'oklch(0.65 0.20 25)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado POS | Punto de Venta para iOS y Android</title>
		<meta name="description" content="Punto de venta nativo para iOS y Android. Floor plan, ordenes multi-tipo, reservas y citas, clases con cupo, informes de venta, KDS, turnos, modo kiosko y operacion offline." />
		<link rel="icon" type="image/png" href="/favicon.png?v=3" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />
		<main>


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">03</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style={`color: ${INDIGO};`}>Avoqado POS</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Tu punto de venta.<br/>En cualquier dispositivo.
						</h1>
						<p class="text-lg md:text-xl text-gray-400 max-w-xl leading-relaxed mb-10">
							App nativa para iOS y Android con floor plan, ordenes multi-tipo, reservas y citas, clases con cupo, informes de venta y operacion offline. Para cualquier tipo de negocio.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://avoqado.io/demo" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-white font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200" style={`background: ${INDIGO};`}>
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Hablar con ventas
							</a>
						</div>
					</div>

					<!-- iPad tablet mockup — floor plan preview (visible en todos los tamanos; tilt solo desktop) -->
					<div class="flex justify-center items-center">
						<div
							aria-hidden="true" class="ipad-frame relative w-full max-w-[320px] lg:max-w-[380px] lg:[transform:perspective(1200px)_rotateY(-5deg)_rotateX(3deg)]"
							style={`
								background: linear-gradient(145deg, oklch(0.82 0.005 155), oklch(0.70 0.005 155));
								border-radius: 1.6rem;
								padding: 8px;
								box-shadow: 0 25px 80px rgba(0,0,0,0.4);
							`}
						>
							<!-- Inner bezel -->
							<div
								class="relative overflow-hidden"
								style="background: oklch(0.12 0.005 155); border-radius: 1.2rem; padding: 4px;"
							>
								<!-- Camera dot -->
								<div class="absolute top-[6px] left-1/2 -translate-x-1/2 w-[6px] h-[6px] rounded-full z-10" style="background: oklch(0.20 0.005 155); box-shadow: inset 0 1px 2px rgba(0,0,0,0.5);"></div>

								<!-- Screen -->
								<div class="relative overflow-hidden" style="background: oklch(0.10 0.008 290); border-radius: 0.9rem; padding: 16px 14px 14px;">
									<!-- Screen header bar -->
									<div class="flex items-center justify-between mb-3 pt-1">
										<div class="flex items-center gap-2">
											<div class="w-6 h-6 rounded-md flex items-center justify-center" style={`background: oklch(0.20 0.04 290); color: ${INDIGO};`}>
												<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
											</div>
											<span class="text-[12px] text-white font-medium">Sala Principal</span>
										</div>
										<div class="flex gap-1.5">
											<span class="text-[9px] px-2 py-0.5 rounded-full font-medium" style={`background: oklch(0.20 0.04 290); color: ${INDIGO};`}>6 mesas</span>
											<span class="text-[9px] px-2 py-0.5 rounded-full font-medium" style="background: oklch(0.19 0.03 155); color: oklch(0.72 0.14 155);">2 libres</span>
										</div>
									</div>

									<!-- Floor plan grid — 2 filas de mesas + barra -->
									<div class="grid grid-cols-3 auto-rows-[92px] gap-2 mb-2">
										<!-- M1: occupied (indigo) -->
										<div class="rounded-xl h-full flex flex-col items-center justify-center gap-0.5" style={`background: oklch(0.22 0.06 290); border: 1px solid oklch(0.42 0.11 290);`}>
											<span class="text-[13px] text-white font-semibold">M1</span>
											<span class="text-[9px]" style={`color: ${INDIGO};`}>4 pax · $2,340</span>
										</div>
										<!-- M2: free (dashed) -->
										<div class="rounded-xl h-full flex flex-col items-center justify-center gap-0.5" style="background: oklch(0.155 0.006 155); border: 1px dashed oklch(0.34 0.008 155);">
											<span class="text-[13px] text-gray-400 font-semibold">M2</span>
											<span class="text-[9px] text-gray-500">Libre</span>
										</div>
										<!-- M3: occupied (indigo) -->
										<div class="rounded-xl h-full flex flex-col items-center justify-center gap-0.5" style={`background: oklch(0.22 0.06 290); border: 1px solid oklch(0.42 0.11 290);`}>
											<span class="text-[13px] text-white font-semibold">M3</span>
											<span class="text-[9px]" style={`color: ${INDIGO};`}>2 pax · $890</span>
										</div>
										<!-- M4: reserved (amber), round -->
										<div class="h-full flex items-center justify-center">
											<div class="w-[84px] h-[84px] rounded-full flex flex-col items-center justify-center gap-0.5" style={`background: oklch(0.21 0.05 75); border: 1px solid oklch(0.46 0.09 75);`}>
												<span class="text-[13px] text-white font-semibold">M4</span>
												<span class="text-[9px]" style={`color: ${AMBER};`}>Res · 19:30</span>
											</div>
										</div>
										<!-- M5: VIP occupied, doble -->
										<div class="rounded-xl h-full flex flex-col items-center justify-center gap-0.5 col-span-2" style={`background: oklch(0.22 0.06 290); border: 1px solid oklch(0.42 0.11 290);`}>
											<span class="text-[13px] text-white font-semibold">M5 — VIP</span>
											<span class="text-[9px]" style={`color: ${INDIGO};`}>8 pax · $5,670 · 1h 20m</span>
										</div>
									</div>
									<!-- Barra -->
									<div class="rounded-xl flex items-center justify-between px-3 py-2.5 mb-3" style="background: oklch(0.155 0.006 155); border: 1px solid oklch(0.26 0.008 155);">
										<span class="text-[10px] text-gray-400 font-medium">Barra</span>
										<div class="flex items-center gap-1.5">
											<div class="w-2.5 h-2.5 rounded-full" style={`background: ${INDIGO};`}></div>
											<div class="w-2.5 h-2.5 rounded-full" style={`background: ${INDIGO};`}></div>
											<div class="w-2.5 h-2.5 rounded-full" style={`background: ${INDIGO};`}></div>
											<div class="w-2.5 h-2.5 rounded-full" style={`background: ${INDIGO};`}></div>
											<div class="w-2.5 h-2.5 rounded-full" style="background: oklch(0.30 0.008 155);"></div>
											<div class="w-2.5 h-2.5 rounded-full" style="background: oklch(0.30 0.008 155);"></div>
											<span class="text-[9px] text-gray-500 ml-1">4/6</span>
										</div>
									</div>

									<!-- Legend bar -->
									<div class="flex items-center gap-3 pt-2 border-t" style="border-color: oklch(0.18 0.005 155);">
										<div class="flex items-center gap-1">
											<div class="w-1.5 h-1.5 rounded-sm" style={`background: ${INDIGO};`}></div>
											<span class="text-[6px] text-gray-500">Ocupada</span>
										</div>
										<div class="flex items-center gap-1">
											<div class="w-1.5 h-1.5 rounded-sm" style="background: oklch(0.25 0.005 155);"></div>
											<span class="text-[6px] text-gray-500">Libre</span>
										</div>
										<div class="flex items-center gap-1">
											<div class="w-1.5 h-1.5 rounded-sm" style={`background: ${AMBER};`}></div>
											<span class="text-[6px] text-gray-500">Reservada</span>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. FLOOR PLAN / MESAS                       -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${INDIGO_DEEP};`}>Mesas</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Gestiona tu espacio como quieras.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Floor plan visual con drag & drop. Posiciona mesas cuadradas, redondas o rectangulares. Ve el estado de cada mesa en tiempo real — ocupada, libre, reservada — con el monto de la cuenta abierta.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${INDIGO};`}></div>
								<span class="text-sm text-gray-600">Drag & drop para posicionar mesas en el plano de tu local</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 bg-avoqado-green shrink-0"></div>
								<span class="text-sm text-gray-600">Formas cuadradas, redondas y rectangulares con capacidad por mesa</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${AMBER};`}></div>
								<span class="text-sm text-gray-600">Estado en tiempo real: disponible, ocupada, reservada, por limpiar</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${BLUE};`}></div>
								<span class="text-sm text-gray-600">Multiples zonas: salon, terraza, bar, privado — cada una con su layout</span>
							</div>
						</div>
					</div>

					<!-- Floor plan detail mockup -->
					<div aria-hidden="true" class="rounded-2xl overflow-hidden border border-black/5 p-5" style="background: #0A0A0A;">
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-gray-500">Zonas configuradas — 4</span>
							<div class="flex gap-1.5">
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 290); color: ${INDIGO};`}>Salon</span>
								<span class="text-[9px] px-2 py-0.5 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">Terraza</span>
								<span class="text-[9px] px-2 py-0.5 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">Bar</span>
								<span class="text-[9px] px-2 py-0.5 rounded-full" style="background: oklch(0.16 0.005 155); color: oklch(0.50 0.005 155);">Privado</span>
							</div>
						</div>
						<!-- Table detail cards -->
						<div class="space-y-2 mb-4">
							<div class="flex items-center justify-between p-3 rounded-lg" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${INDIGO};`}>
								<div class="flex items-center gap-3">
									<div class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold" style={`background: oklch(0.18 0.02 290); color: ${INDIGO};`}>M6</div>
									<div>
										<span class="text-xs text-white">Mesa VIP — 8 personas</span>
										<span class="text-[9px] text-gray-500 block">Ocupada hace 47 min — Mesero: Carlos R.</span>
									</div>
								</div>
								<div class="text-right">
									<span class="text-xs text-white">$5,670</span>
									<span class="text-[9px] block" style={`color: ${INDIGO};`}>9 items</span>
								</div>
							</div>
							<div class="flex items-center justify-between p-3 rounded-lg" style={`background: oklch(0.16 0.005 155); border-left: 3px solid ${AMBER};`}>
								<div class="flex items-center gap-3">
									<div class="w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-bold" style={`background: oklch(0.18 0.02 75); color: ${AMBER};`}>M4</div>
									<div>
										<span class="text-xs text-white">Mesa 4 — 4 personas</span>
										<span class="text-[9px] block" style={`color: ${AMBER};`}>Reservada 20:00 — Ana L. (Tel: *4521)</span>
									</div>
								</div>
								<div class="text-right">
									<span class="text-[9px]" style={`color: ${AMBER};`}>En 35 min</span>
								</div>
							</div>
							<div class="flex items-center justify-between p-3 rounded-lg" style="background: oklch(0.16 0.005 155); border-left: 3px solid oklch(0.40 0.005 155);">
								<div class="flex items-center gap-3">
									<div class="w-8 h-8 rounded-lg flex items-center justify-center text-[10px] font-bold" style="background: oklch(0.20 0.005 155); color: oklch(0.50 0.005 155);">M3</div>
									<div>
										<span class="text-xs text-gray-400">Mesa 3 — 2 personas</span>
										<span class="text-[9px] text-gray-500 block">Disponible</span>
									</div>
								</div>
								<span class="text-[9px] px-2 py-0.5 rounded" style={`background: oklch(0.18 0.02 290); color: ${INDIGO};`}>Asignar</span>
							</div>
						</div>
						<!-- Summary -->
						<div class="grid grid-cols-3 gap-2">
							<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
								<div class="text-sm font-light text-white">7</div>
								<div class="text-[8px] text-gray-500">Ocupadas</div>
							</div>
							<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
								<div class="text-sm font-light text-white">5</div>
								<div class="text-[8px] text-gray-500">Libres</div>
							</div>
							<div class="rounded-lg p-2.5 text-center" style="background: oklch(0.16 0.005 155);">
								<div class="text-sm font-light" style={`color: ${AMBER};`}>2</div>
								<div class="text-[8px] text-gray-500">Reservadas</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. ORDENES Y CATALOGO                       -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Catalog mockup -->
					<div aria-hidden="true" class="order-2 lg:order-1 w-full max-w-[560px] mx-auto" style="background: linear-gradient(145deg, oklch(0.82 0.005 155), oklch(0.70 0.005 155)); border-radius: 1.6rem; padding: 8px; box-shadow: 0 25px 60px rgba(0,0,0,0.35);">
						<div style="background: oklch(0.12 0.005 155); border-radius: 1.2rem; padding: 4px;">
							<div class="overflow-hidden p-5" style="background: #f1f1f1; border-radius: 0.95rem;">
								<div class="flex items-center justify-between mb-3">
									<span class="text-[9px] text-gray-500 font-medium tabular-nums">12:30</span>
									<div class="flex items-center gap-1.5">
										<span class="text-[8px] text-gray-500">LTE</span>
										<div class="relative" style="width: 16px; height: 8px; border: 1px solid oklch(0.60 0.005 155); border-radius: 2px;">
											<div class="absolute" style="inset: 1px; right: 30%; background: oklch(0.55 0.005 155); border-radius: 1px;"></div>
										</div>
									</div>
								</div>
						<div class="flex items-center justify-between mb-4">
							<span class="text-[11px] text-gray-500">Nueva orden — Mesa 6</span>
							<div class="flex gap-1.5">
								<span class="text-[9px] px-2 py-0.5 rounded-full" style={`background: oklch(0.93 0.035 290); color: ${INDIGO_DEEP};`}>Dine-in</span>
							</div>
						</div>
						<!-- Categories -->
						<div class="flex gap-1.5 mb-4 overflow-hidden">
							<div class="px-3 py-1.5 rounded-full text-[9px] text-white shrink-0" style={`background: ${INDIGO_DEEP};`}>Todo</div>
							<div class="px-3 py-1.5 rounded-full text-[9px] text-gray-500 shrink-0" style="background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">Entradas</div>
							<div class="px-3 py-1.5 rounded-full text-[9px] text-gray-500 shrink-0" style="background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">Platos</div>
							<div class="px-3 py-1.5 rounded-full text-[9px] text-gray-500 shrink-0" style="background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">Bebidas</div>
							<div class="px-3 py-1.5 rounded-full text-[9px] text-gray-500 shrink-0" style="background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">Postres</div>
						</div>
						<!-- Product grid -->
						<div class="grid grid-cols-2 gap-2 mb-4">
							<div class="rounded-xl p-3" style={`background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05); border: 1px solid oklch(0.55 0.15 290);`}>
								<div class="w-full aspect-[16/9] rounded-lg mb-2 flex items-center justify-center" style="background: oklch(0.93 0.004 155);"><span class="text-[17px] font-bold tracking-wide" style="color: oklch(0.55 0.10 290);">TP</span></div>
								<span class="text-[11px] text-gray-900">Tacos al Pastor</span>
								<div class="flex items-center justify-between mt-1">
									<span class="text-[10px]" style={`color: ${INDIGO_DEEP};`}>$95</span>
									<div class="flex items-center gap-1">
										<div class="w-4 h-4 rounded flex items-center justify-center" style="background: oklch(0.93 0.004 155);">
											<span class="text-[8px] text-gray-500">-</span>
										</div>
										<span class="text-[9px] text-gray-900">3</span>
										<div class="w-4 h-4 rounded flex items-center justify-center" style={`background: ${INDIGO_DEEP};`}>
											<span class="text-[8px] text-white">+</span>
										</div>
									</div>
								</div>
							</div>
							<div class="rounded-xl p-3" style="background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
								<div class="w-full aspect-[16/9] rounded-lg mb-2 flex items-center justify-center" style="background: oklch(0.93 0.004 155);"><span class="text-[17px] font-bold tracking-wide" style="color: oklch(0.55 0.10 150);">GU</span></div>
								<span class="text-[11px] text-gray-900">Guacamole</span>
								<div class="flex items-center justify-between mt-1">
									<span class="text-[10px] text-gray-500">$120</span>
									<div class="w-4 h-4 rounded flex items-center justify-center" style="background: oklch(0.93 0.004 155);">
										<span class="text-[8px] text-gray-500">+</span>
									</div>
								</div>
							</div>
							<div class="rounded-xl p-3" style="background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
								<div class="w-full aspect-[16/9] rounded-lg mb-2 flex items-center justify-center" style="background: oklch(0.93 0.004 155);"><span class="text-[17px] font-bold tracking-wide" style="color: oklch(0.55 0.10 75);">AR</span></div>
								<span class="text-[11px] text-gray-900">Arrachera 300g</span>
								<div class="flex items-center justify-between mt-1">
									<span class="text-[10px] text-gray-500">$320</span>
									<div class="w-4 h-4 rounded flex items-center justify-center" style="background: oklch(0.93 0.004 155);">
										<span class="text-[8px] text-gray-500">+</span>
									</div>
								</div>
							</div>
							<div class="rounded-xl p-3" style="background: #ffffff; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
