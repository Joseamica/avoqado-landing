---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import HelpSearch from '../components/help/HelpSearch';
import { getArticleUrl, sortHelpArticles, toSearchItem } from '../lib/help';

export const prerender = true;

const articles = sortHelpArticles(await getCollection('help', (article) => article.data.product === 'dashboard'));
const popularArticles = articles.filter((article) => article.data.popular).slice(0, 5);
const searchItems = articles.map(toSearchItem);
---

<Layout title="Centro de ayuda | Avoqado" description="Encuentra guias para usar Avoqado Dashboard y resolver dudas operativas.">
	<Navbar position="fixed" />
	<main class="min-h-screen bg-[#f7f8f4] pt-32 text-black">
		<section class="border-b border-black/10 bg-[#f7f8f4]">
			<div class="mx-auto grid max-w-6xl gap-10 px-6 py-16 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-end">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.18em] text-green-800">Centro de ayuda</p>
					<h1 class="mt-4 max-w-3xl text-5xl font-light tracking-tight md:text-6xl">Hola. ¿Como podemos ayudarte?</h1>
					<p class="mt-5 max-w-2xl text-lg leading-relaxed text-gray-700">
						Busca guias, pasos y accesos directos para operar Avoqado sin perder tiempo.
					</p>
					<div class="mt-8 max-w-3xl">
						<HelpSearch items={searchItems} client:load />
					</div>
				</div>
				<aside class="rounded-[1.5rem] border border-black/10 bg-white p-6 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
					<p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500">Soporte rapido</p>
					<h2 class="mt-3 text-2xl font-medium">¿Ya eres cliente?</h2>
					<p class="mt-3 text-sm leading-6 text-gray-600">
						Inicia sesion para que el Dashboard abra el local correcto y te lleve directo a la pantalla de cada guia.
					</p>
					<div class="mt-5 flex flex-col gap-2">
						<a href="https://dashboard.avoqado.io/login" class="rounded-full bg-black px-4 py-3 text-center text-sm font-semibold text-white transition hover:bg-gray-800">
							Iniciar sesion
						</a>
						<a href="/contact" class="rounded-full border border-black/10 px-4 py-3 text-center text-sm font-semibold text-gray-800 transition hover:border-black/25">
							Contactar soporte
						</a>
					</div>
				</aside>
			</div>
		</section>

		<section class="mx-auto max-w-6xl px-6 py-12">
			<div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_360px]">
				<a href="/help/dashboard" class="group rounded-[1.5rem] border border-black/10 bg-white p-6 shadow-[0_12px_32px_rgba(15,23,42,0.04)] transition hover:-translate-y-0.5 hover:border-black/20 hover:shadow-[0_18px_50px_rgba(15,23,42,0.08)]">
					<span class="text-sm font-semibold text-green-800">Dashboard Web</span>
					<h2 class="mt-2 text-3xl font-medium tracking-tight">Ayuda para operar tu Dashboard</h2>
					<p class="mt-3 max-w-2xl text-gray-600">
						Pagos, pedidos, permisos, menu, inventario, reportes, reservaciones y configuracion del local.
					</p>
					<span class="mt-6 inline-flex text-sm font-semibold text-black group-hover:text-green-800">Ver guias de Dashboard -></span>
				</a>

				<div class="rounded-[1.5rem] border border-black/10 bg-white p-6">
					<p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500">Mas productos</p>
					<div class="mt-4 space-y-3">
						<div class="flex items-center justify-between gap-4 border-b border-black/10 pb-3">
							<span class="font-medium text-gray-800">Avoqado TPV</span>
							<span class="rounded-full bg-black/[0.05] px-3 py-1 text-xs font-semibold text-gray-500">Proximamente</span>
						</div>
						<div class="flex items-center justify-between gap-4">
							<span class="font-medium text-gray-800">Avoqado Android</span>
							<span class="rounded-full bg-black/[0.05] px-3 py-1 text-xs font-semibold text-gray-500">Proximamente</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-6xl px-6 pb-20">
			<div class="border-t border-black/10 pt-10">
				<div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Populares</p>
						<h2 class="mt-2 text-3xl font-medium tracking-tight">Articulos mas consultados</h2>
					</div>
					<a href="/help/dashboard" class="text-sm font-semibold text-green-800 hover:text-black">Ver todos</a>
				</div>
				<div class="mt-6 grid gap-3 md:grid-cols-2">
					{popularArticles.map((article) => (
						<a href={getArticleUrl(article)} class="rounded-2xl border border-black/10 bg-white p-5 transition hover:border-black/25">
							<span class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">{article.data.category}</span>
							<h3 class="mt-2 font-semibold">{article.data.title}</h3>
							<p class="mt-1 text-sm leading-6 text-gray-600">{article.data.description}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
