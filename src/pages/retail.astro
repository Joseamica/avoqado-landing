---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingChatbot from '../components/interactive/FloatingChatbot';

const ACCENT = '#69E185';
const BLUE = 'oklch(0.72 0.14 240)';
const AMBER = 'oklch(0.78 0.14 75)';
const RED = 'oklch(0.65 0.20 25)';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Avoqado para Retail | Gestion integral para tiendas</title>
		<meta name="description" content="Plataforma de gestion para tiendas: inventario FIFO, punto de venta, multi-sucursal, lealtad y e-commerce. Para ropa, farmacias, electronica, mascotas y mas." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full">
		<Navbar position="fixed" transparentOnTop={true} />


		<!-- ═══════════════════════════════════════════ -->
		<!-- HERO                                        -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="min-h-screen flex items-center pt-24 md:pt-32 pb-16 px-6">
			<div class="max-w-[1400px] mx-auto w-full">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<!-- Text -->
					<div>
						<div class="flex items-center gap-3 mb-6">
							<span class="text-5xl font-light text-white/10">R</span>
							<span class="text-xs uppercase tracking-widest font-semibold" style={`color: ${ACCENT};`}>Avoqado Retail</span>
						</div>
						<h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight leading-[0.95] text-white mb-8">
							Vende mas.<br/>Gestiona menos.
						</h1>
						<p class="text-lg md:text-xl text-gray-500 max-w-xl leading-relaxed mb-10">
							Inventario, personal, ventas y clientes en una sola plataforma. Para tiendas de ropa, farmacias, electronica, mascotas, librerias, joyerias y mas.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://demo.dashboard.avoqado.io" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-black font-semibold rounded-full hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200" style={`background: ${ACCENT};`}>
								Probar demo gratis
							</a>
							<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border border-white/20 text-white font-medium rounded-full hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-200">
								Hablar con ventas
							</a>
						</div>
					</div>

					<!-- Stripe-style floating mockups with depth -->
					<div class="hidden lg:block relative" style="min-height: 520px;">
						<!-- Subtle gradient glow behind mockups -->
						<div class="absolute inset-0 -inset-x-10" style="background: radial-gradient(ellipse at 60% 40%, oklch(0.20 0.06 155) 0%, transparent 60%); filter: blur(40px);"></div>

						<!-- LAYER 1 (back): Dashboard analytics panel — rotated, partially hidden -->
						<div class="absolute top-0 right-0 w-[320px]" style="transform: rotate(2deg) translateX(30px);">
							<div class="rounded-xl overflow-hidden" style="box-shadow: 0 20px 60px rgba(0,0,0,0.4);">
								<div class="flex items-center gap-1.5 px-3 py-2" style="background: oklch(0.13 0.005 155);">
									<div class="w-2 h-2 rounded-full" style="background: #FF5F57;"></div>
									<div class="w-2 h-2 rounded-full" style="background: #FEBC2E;"></div>
									<div class="w-2 h-2 rounded-full" style="background: #28C840;"></div>
									<span class="text-[7px] ml-2" style="color: oklch(0.50 0.005 155);">dashboard.avoqado.io</span>
								</div>
								<div class="p-4" style="background: oklch(0.10 0.005 155);">
									<div class="flex items-center justify-between mb-3">
										<span class="text-[10px] text-white font-medium">Dashboard — Hoy</span>
										<span class="text-[8px]" style="color: oklch(0.50 0.005 155);">Mar 19, 2026</span>
									</div>
									<div class="flex gap-2 mb-3">
										<div class="flex-1 p-2.5 rounded-lg" style="background: oklch(0.14 0.005 155);">
											<div class="text-[7px]" style="color: oklch(0.50 0.005 155);">Ventas hoy</div>
											<div class="text-sm font-semibold" style={`color: ${ACCENT};`}>$47,280</div>
											<div class="text-[7px]" style={`color: ${ACCENT};`}>+18% vs ayer</div>
										</div>
										<div class="flex-1 p-2.5 rounded-lg" style="background: oklch(0.14 0.005 155);">
											<div class="text-[7px]" style="color: oklch(0.50 0.005 155);">Transacciones</div>
											<div class="text-sm font-semibold text-white">84</div>
											<div class="text-[7px]" style="color: oklch(0.50 0.005 155);">Ticket prom: $563</div>
										</div>
									</div>
									<div class="rounded-lg p-2.5" style="background: oklch(0.14 0.005 155);">
										<div class="text-[7px] mb-2" style="color: oklch(0.50 0.005 155);">Ventas por hora</div>
										<div class="flex items-end gap-1 h-[50px]">
											{[15,25,40,65,55,80,70,90,60,45,30,20].map((h, i) => (
												<div class="flex-1 rounded-t" style={`height: ${h}%; background: ${ACCENT}; opacity: ${0.3 + i * 0.05};`}></div>
											))}
										</div>
									</div>
								</div>
							</div>
						</div>

						<!-- LAYER 2 (mid): Inventory alert — small floating card -->
						<div class="absolute top-[280px] right-[20px] w-[200px] rounded-xl p-3 z-10" style="background: oklch(0.10 0.005 155); border: 1px solid oklch(0.65 0.20 25 / 0.3); box-shadow: 0 12px 40px rgba(0,0,0,0.5); transform: rotate(-1deg);">
							<div class="flex items-center gap-2 mb-2">
								<div class="w-2 h-2 rounded-full animate-pulse" style="background: oklch(0.65 0.20 25);"></div>
								<span class="text-[9px] font-medium" style="color: oklch(0.65 0.20 25);">Alerta de stock</span>
							</div>
							<div class="space-y-1.5">
								<div class="flex items-center justify-between">
									<span class="text-[8px] text-white">Playera Basica M</span>
									<span class="text-[8px] font-medium" style="color: oklch(0.65 0.20 25);">3 uds</span>
								</div>
								<div class="flex items-center justify-between">
									<span class="text-[8px] text-white">Jeans Slim 30</span>
									<span class="text-[8px] font-medium" style="color: oklch(0.78 0.14 75);">7 uds</span>
								</div>
							</div>
							<div class="mt-2 text-center text-[8px] py-1 rounded-lg" style={`background: oklch(0.18 0.02 25); color: oklch(0.65 0.20 25);`}>Crear orden de compra</div>
						</div>

						<!-- LAYER 3 (front): POS terminal — main, largest, slight tilt -->
						<div class="absolute top-[40px] left-0 w-[360px] rounded-2xl p-4 z-20" style="background: oklch(0.09 0.005 155); border: 1px solid oklch(0.20 0.005 155); box-shadow: 0 25px 80px rgba(0,0,0,0.6), 0 0 0 1px oklch(0.15 0.005 155); transform: rotate(-1.5deg);">
							<!-- POS header -->
							<div class="flex items-center justify-between mb-3">
								<div class="flex items-center gap-2">
									<div class="w-5 h-5 rounded-md flex items-center justify-center" style={`background: oklch(0.16 0.02 155);`}>
										<div class="w-2.5 h-2.5 rounded-sm" style={`background: ${ACCENT};`}></div>
									</div>
									<span class="text-[10px] text-white font-medium">Boutique Roma — POS</span>
								</div>
								<span class="text-[7px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 155); color: ${ACCENT};`}>En linea</span>
							</div>
							<!-- Category pills -->
							<div class="flex gap-1 mb-3">
								<div class="px-2.5 py-1 rounded-full text-[8px] font-medium text-black" style={`background: ${ACCENT};`}>Todo</div>
								<div class="px-2.5 py-1 rounded-full text-[8px]" style="background: oklch(0.14 0.005 155); color: oklch(0.55 0.005 155);">Ropa</div>
								<div class="px-2.5 py-1 rounded-full text-[8px]" style="background: oklch(0.14 0.005 155); color: oklch(0.55 0.005 155);">Accesorios</div>
								<div class="px-2.5 py-1 rounded-full text-[8px]" style="background: oklch(0.14 0.005 155); color: oklch(0.55 0.005 155);">Calzado</div>
							</div>
							<!-- Product grid — 3x2 with realistic names -->
							<div class="grid grid-cols-3 gap-1.5 mb-3">
								{[
									{ name: 'Playera Basica', price: '$349', sku: 'SKU-001', active: true },
									{ name: 'Jeans Slim Fit', price: '$899', sku: 'SKU-045', active: true },
									{ name: 'Sudadera Oversize', price: '$1,250', sku: 'SKU-078', active: false },
									{ name: 'Gorra Logo MX', price: '$450', sku: 'SKU-112', active: false },
									{ name: 'Tenis Runner Pro', price: '$2,190', sku: 'SKU-203', active: false },
									{ name: 'Bolsa Tote Piel', price: '$780', sku: 'SKU-156', active: false },
								].map((p) => (
									<div class="rounded-lg p-2" style={`background: oklch(0.13 0.005 155); ${p.active ? `border: 1px solid ${ACCENT}40;` : 'border: 1px solid oklch(0.18 0.005 155);'}`}>
										<div class="w-full aspect-square rounded-md mb-1.5" style="background: oklch(0.18 0.005 155);"></div>
										<div class="text-[8px] text-white truncate">{p.name}</div>
										<div class="flex items-center justify-between mt-0.5">
											<span class="text-[8px]" style={`color: ${p.active ? ACCENT : 'oklch(0.50 0.005 155)'};`}>{p.price}</span>
											{p.active && <div class="w-3 h-3 rounded-full flex items-center justify-center text-[6px] font-bold text-black" style={`background: ${ACCENT};`}>1</div>}
										</div>
									</div>
								))}
							</div>
							<!-- Cart bar -->
							<div class="rounded-xl flex items-center justify-between px-4 py-2.5" style={`background: ${ACCENT};`}>
								<span class="text-[10px] font-semibold text-black">2 items — $1,248.00</span>
								<span class="text-[11px] font-bold text-black">Cobrar →</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 1. INVENTARIO                               -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-white border-t border-black/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<div>
						<span class="text-xs uppercase tracking-widest font-semibold mb-4 block" style={`color: ${ACCENT};`}>Inventario</span>
						<h2 class="text-4xl md:text-5xl font-light tracking-tight text-black mb-6 leading-tight">
							Control total de tu stock.
						</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-8">
							Sistema FIFO para rotacion optima de productos. Alertas de bajo stock, ordenes de compra automaticas y gestion de proveedores integrada. Cada unidad trackeada desde que entra al almacen hasta que se vende.
						</p>
						<div class="space-y-3">
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${ACCENT};`}></div>
								<span class="text-sm text-gray-600">Rotacion FIFO automatica — primero en entrar, primero en salir</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${AMBER};`}></div>
								<span class="text-sm text-gray-600">Alertas de bajo stock y auto-reorden configurable por producto</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${BLUE};`}></div>
								<span class="text-sm text-gray-600">Ordenes de compra integradas con directorio de proveedores</span>
							</div>
							<div class="flex items-start gap-3">
								<div class="w-1.5 h-1.5 rounded-full mt-2 shrink-0" style={`background: ${RED};`}></div>
								<span class="text-sm text-gray-600">Variantes por talla, color y SKU con stock independiente</span>
							</div>
						</div>
					</div>

					<!-- Inventory mockup -->
					<div class="rounded-xl overflow-hidden" style="box-shadow: 0 15px 40px rgba(0,0,0,0.12);">
						<div class="flex items-center gap-1.5 px-3 py-2" style="background: oklch(0.13 0.005 155);">
							<div class="w-2 h-2 rounded-full" style="background: #FF5F57;"></div>
							<div class="w-2 h-2 rounded-full" style="background: #FEBC2E;"></div>
							<div class="w-2 h-2 rounded-full" style="background: #28C840;"></div>
							<span class="text-[7px] ml-2" style="color: oklch(0.50 0.005 155);">dashboard.avoqado.io/inventario</span>
						</div>
						<div class="p-5" style="background: #0A0A0A;">
							<div class="flex items-center justify-between mb-4">
								<span class="text-[11px] text-gray-500">Inventario — 342 productos</span>
								<div class="flex gap-1.5">
									<span class="text-[8px] px-2 py-0.5 rounded-full bg-avoqado-green text-black">285 en stock</span>
									<span class="text-[8px] px-2 py-0.5 rounded-full" style={`background: oklch(0.18 0.02 75); color: ${AMBER};`}>12 bajo</span>
								</div>
							</div>
							<!-- Inventory list -->
							<div class="space-y-2 mb-4">
								<div class="flex items-center justify-between p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
									<div class="flex items-center gap-3">
										<div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: oklch(0.20 0.005 155);">
											<div class="w-5 h-5 rounded" style="background: oklch(0.25 0.005 155);"></div>
										</div>
										<div>
											<span class="text-xs text-white">Playera Basica — Negra M</span>
											<span class="text-[9px] text-gray-600 block">SKU-001-BLK-M</span>
										</div>
									</div>
									<div class="text-right flex items-center gap-3">
										<div class="w-16 h-1.5 rounded-full overflow-hidden" style="background: oklch(0.20 0.005 155);">
											<div class="h-full rounded-full" style={`width: 82%; background: ${ACCENT};`}></div>
										</div>
										<span class="text-xs text-white w-6 text-right">48</span>
									</div>
								</div>
								<div class="flex items-center justify-between p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
									<div class="flex items-center gap-3">
										<div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: oklch(0.20 0.005 155);">
											<div class="w-5 h-5 rounded" style="background: oklch(0.25 0.005 155);"></div>
										</div>
										<div>
											<span class="text-xs text-white">Jeans Slim — Azul 32</span>
											<span class="text-[9px] text-gray-600 block">SKU-045-BLU-32</span>
										</div>
									</div>
									<div class="text-right flex items-center gap-3">
										<div class="w-16 h-1.5 rounded-full overflow-hidden" style="background: oklch(0.20 0.005 155);">
											<div class="h-full rounded-full" style={`width: 35%; background: ${AMBER};`}></div>
										</div>
										<span class="text-xs" style={`color: ${AMBER};`}>7</span>
									</div>
								</div>
								<div class="flex items-center justify-between p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
									<div class="flex items-center gap-3">
										<div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: oklch(0.20 0.005 155);">
											<div class="w-5 h-5 rounded" style="background: oklch(0.25 0.005 155);"></div>
										</div>
										<div>
											<span class="text-xs text-white">Tenis Runner — Blanco 27</span>
											<span class="text-[9px] text-gray-600 block">SKU-203-WHT-27</span>
										</div>
									</div>
									<div class="text-right flex items-center gap-3">
										<div class="w-16 h-1.5 rounded-full overflow-hidden" style="background: oklch(0.20 0.005 155);">
											<div class="h-full rounded-full" style={`width: 12%; background: ${RED};`}></div>
										</div>
										<span class="text-xs" style={`color: ${RED};`}>2</span>
									</div>
								</div>
								<div class="flex items-center justify-between p-3 rounded-lg" style="background: oklch(0.16 0.005 155);">
									<div class="flex items-center gap-3">
										<div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: oklch(0.20 0.005 155);">
											<div class="w-5 h-5 rounded" style="background: oklch(0.25 0.005 155);"></div>
										</div>
										<div>
											<span class="text-xs text-white">Sudadera Over — Gris L</span>
											<span class="text-[9px] text-gray-600 block">SKU-078-GRY-L</span>
										</div>
									</div>
									<div class="text-right flex items-center gap-3">
										<div class="w-16 h-1.5 rounded-full overflow-hidden" style="background: oklch(0.20 0.005 155);">
											<div class="h-full rounded-full" style={`width: 60%; background: ${ACCENT};`}></div>
										</div>
										<span class="text-xs text-white w-6 text-right">24</span>
									</div>
								</div>
							</div>
							<!-- Purchase order alert -->
							<div class="rounded-lg p-3 flex items-center justify-between" style={`background: oklch(0.14 0.02 75); border: 1px solid oklch(0.25 0.04 75);`}>
								<div>
									<span class="text-[10px] text-white">Orden de compra sugerida</span>
									<span class="text-[9px] block" style={`color: ${AMBER};`}>3 productos bajo minimo — Proveedor: TextilMX</span>
								</div>
								<span class="text-[9px] px-2 py-0.5 rounded font-medium" style={`background: ${AMBER}; color: black;`}>Revisar</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>


		<!-- ═══════════════════════════════════════════ -->
		<!-- 2. PUNTO DE VENTA                           -->
		<!-- ═══════════════════════════════════════════ -->
		<section class="px-6 py-24 md:py-32 bg-black border-t border-white/5">
			<div class="max-w-[1400px] mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Payment mockup — iPad frame -->
					<div class="order-2 lg:order-1 rounded-[1.2rem] p-[5px]" style="background: linear-gradient(145deg, oklch(0.84 0.005 155), oklch(0.70 0.005 155)); box-shadow: 0 15px 40px rgba(0,0,0,0.12);">
						<div class="rounded-[0.9rem] p-[3px] relative" style="background: oklch(0.12 0.005 155);">
							<div class="absolute top-[5px] left-1/2 -translate-x-1/2 w-[4px] h-[4px] rounded-full" style="background: oklch(0.22 0.005 155);"></div>
							<div class="rounded-[0.7rem] overflow-hidden p-5" style="background: oklch(0.12 0.005 155);">
								<div class="flex items-center justify-between mb-4">
									<span class="text-[11px] text-gray-500">Cobro — Venta #1847</span>
									<span class="text-[9px] px-2 py-0.5 rounded-full bg-avoqado-green text-black font-medium">Terminal lista</span>
								</div>
								<!-- Amount display -->
								<div class="text-center py-6 mb-4 rounded-xl" style="background: oklch(0.16 0.005 155);">
									<div class="text-[10px] text-gray-500 mb-1">Total a cobrar</div>
									<div class="text-4xl font-light text-white">$1,248<span class="text-lg text-gray-500">.00</span></div>
									<div class="text-[10px] text-gray-600 mt-1">2 articulos — IVA incluido</div>
								</div>
								<!-- Payment methods -->
								<div class="grid grid-cols-2 gap-2 mb-4">
									<div class="rounded-xl p-3 text-center" style={`background: oklch(0.14 0.02 155); border: 1px solid oklch(0.25 0.04 155);`}>
										<svg class="mx-auto mb-1.5" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={ACCENT} stroke-width="1.5" stroke-linecap="round"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
										<span class="text-[10px] text-white block">Tarjeta</span>
										<span class="text-[8px] text-gray-600">NFC / Chip / Banda</span>
									</div>
									<div class="rounded-xl p-3 text-center" style="background: oklch(0.16 0.005 155);">
										<svg class="mx-auto mb-1.5" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.50 0.005 155)" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h3v3H7z"/><path d="M14 7h3v3h-3z"/><path d="M7 14h3v3H7z"/></svg>
										<span class="text-[10px] text-white block">QR</span>
										<span class="text-[8px] text-gray-600">CoDi / Transferencia</span>
									</div>
									<div class="rounded-xl p-3 text-center" style="background: oklch(0.16 0.005 155);">
										<svg class="mx-auto mb-1.5" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.50 0.005 155)" stroke-width="1.5" stroke-linecap="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
