---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/layout/Footer.astro';
import Navbar from '../components/layout/Navbar.astro';
---

<Layout title="Avoqado para Retail | Punto de venta para tiendas" description="Gestiona inventario, cobra y analiza tu negocio retail con Avoqado. Terminal TPV, dashboard y pagos QR en una sola plataforma.">
  <body class="bg-white min-h-screen">

    <Navbar position="fixed" transparentOnTop={false} />

    <!-- Hero Section - Square style: clean, white, big typography -->
    <section class="pt-32 pb-20 lg:pt-40 lg:pb-28 bg-white">
      <div class="max-w-[1400px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div>
            <p class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Avoqado para Retail</p>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-black leading-[1.05] tracking-tight mb-6">
              Vende más.<br/>
              Gestiona mejor.
            </h1>
            <p class="text-xl text-gray-600 leading-relaxed mb-8 max-w-lg">
              Todo lo que tu tienda necesita en un solo sistema: cobros, inventario, clientes y reportes. Sin complicaciones.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-black text-white rounded-full font-semibold text-base hover:bg-gray-800 transition-colors">
                Comenzar gratis
              </a>
              <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 border-2 border-gray-300 text-black rounded-full font-semibold text-base hover:border-black transition-colors">
                Contactar ventas
              </a>
            </div>
          </div>
          <!-- Hero Image Placeholder -->
          <div class="relative">
            <div class="aspect-[4/3] bg-gray-100 rounded-3xl overflow-hidden">
              <div class="w-full h-full bg-gradient-to-br from-gray-50 to-gray-200 flex items-center justify-center">
                <div class="w-3/4 h-4/5 bg-white rounded-2xl shadow-2xl p-6 flex flex-col">
                  <div class="flex items-center gap-3 mb-6">
                    <div class="w-3 h-3 rounded-full bg-red-400"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                    <div class="w-3 h-3 rounded-full bg-green-400"></div>
                  </div>
                  <div class="flex-1 grid grid-cols-3 gap-3">
                    <div class="col-span-2 bg-gray-50 rounded-xl p-4">
                      <div class="h-3 w-20 bg-gray-200 rounded mb-3"></div>
                      <div class="grid grid-cols-2 gap-2">
                        <div class="aspect-square bg-gray-100 rounded-lg"></div>
                        <div class="aspect-square bg-gray-100 rounded-lg"></div>
                        <div class="aspect-square bg-gray-100 rounded-lg"></div>
                        <div class="aspect-square bg-gray-100 rounded-lg"></div>
                      </div>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-3">
                      <div class="h-2 w-12 bg-gray-200 rounded mb-3"></div>
                      <div class="space-y-2">
                        <div class="h-8 bg-gray-100 rounded-lg"></div>
                        <div class="h-8 bg-gray-100 rounded-lg"></div>
                        <div class="h-8 bg-gray-100 rounded-lg"></div>
                      </div>
                      <div class="mt-4 h-10 bg-black rounded-lg"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Bar -->
    <section class="py-12 border-y border-gray-100 bg-white">
      <div class="max-w-[1400px] mx-auto px-6">
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16">
          <p class="text-sm text-gray-400 font-medium">Usado por tiendas en</p>
          <div class="flex flex-wrap items-center gap-8 md:gap-12">
            <span class="text-gray-300 font-bold text-lg">CDMX</span>
            <span class="text-gray-300 font-bold text-lg">Monterrey</span>
            <span class="text-gray-300 font-bold text-lg">Guadalajara</span>
            <span class="text-gray-300 font-bold text-lg">Playa del Carmen</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Section 1: Point of Sale -->
    <section id="punto-de-venta" class="py-24 bg-white">
      <div class="max-w-[1400px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="order-2 lg:order-1">
            <div class="aspect-[4/3] bg-gray-50 rounded-3xl overflow-hidden flex items-center justify-center">
              <!-- Simulated POS Screen -->
              <div class="w-4/5 h-4/5 bg-black rounded-2xl p-4 text-white">
                <div class="flex items-center justify-between mb-4">
                  <span class="text-sm font-medium">Avoqado TPV</span>
                  <span class="text-xs text-gray-400">14:32</span>
                </div>
                <div class="grid grid-cols-3 gap-2 mb-4">
                  <div class="aspect-square bg-gray-800 rounded-xl flex flex-col items-center justify-center p-2">
                    <div class="w-6 h-6 bg-blue-500 rounded-lg mb-1"></div>
                    <span class="text-[10px] text-gray-300">Camiseta</span>
                    <span class="text-xs font-bold">$450</span>
                  </div>
                  <div class="aspect-square bg-gray-800 rounded-xl flex flex-col items-center justify-center p-2">
                    <div class="w-6 h-6 bg-green-500 rounded-lg mb-1"></div>
                    <span class="text-[10px] text-gray-300">Zapatos</span>
                    <span class="text-xs font-bold">$1,200</span>
                  </div>
                  <div class="aspect-square bg-gray-800 rounded-xl flex flex-col items-center justify-center p-2">
                    <div class="w-6 h-6 bg-purple-500 rounded-lg mb-1"></div>
                    <span class="text-[10px] text-gray-300">Gorra</span>
                    <span class="text-xs font-bold">$350</span>
                  </div>
                </div>
                <div class="bg-gray-800 rounded-xl p-3">
                  <div class="flex justify-between text-sm mb-2">
                    <span class="text-gray-400">Subtotal</span>
                    <span>$2,000.00</span>
                  </div>
                  <div class="flex justify-between text-sm font-bold">
                    <span>Total</span>
                    <span>$2,000.00</span>
                  </div>
                </div>
                <div class="mt-3 bg-white text-black rounded-xl py-2.5 text-center font-bold text-sm">
                  Cobrar
                </div>
              </div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <p class="text-sm font-semibold text-blue-600 uppercase tracking-wider mb-3">Punto de venta</p>
            <h2 class="text-4xl md:text-5xl font-bold text-black leading-tight mb-6">
              Cobra rápido,<br/>vende más.
            </h2>
            <p class="text-lg text-gray-600 leading-relaxed mb-8">
              Interfaz intuitiva diseñada para retail. Escaneo de códigos de barras, búsqueda rápida de productos, descuentos y devoluciones en segundos.
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Acepta tarjetas, efectivo, QR y contactless</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Escaneo de código de barras integrado</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Descuentos, promociones y devoluciones rápidas</span>
              </li>
            </ul>
            <a href="/productos/tpv" class="inline-flex items-center gap-2 mt-8 text-base font-semibold text-black hover:underline">
              Conocer más sobre el TPV
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Section 2: Inventory -->
    <section id="inventario" class="py-24 bg-gray-50">
      <div class="max-w-[1400px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-sm font-semibold text-green-600 uppercase tracking-wider mb-3">Inventario</p>
            <h2 class="text-4xl md:text-5xl font-bold text-black leading-tight mb-6">
              Controla tu stock<br/>en tiempo real.
            </h2>
            <p class="text-lg text-gray-600 leading-relaxed mb-8">
              Sabe exactamente qué tienes, qué se vende y qué necesitas pedir. Alertas automáticas de stock bajo y reportes de rotación.
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Gestión de variantes (talla, color, modelo)</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Alertas automáticas de stock bajo</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Importación masiva desde CSV/Excel</span>
              </li>
            </ul>
            <a href="/productos/dashboard" class="inline-flex items-center gap-2 mt-8 text-base font-semibold text-black hover:underline">
              Ver gestión de inventario
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
          <div>
            <div class="aspect-[4/3] bg-white rounded-3xl shadow-lg overflow-hidden p-8 flex items-center justify-center">
              <!-- Simulated Inventory Dashboard -->
              <div class="w-full space-y-4">
                <div class="flex items-center justify-between">
                  <h3 class="text-lg font-bold text-black">Inventario</h3>
                  <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full font-medium">324 productos</span>
                </div>
                <div class="space-y-3">
                  <div class="flex items-center gap-4 p-3 bg-gray-50 rounded-xl">
                    <div class="w-10 h-10 bg-blue-100 rounded-lg"></div>
                    <div class="flex-1">
                      <p class="text-sm font-medium text-black">Camiseta Basica Blanca</p>
                      <p class="text-xs text-gray-500">SKU: CB-001 | S, M, L, XL</p>
                    </div>
                    <div class="text-right">
                      <p class="text-sm font-bold text-black">$450</p>
                      <p class="text-xs text-green-600">42 en stock</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-4 p-3 bg-gray-50 rounded-xl">
                    <div class="w-10 h-10 bg-purple-100 rounded-lg"></div>
                    <div class="flex-1">
                      <p class="text-sm font-medium text-black">Jean Slim Fit</p>
                      <p class="text-xs text-gray-500">SKU: JS-002 | 28-36</p>
                    </div>
                    <div class="text-right">
                      <p class="text-sm font-bold text-black">$890</p>
                      <p class="text-xs text-orange-600">3 en stock</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-4 p-3 bg-gray-50 rounded-xl">
                    <div class="w-10 h-10 bg-green-100 rounded-lg"></div>
                    <div class="flex-1">
                      <p class="text-sm font-medium text-black">Tenis Running Pro</p>
                      <p class="text-xs text-gray-500">SKU: TR-003 | 25-30</p>
                    </div>
                    <div class="text-right">
                      <p class="text-sm font-bold text-black">$1,890</p>
                      <p class="text-xs text-red-600">0 en stock</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Section 3: Analytics -->
    <section id="analytics" class="py-24 bg-white">
      <div class="max-w-[1400px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="order-2 lg:order-1">
            <div class="aspect-[4/3] bg-gray-50 rounded-3xl overflow-hidden p-8 flex items-center justify-center">
              <!-- Simulated Analytics Dashboard -->
              <div class="w-full space-y-4">
                <div class="flex items-center justify-between">
                  <h3 class="text-lg font-bold text-black">Ventas de hoy</h3>
                  <span class="text-xs text-gray-500">31 Ene 2026</span>
                </div>
                <div class="grid grid-cols-3 gap-3">
                  <div class="bg-white rounded-xl p-4 shadow-sm">
                    <p class="text-xs text-gray-500">Ventas</p>
                    <p class="text-2xl font-bold text-black">$24,580</p>
                    <p class="text-xs text-green-600 mt-1">+12% vs ayer</p>
                  </div>
                  <div class="bg-white rounded-xl p-4 shadow-sm">
                    <p class="text-xs text-gray-500">Tickets</p>
                    <p class="text-2xl font-bold text-black">47</p>
                    <p class="text-xs text-green-600 mt-1">+8% vs ayer</p>
                  </div>
                  <div class="bg-white rounded-xl p-4 shadow-sm">
                    <p class="text-xs text-gray-500">Ticket prom.</p>
                    <p class="text-2xl font-bold text-black">$523</p>
                    <p class="text-xs text-green-600 mt-1">+4% vs ayer</p>
                  </div>
                </div>
                <!-- Simple bar chart -->
                <div class="bg-white rounded-xl p-4 shadow-sm">
                  <p class="text-xs text-gray-500 mb-3">Ventas por hora</p>
                  <div class="flex items-end gap-1.5 h-20">
                    <div class="flex-1 bg-gray-200 rounded-t-sm" style="height: 20%"></div>
                    <div class="flex-1 bg-gray-200 rounded-t-sm" style="height: 15%"></div>
                    <div class="flex-1 bg-gray-200 rounded-t-sm" style="height: 40%"></div>
                    <div class="flex-1 bg-gray-200 rounded-t-sm" style="height: 65%"></div>
                    <div class="flex-1 bg-gray-200 rounded-t-sm" style="height: 80%"></div>
                    <div class="flex-1 bg-black rounded-t-sm" style="height: 100%"></div>
                    <div class="flex-1 bg-black rounded-t-sm" style="height: 90%"></div>
                    <div class="flex-1 bg-gray-200 rounded-t-sm" style="height: 70%"></div>
                    <div class="flex-1 bg-gray-200 rounded-t-sm" style="height: 55%"></div>
                    <div class="flex-1 bg-gray-200 rounded-t-sm" style="height: 30%"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <p class="text-sm font-semibold text-purple-600 uppercase tracking-wider mb-3">Analytics</p>
            <h2 class="text-4xl md:text-5xl font-bold text-black leading-tight mb-6">
              Datos que impulsan<br/>decisiones.
            </h2>
            <p class="text-lg text-gray-600 leading-relaxed mb-8">
              Entiende qué se vende, cuándo y por qué. Dashboard en tiempo real con insights accionables y un consultor IA que te ayuda a tomar mejores decisiones.
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Reportes de ventas, productos y personal</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Consultor IA integrado en el dashboard</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Acceso desde cualquier dispositivo</span>
              </li>
            </ul>
            <a href="/productos/dashboard" class="inline-flex items-center gap-2 mt-8 text-base font-semibold text-black hover:underline">
              Explorar el Dashboard
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Section 4: Customers & Loyalty -->
    <section id="clientes" class="py-24 bg-gray-50">
      <div class="max-w-[1400px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-sm font-semibold text-orange-600 uppercase tracking-wider mb-3">Clientes</p>
            <h2 class="text-4xl md:text-5xl font-bold text-black leading-tight mb-6">
              Conoce a tus<br/>clientes.
            </h2>
            <p class="text-lg text-gray-600 leading-relaxed mb-8">
              Construye relaciones que generan ventas recurrentes. Perfiles automáticos, historial de compras y comunicación directa.
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Perfiles automáticos con historial de compras</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Segmentación por frecuencia y ticket promedio</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </div>
                <span class="text-gray-700">Recibos digitales con branding personalizado</span>
              </li>
            </ul>
            <a href="/productos/dashboard" class="inline-flex items-center gap-2 mt-8 text-base font-semibold text-black hover:underline">
              Ver gestión de clientes
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
          <div>
            <div class="aspect-[4/3] bg-white rounded-3xl shadow-lg overflow-hidden p-8 flex items-center justify-center">
              <!-- Simulated Customer Profile -->
              <div class="w-full space-y-4">
                <div class="flex items-center gap-4 mb-6">
                  <div class="w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center">
                    <span class="text-xl font-bold text-gray-400">MA</span>
                  </div>
                  <div>
                    <p class="text-base font-bold text-black">Maria Alejandra Lopez</p>
                    <p class="text-sm text-gray-500">Cliente desde Mar 2025</p>
                  </div>
                </div>
                <div class="grid grid-cols-3 gap-3">
                  <div class="bg-gray-50 rounded-xl p-3 text-center">
                    <p class="text-xs text-gray-500">Visitas</p>
                    <p class="text-lg font-bold text-black">23</p>
                  </div>
                  <div class="bg-gray-50 rounded-xl p-3 text-center">
                    <p class="text-xs text-gray-500">Total gastado</p>
                    <p class="text-lg font-bold text-black">$18.4k</p>
                  </div>
                  <div class="bg-gray-50 rounded-xl p-3 text-center">
                    <p class="text-xs text-gray-500">Ticket prom.</p>
                    <p class="text-lg font-bold text-black">$800</p>
                  </div>
                </div>
                <div>
                  <p class="text-xs text-gray-500 mb-2">Últimas compras</p>
                  <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-700">Jean Slim Fit x1</span>
                      <span class="text-black font-medium">$890</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-700">Camiseta Basica x2</span>
                      <span class="text-black font-medium">$900</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hardware Section -->
