---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import AvoqadoTour from '../components/interactive/tour/AvoqadoTour';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Prueba Avoqado — demo interactivo</title>
		<meta
			name="description"
			content="Prueba Avoqado sin registrarte: cobra en una terminal real, recibe una reserva en línea y crea una liga de pago — demos interactivos guiados en tu navegador."
		/>
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-black m-0 p-0 w-full antialiased overflow-x-hidden">
		<Navbar position="fixed" transparentOnTop={false} />

		<!-- ═══════════════════════════════════════════ -->
		<!-- AVOQADO TOUR — interactive guided TPV demo  -->
		<!-- ═══════════════════════════════════════════ -->
		<!-- header compacto: en laptops de 900px el primer target guiado debe
		     quedar sobre el fold (QA de conversión) -->
		<main
			class="min-h-screen pt-24 md:pt-28 pb-24 px-4 sm:px-6"
			style="background: radial-gradient(900px 600px at 42% 30%, rgba(16,185,129,0.07), transparent 65%), #0D0E0D;"
		>
			<header class="text-center mb-6 md:mb-8 max-w-2xl mx-auto">
				<div class="inline-flex items-center gap-2 text-xs font-bold tracking-wide lowercase" style="color: #34D399;">
					<span class="w-2 h-2 rounded-full" style="background: #10B981; box-shadow: 0 0 10px rgba(16,185,129,0.8);"></span>
					avoqado tour
				</div>
				<h1 class="mt-2 text-2xl md:text-3xl font-semibold tracking-tight text-white">Prueba Avoqado en 60 segundos</h1>
				<p class="mt-1.5 text-sm text-gray-500">
					Sigue el punto verde: cobra en la terminal, recibe una reserva o crea una liga de pago. Sin registro, sin tarjeta.
				</p>
			</header>

			<AvoqadoTour client:load />
		</main>

		<Footer />
	</body>
</html>
