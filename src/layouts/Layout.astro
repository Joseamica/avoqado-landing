---
import '../styles/global.css';
import CookieConsent from '../components/interactive/CookieConsent';

import GlobalSearch from '../components/interactive/GlobalSearch';

import SEO from '../components/layout/SEO.astro';
import StructuredData from '../components/layout/StructuredData.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article' | 'product';
	noindex?: boolean;
	/** Set on pages whose hero/top content is LIGHT so the navbar renders its dark (visible)
	 *  text + logo from the first paint, instead of relying on runtime background sampling. */
	navLight?: boolean;
}

const {
	title,
	description = 'Avoqado - Soluciones de pago diseñadas para los mejores restaurantes del mundo. Pagos instantáneos, analytics con IA y gestión completa.',
	image,
	type = 'website',
	noindex = false,
	navLight = false
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" type="image/png" href="/favicon.png?v=2" />
		<link rel="shortcut icon" href="/favicon.ico?v=2" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Component -->
		<SEO
			title={title}
			description={description}
			image={image}
			type={type}
			noindex={noindex}
		/>

		<!-- Structured Data -->
		<StructuredData type="Organization" />
	</head>
	<body class="antialiased overflow-x-hidden" data-nav-light={navLight ? 'true' : undefined}>
		<slot />
		<!-- <FloatingChatbot client:idle /> -->
		<GlobalSearch client:load />
		<CookieConsent client:idle />
	</body>
</html>
